## App
NODE_ENV=development
PORT=3000
BASE_URL=http://localhost:3000
# عنوان الخادم داخل تطبيق Android (Capacitor): محاكي = http://10.0.2.2:PORT، جهاز حقيقي = http://IP_الشبكة:PORT، إنتاج = https://نطاقك
CAPACITOR_SERVER_URL=http://10.0.2.2:3000
CORS_ORIGINS=http://localhost:3000
TRUST_PROXY=1
CDN_BASE_URL=
REDIS_URL=
EMAIL_WORKER_CONCURRENCY=5
ALERT_WEBHOOK_URL=
LOAD_TEST_MODE=false
LOG_LEVEL=info
HOMEPAGE_CASES_LIMIT=8
HOMEPAGE_TESTIMONIALS_LIMIT=12
STORIES_PAGE_LIMIT=60
REDIS_CONNECT_TIMEOUT_MS=10000
REDIS_KEEPALIVE_MS=30000
REDIS_RETRY_BASE_MS=200
REDIS_RETRY_MAX_MS=5000
RATE_LIMIT_REDIS=true
EMAIL_QUEUE_ATTEMPTS=3
EMAIL_QUEUE_BACKOFF_MS=2000
EMAIL_QUEUE_KEEP_COMPLETE=1000
EMAIL_QUEUE_KEEP_FAILED=2000
MONGO_MAX_POOL_SIZE=50
MONGO_MIN_POOL_SIZE=5
MONGO_SERVER_SELECTION_TIMEOUT_MS=10000
MONGO_SOCKET_TIMEOUT_MS=45000
SOCKET_VERBOSE_LOGS=false
SOCKET_REDIS_ADAPTER=true
SERVER_KEEP_ALIVE_TIMEOUT_MS=65000
SERVER_HEADERS_TIMEOUT_MS=70000
APP_BODY_LIMIT=5mb
SESSION_SAME_SITE=lax
CSRF_SAME_SITE=lax
AUTH_RATE_LIMIT_MAX=25
PAYMENT_RATE_LIMIT_MAX=35
API_RATE_LIMIT_MAX=3000
DISABLE_LOGIN=false
STRICT_ENV_VALIDATION=false

