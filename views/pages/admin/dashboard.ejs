<%- include('../../partials/admin-layout-top') %>

<!-- Admin Header Info (Updated for Professional Sidebar) -->
<div style="margin-bottom: 40px; background: white; padding: 30px; border-radius: var(--radius-md); border: 1px solid #e2e8f0;">
    <span class="section-badge" style="margin: 0 0 10px 0;"><i class="fas fa-shield-alt"></i> <%= __('admin_dashboard_badge') %></span>
    <h2 class="font-cairo" style="margin: 0; font-weight: 800;"><%= __('admin_dashboard_title') %></h2>
    <p style="color: var(--text-muted); margin-top: 5px;"><%= __('admin_dashboard_welcome') %><%= user.name %><%= __('admin_dashboard_welcome_desc') %></p>
</div>

    <!-- Executive Stats -->
    <div class="<%= user.role === 'super_admin' ? 'grid-4' : 'grid-3' %>" style="gap: 20px; margin-bottom: 50px; display: grid; grid-template-columns: repeat(<%= user.role === 'super_admin' ? 4 : 3 %>, 1fr);">
        <div class="luxury-card glass-panel" style="padding: 30px 15px; text-align: center; border-bottom: 4px solid var(--secondary);">
            <div style="font-size: 2.5rem; color: var(--secondary); margin-bottom: 15px;"><i class="fas fa-vault"></i></div>
            <div style="font-size: 0.85rem; color: var(--text-muted); margin-bottom: 5px;"><%= __('admin_dashboard_total_donations') %></div>
            <div style="font-size: 1.8rem; font-weight: 800; color: var(--primary);">$<%= stats.totalDonations %></div>
        </div>
        <% if (user.role === 'super_admin') { %>
            <div class="luxury-card glass-panel" style="padding: 30px 15px; text-align: center; border-bottom: 4px solid #8b5cf6;">
                <div style="font-size: 2.5rem; color: #8b5cf6; margin-bottom: 15px;"><i class="fas fa-chart-line"></i></div>
                <div style="font-size: 0.85rem; color: var(--text-muted); margin-bottom: 5px;"><%= __('admin_dashboard_operation_fees') %></div>
                <div style="font-size: 1.8rem; font-weight: 800; color: var(--primary); margin-bottom: 10px;">$<%= stats.operationFees.toFixed(2) %></div>
                <a href="/admin/operation-fees" class="btn-lux btn-lux-outline btn-sm" style="padding: 4px 12px; font-size: 0.75rem; border-color: #8b5cf6; color: #8b5cf6;">
                    <i class="fas fa-eye"></i> <%= __('admin_common_view_details') %>
                </a>
            </div>
        <% } %>
        <div class="luxury-card glass-panel" style="padding: 30px 15px; text-align: center; border-bottom: 4px solid var(--accent);">
            <div style="font-size: 2.5rem; color: var(--accent); margin-bottom: 15px;"><i class="fas fa-handshake-angle"></i></div>
            <div style="font-size: 0.85rem; color: var(--text-muted); margin-bottom: 5px;"><%= __('admin_dashboard_active_sponsorships') %></div>
            <div style="font-size: 1.8rem; font-weight: 800; color: var(--primary);"><%= stats.activeSponsorships %></div>
        </div>
        <div class="luxury-card glass-panel" style="padding: 30px 15px; text-align: center; border-bottom: 4px solid #10b981;">
            <div style="font-size: 2.5rem; color: #10b981; margin-bottom: 15px;"><i class="fas fa-user-shield"></i></div>
            <div style="font-size: 0.85rem; color: var(--text-muted); margin-bottom: 5px;"><%= __('admin_dashboard_total_users') %></div>
            <div style="font-size: 1.8rem; font-weight: 800; color: var(--primary);"><%= stats.totalUsers %></div>
        </div>
    </div>

    <!-- Pending Reviews -->
    <div class="grid-2" style="gap: 40px; grid-template-columns: 1fr 1fr;">
        <!-- Cases to Approve -->
        <div>
            <div class="section-header-luxury" style="margin-bottom: 25px; display: flex; justify-content: space-between; align-items: center;">
                <h3 class="font-cairo" style="margin: 0;"><i class="fas fa-clock"></i> <%= __('admin_dashboard_pending_cases') %></h3>
                <a href="/admin/cases-manager" style="font-size: 0.85rem; font-weight: 700; color: var(--secondary);"><%= __('admin_common_view_all') %> <i class="fas fa-chevron-<%= langDir === 'rtl' ? 'left' : 'right' %>"></i></a>
            </div>
            <% if (pendingCases.length > 0) { %>
                <div class="luxury-card glass-panel" style="padding: 0; overflow: hidden;">
                    <table style="width: 100%; border-collapse: collapse; text-align: right;">
                        <thead style="background: rgba(0,0,0,0.02); border-bottom: 1px solid rgba(0,0,0,0.05);">
                            <tr>
                                <th style="padding: 15px 20px;"><%= __('admin_dashboard_table_case') %></th>
                                <th style="padding: 15px 20px;"><%= __('admin_dashboard_table_date') %></th>
                                <th style="padding: 15px 20px;"><%= __('admin_dashboard_table_action') %></th>
                            </tr>
                        </thead>
                        <tbody>
                            <% pendingCases.forEach(item => { %>
                                <tr style="border-bottom: 1px solid rgba(0,0,0,0.03);">
                                    <td style="padding: 15px 20px;">
                                        <div style="font-weight: 700;"><%= item.title %></div>
                                        <div style="font-size: 0.8rem; color: var(--text-muted);"><%= item.location %></div>
                                    </td>
                                    <td style="padding: 15px 20px; font-size: 0.85rem;"><%= item.createdAt.toLocaleDateString(lang === 'ar' ? 'ar-EG' : 'en-US') %></td>
                                    <td style="padding: 15px 20px;">
                                        <a href="/admin/cases-manager?status=pending" class="btn-lux btn-lux-navy" style="padding: 5px 12px; font-size: 0.8rem;"><%= __('admin_dashboard_btn_review_case') %></a>
                                    </td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            <% } else { %>
                <div class="luxury-card glass-panel" style="padding: 40px; text-align: center; color: var(--text-muted);">
                    <i class="fas fa-check-double" style="font-size: 2rem; opacity: 0.3; margin-bottom: 10px;"></i>
                    <p><%= __('admin_dashboard_empty_cases') %></p>
                </div>
            <% } %>
        </div>

        <!-- Transactions to Verify -->
        <div>
            <div class="section-header-luxury" style="margin-bottom: 25px;">
                <h3 class="font-cairo"><i class="fas fa-money-bill-transfer"></i> <%= __('admin_dashboard_pending_transactions') %></h3>
            </div>
            <% if (pendingTransactions.length > 0) { %>
                <div class="luxury-card glass-panel" style="padding: 0; overflow: hidden;">
                    <table style="width: 100%; border-collapse: collapse; text-align: right;">
                        <thead style="background: rgba(0,0,0,0.02); border-bottom: 1px solid rgba(0,0,0,0.05);">
                            <tr>
                                <th style="padding: 15px 20px;"><%= __('admin_dashboard_table_amount') %></th>
                                <th style="padding: 15px 20px;"><%= __('admin_dashboard_table_donor') %></th>
                                <th style="padding: 15px 20px;"><%= __('admin_dashboard_table_action') %></th>
                            </tr>
                        </thead>
                        <tbody>
                            <% pendingTransactions.forEach(trans => { %>
                                <tr style="border-bottom: 1px solid rgba(0,0,0,0.03);">
                                    <td style="padding: 15px 20px; font-weight: 800; color: var(--secondary);">$<%= trans.amount %></td>
                                    <td style="padding: 15px 20px; font-size: 0.85rem;"><%= trans.donor ? trans.donor.name : 'Unknown' %></td>
                                    <td style="padding: 15px 20px;">
                                        <div style="display: flex; gap: 5px;">
                                            <a href="<%= trans.receiptImage %>" target="_blank" class="btn-lux btn-lux-navy" style="padding: 5px 12px; font-size: 0.8rem;"><%= __('admin_dashboard_btn_receipt') %></a>
                                            <form action="/admin/transactions/<%= trans._id %>/status" method="POST">
                                                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                                <input type="hidden" name="status" value="verified">
                                                <button type="submit" class="btn-lux btn-lux-primary" style="padding: 5px 12px; font-size: 0.8rem;"><%= __('admin_dashboard_btn_verify') %></button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            <% } else { %>
                <div class="luxury-card glass-panel" style="padding: 40px; text-align: center; color: var(--text-muted);">
                    <i class="fas fa-coins" style="font-size: 2rem; opacity: 0.3; margin-bottom: 10px;"></i>
                    <p><%= __('admin_dashboard_empty_transactions') %></p>
                </div>
            <% } %>
        </div>
    </div>

    <!-- Phase 11: Impact Proofs Pending Review -->
    <div style="margin-top: 40px;">
        <div class="section-header-luxury" style="margin-bottom: 25px; display: flex; justify-content: space-between; align-items: center;">
            <h3 class="font-cairo" style="margin: 0;"><i class="fas fa-file-shield"></i> <%= __('admin_dashboard_pending_impact_proofs') %></h3>
            <a href="/admin/pending-impact-proofs" style="font-size: 0.85rem; font-weight: 700; color: var(--secondary);"><%= __('admin_common_review_all') %> <i class="fas fa-chevron-<%= langDir === 'rtl' ? 'left' : 'right' %>"></i></a>
        </div>
        
        <% if (pendingImpactProofs && pendingImpactProofs.length > 0) { %>
            <div class="luxury-card glass-panel" style="padding: 0; overflow: hidden;">
                <table style="width: 100%; border-collapse: collapse; text-align: right;">
                    <thead style="background: rgba(0,0,0,0.02); border-bottom: 1px solid rgba(0,0,0,0.05);">
                        <tr>
                            <th style="padding: 15px 20px;"><%= __('admin_dashboard_table_title') %></th>
                            <th style="padding: 15px 20px;"><%= __('admin_dashboard_table_related_case') %></th>
                            <th style="padding: 15px 20px;"><%= __('admin_dashboard_table_upload_date') %></th>
                            <th style="padding: 15px 20px;"><%= __('admin_dashboard_table_action') %></th>
                        </tr>
                    </thead>
                    <tbody>
                        <% pendingImpactProofs.forEach(proof => { %>
                            <tr style="border-bottom: 1px solid rgba(0,0,0,0.03);">
                                <td style="padding: 15px 20px; font-weight: 700;"><%= proof.title %></td>
                                <td style="padding: 15px 20px; font-size: 0.85rem;"><%= proof.case ? proof.case.title : '---' %></td>
                                <td style="padding: 15px 20px; font-size: 0.85rem;"><%= new Date(proof.createdAt).toLocaleDateString(lang === 'ar' ? 'ar-EG' : 'en-US') %></td>
                                <td style="padding: 15px 20px;">
                                    <a href="/admin/pending-impact-proofs" class="btn-lux btn-lux-navy" style="padding: 5px 12px; font-size: 0.8rem;"><%= __('admin_dashboard_btn_preview_impact') %></a>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        <% } else { %>
            <div class="luxury-card glass-panel" style="padding: 40px; text-align: center; color: var(--text-muted);">
                <i class="fas fa-shield-check" style="font-size: 2rem; opacity: 0.3; margin-bottom: 10px;"></i>
                <p><%= __('admin_dashboard_empty_impact_proofs') %></p>
            </div>
        <% } %>
    </div>
<%- include('../../partials/admin-layout-bottom') %>