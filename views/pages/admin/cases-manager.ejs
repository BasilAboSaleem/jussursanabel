<%- include('../../partials/admin-layout-top') %>

<div class="luxury-card glass-panel" style="padding: 25px 30px; margin-bottom: 25px; border-<%= langDir === 'rtl' ? 'right' : 'left' %>: 4px solid var(--secondary);">
    <div style="display: flex; justify-content: space-between; align-items: flex-start; flex-wrap: wrap; gap: 20px;">
        <div>
            <h3 class="font-cairo" style="margin: 0; font-weight: 800;"><i class="fas fa-folder-tree" style="color: var(--primary);"></i> <%= __('admin_cases_manager_title') %></h3>
            <p style="color: var(--text-muted); margin-top: 8px; font-size: 0.95rem;"><%= __('admin_cases_manager_desc') %></p>
        </div>
        <div style="text-align: <%= langDir === 'rtl' ? 'left' : 'right' %>;">
            <div style="font-size: 0.8rem; color: var(--text-muted); font-weight: 600;"><%= __('admin_cases_manager_total_label') || 'إجمالي الحالات هنا' %></div>
            <div style="font-size: 1.8rem; font-weight: 800; color: var(--primary); line-height: 1;"><%= cases.length %></div>
        </div>
    </div>
    
    <div style="margin-top: 25px; display: flex; flex-wrap: wrap; gap: 15px; align-items: center; justify-content: space-between; background: rgba(0,0,0,0.02); padding: 15px; border-radius: 12px; border: 1px solid rgba(0,0,0,0.05);">
        <div style="display: flex; gap: 10px; overflow-x: auto; padding-bottom: 5px;">
            <a href="/admin/cases-manager" class="btn-lux btn-sm <%= currentStatus === 'all' ? 'btn-lux-primary' : 'btn-lux-outline' %>" style="white-space: nowrap;"><%= __('common_all') %></a>
            <a href="/admin/cases-manager?status=pending" class="btn-lux btn-sm <%= currentStatus === 'pending' ? 'btn-lux-primary' : 'btn-lux-outline' %>" style="white-space: nowrap;"><%= __('common_pending') %></a>
            <a href="/admin/cases-manager?status=field_verification" class="btn-lux btn-sm <%= currentStatus === 'field_verification' ? 'btn-lux-primary' : 'btn-lux-outline' %>" style="white-space: nowrap;"><%= __('common_field_verification') %></a>
            <a href="/admin/cases-manager?status=approved" class="btn-lux btn-sm <%= currentStatus === 'approved' ? 'btn-lux-primary' : 'btn-lux-outline' %>" style="white-space: nowrap;"><%= __('common_approved') %></a>
        </div>
        
        <div style="position: relative; flex: 1; max-width: 350px;">
            <i class="fas fa-search" style="position: absolute; right: <%= langDir === 'rtl' ? '15px' : 'auto' %>; left: <%= langDir === 'rtl' ? 'auto' : '15px' %>; top: 50%; transform: translateY(-50%); color: var(--text-muted);"></i>
            <input type="text" id="liveSearchInput" onkeyup="filterCasesTable()" placeholder="<%= __('common_search') || 'بحث برقم الحالة (JSR) أو الاسم...' %>" class="form-input" style="padding-<%= langDir === 'rtl' ? 'right' : 'left' %>: 45px; width: 100%; margin: 0; background: #fff; border: 1px solid rgba(0,0,0,0.1); height: 42px;">
        </div>
    </div>
</div>

<div class="luxury-card" style="padding: 0; overflow: hidden;">
    <table style="width: 100%; border-collapse: collapse; text-align: <%= langDir === 'rtl' ? 'right' : 'left' %>;">
        <thead>
            <tr style="background: var(--bg-subtle); border-bottom: 2px solid rgba(0,0,0,0.05);">
                <th style="padding: 20px;"><%= __('common_case_title') %></th>
                <th style="padding: 20px;"><%= __('common_type') %></th>
                <th style="padding: 20px;"><%= __('common_date') %></th>
                <th style="padding: 20px;"><%= __('common_current_status') %></th>
                <th style="padding: 20px;"><%= __('common_actions') %></th>
            </tr>
        </thead>
        <tbody>
            <% if (cases.length === 0) { %>
                <tr>
                    <td colspan="5" style="padding: 60px; text-align: center; color: var(--text-muted);">
                        <i class="fas fa-search" style="font-size: 2rem; opacity: 0.2; display: block; margin-bottom: 15px;"></i>
                        <%= __('admin_cases_manager_empty') %>
                    </td>
                </tr>
            <% } %>
            <% cases.forEach(item => { %>
                <tr class="case-row" style="border-bottom: 1px solid rgba(0,0,0,0.05); transition: background 0.3s;" onmouseover="this.style.background='rgba(0,0,0,0.01)'" onmouseout="this.style.background='transparent'">
                    <td style="padding: 20px;">
                        <span class="badge badge-navy" style="font-size: 0.7rem; margin-bottom: 5px; opacity: 0.8; letter-spacing: 0.5px;"><i class="fas fa-hashtag"></i> <%= item.referenceNumber || 'JSR-?????' %></span>
                        <div style="font-weight: 700; color: var(--primary);"><%= item.title %></div>
                        <div style="font-size: 0.8rem; color: var(--text-muted);"><i class="fas fa-location-dot"></i> <%= item.location %></div>
                    </td>
                    <td style="padding: 20px;">
                        <span class="badge <%= item.type === 'orphan' ? 'badge-gold' : 'badge-navy' %>">
                            <%= item.type === 'orphan' ? __('common_orphan') : __('common_family') %>
                        </span>
                    </td>
                    <td style="padding: 20px; font-size: 0.9rem;">
                        <%= item.createdAt.toLocaleDateString(lang === 'ar' ? 'ar-EG' : 'en-US') %>
                    </td>
                    <td style="padding: 20px;">
                        <span class="badge <%= 
                            item.status === 'approved' ? 'badge-success' : 
                            item.status === 'field_verification' ? 'badge-teal' : 
                            item.status === 'rejected' ? 'badge-danger' : 'badge-navy' 
                        %>">
                            <%= 
                                item.status === 'approved' ? __('common_approved_desc') : 
                                item.status === 'field_verification' ? __('common_field_verification') : 
                                item.status === 'rejected' ? __('common_rejected') : __('common_pending_review') 
                            %>
                        </span>
                    </td>
                    <td style="padding: 15px 20px;">
                        <div style="display: flex; gap: 8px; justify-content: flex-end; align-items: center;">
                            <button class="btn-lux btn-sm btn-lux-navy" style="font-size:0.75rem;" onclick="openActionModal('<%= item._id %>', '<%= item.title %>', '<%= item.status %>', '<%= item.area %>', '<%= item.housingStatus %>', '<%= item.isFieldVerified %>', '<%= item.verificationNotes %>', '<%= JSON.stringify(item.impactMetrics || []) %>', '<%= JSON.stringify(item.needs || []) %>', '<%= item.targetAmount || 0 %>', '<%= item.monthlySponsorshipAmount || 0 %>')">
                                <i class="fas fa-edit"></i> <%= __('common_review') %>
                            </button>
                            
                            <div class="dropdown-container" style="position: relative;">
                                <button class="btn-lux btn-sm btn-lux-outline" style="padding: 5px 12px;" onclick="toggleDropdown('drop-<%= item._id %>')">
                                    <i class="fas fa-ellipsis-v"></i>
                                </button>
                                <div id="drop-<%= item._id %>" class="dropdown-menu" style="display: none; position: absolute; top: 100%; <%= langDir === 'rtl' ? 'left: 0' : 'right: 0' %>; background: #fff; min-width: 180px; box-shadow: 0 10px 30px rgba(0,0,0,0.1); border-radius: 8px; border: 1px solid rgba(0,0,0,0.05); z-index: 1000; padding: 5px; text-align: <%= langDir === 'rtl' ? 'right' : 'left' %>; margin-top: 5px;">
                                    
                                    <a href="javascript:void(0)" onclick="openUpdateModal('<%= item._id %>', '<%= item.title %>'); toggleDropdown('drop-<%= item._id %>');" class="dropdown-item">
                                        <i class="fas fa-history"></i> <%= __('admin_cases_manager_action_timeline') || 'التسلسل الزمني وتحديث التنفيذ' %>
                                    </a>
                                    
                                    <form action="/admin/cases/<%= item._id %>/toggle-satisfaction" method="POST" style="margin: 0; padding: 0;">
                                        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                        <button type="submit" class="dropdown-item" style="width: 100%; text-align: <%= langDir === 'rtl' ? 'right' : 'left' %>; background: none; border: none; cursor: pointer;">
                                            <i class="fas <%= item.isSatisfied ? 'fa-hand-holding-heart' : 'fa-check-double' %>"></i> <%= item.isSatisfied ? __('admin_cases_manager_resume_donations') || 'استئناف' : __('admin_cases_manager_declare_satisfied') || 'اعتبارها حالة مكتفية' %>
                                        </button>
                                    </form>
                                    
                                    <a href="/cases/<%= item._id %>" target="_blank" class="dropdown-item">
                                        <i class="fas fa-eye"></i> <%= __('admin_cases_manager_action_view_form') || 'عرض نموذج الحالة' %>
                                    </a>

                                    <% if (locals.user && locals.user.role === 'super_admin') { %>
                                        <div style="height: 1px; background: rgba(0,0,0,0.05); margin: 5px 0;"></div>
                                        
                                        <form action="/admin/cases/<%= item._id %>/toggle-visibility" method="POST" style="margin: 0; padding: 0;">
                                            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                            <button type="submit" class="dropdown-item" style="width: 100%; text-align: <%= langDir === 'rtl' ? 'right' : 'left' %>; background: none; border: none; cursor: pointer; color: #f59e0b;">
                                                <i class="fas <%= item.isHidden ? 'fa-eye' : 'fa-eye-slash' %>"></i> <%= item.isHidden ? 'إظهار الحالة للعامة' : 'إخفاء الحالة عن العامة' %>
                                            </button>
                                        </form>

                                        <form action="/admin/cases/<%= item._id %>/hard-delete" method="POST" style="margin: 0; padding: 0;" onsubmit="return confirm('هل أنت متأكد من حذف هذه الحالة وكل بياناتها نهائياً؟ هذا الإجراء لا يمكن التراجع عنه!');">
                                            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                            <button type="submit" class="dropdown-item" style="width: 100%; text-align: <%= langDir === 'rtl' ? 'right' : 'left' %>; background: none; border: none; cursor: pointer; color: #ef4444;">
                                                <i class="fas fa-trash-alt"></i> حذف الحالة نهائياً
                                            </button>
                                        </form>

                                        <% if (item.storyVideo) { %>
                                            <form action="/admin/cases/<%= item._id %>/toggle-story-visibility" method="POST" style="margin: 0; padding: 0;">
                                                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                                <button type="submit" class="dropdown-item" style="width: 100%; text-align: <%= langDir === 'rtl' ? 'right' : 'left' %>; background: none; border: none; cursor: pointer; color: #8b5cf6;">
                                                    <i class="fas <%= item.isStoryHidden ? 'fa-video' : 'fa-video-slash' %>"></i> <%= item.isStoryHidden ? 'إظهار الستوري' : 'إخفاء الستوري' %>
                                                </button>
                                            </form>
                                            
                                            <form action="/admin/cases/<%= item._id %>/story-hard-delete" method="POST" style="margin: 0; padding: 0;" onsubmit="return confirm('هل أنت متأكد من حذف ستوري الحالة نهائياً؟');">
                                                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                                <button type="submit" class="dropdown-item" style="width: 100%; text-align: <%= langDir === 'rtl' ? 'right' : 'left' %>; background: none; border: none; cursor: pointer; color: #ef4444;">
                                                    <i class="fas fa-file-video"></i> حذف ستوري الحالة
                                                </button>
                                            </form>
                                        <% } %>
                                    <% } %>
                                    
                                    <% if (['field_verification', 'approved', 'fully_sponsored'].includes(item.status)) { %>
                                        <div style="height: 1px; background: rgba(0,0,0,0.05); margin: 5px 0;"></div>
                                        <a href="/admin/cases/<%= item._id %>/field-report" target="_blank" class="dropdown-item" style="color: var(--primary); font-weight: 700;">
                                            <i class="fas fa-print"></i> <%= __('admin_cases_btn_print_report') || 'طباعة تقرير التحقق الميداني' %>
                                        </a>
                                    <% } %>
                                </div>
                            </div>
                        </div>
                    </td>
                </tr>
            <% }) %>
        </tbody>
    </table>
</div>

<!-- Action Modal -->
<div id="actionModal" class="modal-overlay" style="display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.7); backdrop-filter: blur(8px); z-index: 2000; align-items: center; justify-content: center;">
    <div class="luxury-card" style="width: 100%; max-width: 600px; max-height: 90vh; overflow-y: auto; padding: 40px; background: white;">
        <h3 class="font-cairo" style="margin-bottom: 25px; border-bottom: 1px solid #eee; padding-bottom: 15px;">
            <i class="fas fa-file-signature" style="color: var(--secondary);"></i> <span id="modalCaseTitle"><%= __('admin_cases_manager_modal_review_title') %></span>
        </h3>
        
        <form id="actionForm" action="" method="POST" class="premium-form">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            
            <div class="form-group" style="margin-bottom: 25px;">
                <label class="form-label-luxury"><%= __('admin_cases_manager_label_action') %></label>
                <select name="status" id="statusSelect" class="form-input" onchange="toggleInputs()">
                    <option value="pending"><%= __('admin_cases_status_pending_initial') %></option>
                    <option value="field_verification"><%= __('admin_cases_status_to_field') %></option>
                    <option value="approved"><%= __('admin_cases_status_approve_final') %></option>
                    <option value="rejected"><%= __('admin_cases_status_reject') %></option>
                </select>
            </div>

            <!-- Case Needs Display -->
            <div class="form-group" style="margin-bottom: 25px;">
                <label class="form-label-luxury"><%= __('admin_cases_manager_label_needs') %></label>
                <div id="modalNeedsContainer" style="display: flex; flex-wrap: wrap; gap: 10px; margin-top: 10px; padding: 15px; background: #fffcf0; border-radius: 10px; border: 1px solid #f0e68c;">
                    <!-- Filled dynamically -->
                </div>
            </div>

            <!-- New Fields for Enrichment -->
            <div id="enrichmentFields" style="display: none;">
                <div style="display: flex; align-items: center; gap: 15px; margin-bottom: 20px;">
                    <i class="fas fa-coins" style="font-size: 1.5rem; color: var(--secondary);"></i>
                    <h5 style="margin:0; font-family:'Cairo';"><%= __('admin_cases_manager_label_financial') %></h5>
                </div>
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px; margin-bottom: 25px;">
                    <div class="form-group">
                        <label class="form-label-luxury"><%= __('admin_cases_manager_label_target_amount') %></label>
                        <input type="number" name="targetAmount" id="adminTargetAmountInput" class="form-input" placeholder="<%= __('admin_cases_manager_placeholder_target_amount') %>">
                    </div>
                    <div class="form-group">
                        <label class="form-label-luxury"><%= __('admin_cases_manager_label_monthly_amount') %></label>
                        <input type="number" name="monthlySponsorshipAmount" id="adminMonthlyAmountInput" class="form-input" placeholder="<%= __('admin_cases_manager_placeholder_monthly_amount') %>">
                    </div>
                </div>

                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px; margin-bottom: 25px;">
                    <div class="form-group">
                        <label class="form-label-luxury"><%= __('common_location_area') %></label>
                        <input type="text" name="area" id="areaInput" class="form-input" placeholder="<%= __('common_location_placeholder') %>">
                    </div>
                    <div class="form-group">
                        <label class="form-label-luxury"><%= __('common_housing_status') %></label>
                        <select name="housingStatus" id="housingInput" class="form-input">
                            <option value="other"><%= __('common_other') %></option>
                            <option value="tent"><%= __('common_housing_tent') %></option>
                            <option value="rental"><%= __('common_housing_rental') %></option>
                            <option value="host_family"><%= __('common_housing_host_family') %></option>
                            <option value="destroyed_home"><%= __('common_housing_destroyed_home') %></option>
                        </select>
                    </div>
                </div>

                <div class="form-group" style="margin-bottom: 25px; display: flex; align-items: center; gap: 10px; background: rgba(16, 185, 129, 0.05); padding: 10px; border-radius: 8px;">
                    <input type="checkbox" name="isFieldVerified" id="isVerifiedInput" style="width: 20px; height: 20px; cursor: pointer;">
                    <label for="isVerifiedInput" style="margin: 0; font-weight: 700; color: #10b981; cursor: pointer;"><%= __('admin_cases_manager_label_is_verified') %></label>
                </div>

                <!-- Impact Metrics Editor (Phase 2) -->
                <div class="form-group" style="margin-bottom: 25px;">
                    <label class="form-label-luxury"><%= __('admin_cases_manager_label_impact_metrics') %></label>
                    <div id="impactMetricsList" style="display: flex; flex-direction: column; gap: 10px; margin-bottom: 15px;">
                        <!-- Dynamic metrics will be added here -->
                    </div>
                    <button type="button" class="btn-lux btn-sm btn-lux-outline" onclick="addImpactMetric()">
                        <i class="fas fa-plus"></i> <%= __('admin_cases_manager_btn_add_metric') %>
                    </button>
                    <input type="hidden" name="impactMetrics" id="impactMetricsHidden">
                </div>
            </div>

            <div id="verificationNotesGroup" class="form-group" style="margin-bottom: 25px; display: none;">
                <label class="form-label-luxury"><%= __('admin_cases_manager_label_verification_notes') %></label>
                <textarea name="verificationNotes" id="notesInput" class="form-input" rows="4" placeholder="<%= __('admin_cases_manager_placeholder_verification_notes') %>"></textarea>
            </div>

            <div id="rejectionReasonGroup" class="form-group" style="margin-bottom: 25px; display: none;">
                <label class="form-label-luxury"><%= __('admin_cases_manager_label_rejection_reason') %></label>
                <textarea name="rejectionReason" class="form-input" rows="4" placeholder="<%= __('admin_cases_manager_placeholder_rejection_reason') %>"></textarea>
            </div>

            <div style="display: flex; gap: 15px; margin-top: 30px;">
                <button type="submit" class="btn-lux btn-lux-primary" style="flex: 1; justify-content: center;"><%= __('common_save_changes') %></button>
                <button type="button" class="btn-lux btn-lux-outline-white" onclick="closeAllModals()" style="flex: 1; justify-content: center; color: #555; border-color: #ddd;"><%= __('common_cancel') %></button>
            </div>
        </form>
    </div>
</div>

<!-- Update Modal -->
<div id="updateModal" class="modal-overlay" style="display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.7); backdrop-filter: blur(8px); z-index: 2000; align-items: center; justify-content: center;">
    <div class="luxury-card" style="width: 100%; max-width: 600px; padding: 40px; background: white;">
        <h3 class="font-cairo" style="margin-bottom: 25px; border-bottom: 1px solid #eee; padding-bottom: 15px;">
            <i class="fas fa-history" style="color: var(--primary);"></i> <span id="updateModalTitle"><%= __('admin_cases_manager_modal_update_title') %></span>
        </h3>
        
        <form id="updateForm" action="" method="POST" class="premium-form" enctype="multipart/form-data">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            
            <div class="form-group" style="margin-bottom: 25px;">
                <label class="form-label-luxury"><%= __('admin_cases_manager_update_label_title') %></label>
                <input type="text" name="title" class="form-input" placeholder="<%= __('admin_cases_manager_update_placeholder_title') %>" required>
            </div>

            <div class="form-group" style="margin-bottom: 25px;">
                <label class="form-label-luxury"><%= __('admin_cases_manager_update_label_desc') %></label>
                <textarea name="description" class="form-input" rows="6" placeholder="<%= __('admin_cases_manager_update_placeholder_desc') %>" required></textarea>
            </div>

            <div class="form-group" style="margin-bottom: 25px;">
                <label class="form-label-luxury">إرفاق وسائط ووثائق التنفيذ (اختياري)</label>
                <div style="position: relative;">
                    <input type="file" name="attachments" id="attachmentsInput" class="form-input" multiple accept="image/*,video/*,.pdf,.doc,.docx" style="padding-<%= langDir === 'rtl' ? 'right' : 'left' %>: 45px; cursor: pointer; height: auto; min-height: 48px; padding-top: 10px;">
                    <i class="fas fa-paperclip" style="position: absolute; right: <%= langDir === 'rtl' ? '15px' : 'auto' %>; left: <%= langDir === 'rtl' ? 'auto' : '15px' %>; top: 15px; color: var(--text-muted);"></i>
                </div>
                <div style="font-size: 0.75rem; color: var(--text-muted); margin-top: 8px;"><i class="fas fa-info-circle"></i> يمكنك اختيار عدة صور، مقاطع فيديو، أو ملفات من جهازك لتوثيق التسليم للجهة العامة.</div>
            </div>

            <div style="display: flex; gap: 15px; margin-top: 30px;">
                <button type="submit" class="btn-lux btn-lux-primary" style="flex: 1; justify-content: center;"><%= __('admin_cases_manager_btn_add_update') %></button>
                <button type="button" class="btn-lux btn-lux-outline-white" onclick="closeAllModals()" style="flex: 1; justify-content: center; color: #555; border-color: #ddd;"><%= __('common_cancel') %></button>
            </div>
        </form>
    </div>
</div>

<script>
    function filterCasesTable() {
        const query = document.getElementById("liveSearchInput").value.toLowerCase();
        const rows = document.querySelectorAll(".case-row");
        rows.forEach(row => {
            const textContent = row.innerText.toLowerCase();
            row.style.display = textContent.includes(query) ? "" : "none";
        });
    }

    function openActionModal(id, title, status, area, housing, isVerified, notes, impactMetricsStr, needsStr, targetAmount, monthlyAmount) {
        document.getElementById('actionForm').action = '/admin/cases/' + id + '/status';
        document.getElementById('modalCaseTitle').innerText = '<%= __("admin_cases_manager_modal_review_prefix") %>' + title;
        document.getElementById('statusSelect').value = status;
        document.getElementById('areaInput').value = area || '';
        document.getElementById('housingInput').value = housing || 'other';
        document.getElementById('isVerifiedInput').checked = isVerified === 'true' || isVerified === true;
        document.getElementById('notesInput').value = notes || '';
        document.getElementById('adminTargetAmountInput').value = targetAmount || '';
        document.getElementById('adminMonthlyAmountInput').value = monthlyAmount || '';
        
        // Populate Needs
        const needsContainer = document.getElementById('modalNeedsContainer');
        needsContainer.innerHTML = '';
        try {
            const needs = JSON.parse(needsStr || '[]');
            if (needs.length === 0) {
                needsContainer.innerHTML = '<span style="color:var(--text-muted); font-size:0.9rem;"><%= __("admin_cases_manager_no_needs") %></span>';
            } else {
                needs.forEach(need => {
                    const span = document.createElement('span');
                    span.className = 'badge badge-gold';
                    span.innerText = need;
                    needsContainer.appendChild(span);
                });
            }
        } catch(e) { console.error(e); }
        
        // Populate Impact Metrics
        const list = document.getElementById('impactMetricsList');
        list.innerHTML = '';
        try {
            const metrics = JSON.parse(impactMetricsStr || '[]');
            metrics.forEach(m => addImpactMetric(m.amount, m.descriptionAr));
        } catch(e) { console.error(e); }

        document.getElementById('actionModal').style.display = 'flex';
        toggleInputs();
    }

    function openUpdateModal(id, title) {
        document.getElementById('updateForm').action = '/admin/cases/' + id + '/updates?_csrf=<%= csrfToken %>';
        document.getElementById('updateModalTitle').innerText = '<%= __("admin_cases_manager_modal_update_prefix") %>' + title;
        document.getElementById('updateModal').style.display = 'flex';
    }

    function closeAllModals() {
        document.getElementById('actionModal').style.display = 'none';
        document.getElementById('updateModal').style.display = 'none';
    }

    function toggleInputs() {
        const status = document.getElementById('statusSelect').value;
        const notesGroup = document.getElementById('verificationNotesGroup');
        const rejectionGroup = document.getElementById('rejectionReasonGroup');
        const enrichment = document.getElementById('enrichmentFields');

        notesGroup.style.display = (status === 'field_verification' || status === 'approved') ? 'block' : 'none';
        enrichment.style.display = (status === 'approved') ? 'block' : 'none';
        rejectionGroup.style.display = (status === 'rejected') ? 'block' : 'none';
    }

    function addImpactMetric(amount = '', desc = '') {
        const container = document.getElementById('impactMetricsList');
        const div = document.createElement('div');
        div.className = 'metric-row';
        div.style.display = 'flex';
        div.style.gap = '10px';
        div.style.marginBottom = '10px';
        div.innerHTML = `
            <input type="number" class="form-input metric-amount" placeholder="<%= __("admin_cases_manager_impact_amount_placeholder") %>" value="${amount || ''}" style="width: 100px;">
            <input type="text" class="form-input metric-desc" placeholder="<%= __("admin_cases_manager_impact_desc_placeholder") %>" value="${desc || ''}" style="flex: 1;">
            <button type="button" class="btn-lux btn-sm btn-lux-danger" onclick="this.parentElement.remove()" style="padding: 10px;"><i class="fas fa-trash"></i></button>
        `;
        container.appendChild(div);
    }

    document.getElementById('actionForm').onsubmit = function() {
        const metrics = [];
        document.querySelectorAll('.metric-row').forEach(row => {
            const amount = row.querySelector('.metric-amount').value;
            const descriptionAr = row.querySelector('.metric-desc').value;
            if (amount && descriptionAr) {
                metrics.push({ amount: Number(amount), descriptionAr });
            }
        });
        document.getElementById('impactMetricsHidden').value = JSON.stringify(metrics);
        return true;
    };

    // Close on outside click
    window.onclick = function(event) {
        if (event.target.classList.contains('modal-overlay')) closeAllModals();
        
        // Handle dropdown clicks outside
        if (!event.target.closest('.dropdown-container')) {
            document.querySelectorAll('.dropdown-menu').forEach(i => i.style.display = 'none');
        }
    }

    function toggleDropdown(id) {
        // Close others
        document.querySelectorAll('.dropdown-menu').forEach(i => {
            if (i.id !== id) i.style.display = 'none';
        });
        const el = document.getElementById(id);
        el.style.display = el.style.display === 'none' ? 'block' : 'none';
    }
</script>

<style>
    .modal-overlay { animation: fadeIn 0.3s var(--ease-smooth); }
    @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
    
    .dropdown-item {
        display: block;
        padding: 8px 15px;
        color: var(--dark);
        text-decoration: none;
        font-size: 0.85rem;
        border-radius: 5px;
        transition: all 0.2s;
        font-family: 'Cairo', sans-serif;
    }
    .dropdown-item:hover {
        background: rgba(0,0,0,0.03);
        color: var(--primary);
    }
    .dropdown-item i { width: 22px; text-align: center; color: var(--text-muted); margin-<%= langDir === 'rtl' ? 'left' : 'right' %>: 5px; }
    .dropdown-item:hover i { color: var(--primary); }
</style>

<%- include('../../partials/admin-layout-bottom') %>
