<%- include('../../partials/admin-layout-top') %>

<div class="container-fluid" style="padding: 30px; max-width: 1000px; margin: 0 auto;">
    <div class="section-header-luxury" style="text-align: <%= langDir === 'rtl' ? 'right' : 'left' %>; margin-bottom: 40px;">
        <span class="section-badge"><i class="fas fa-cogs"></i> <%= __('common_control_center') %></span>
        <h2 class="section-title-luxury"><%= __('admin_settings_title') %></h2>
        <p class="section-subtitle-luxury"><%= __('admin_settings_desc') %></p>
    </div>

    <div class="row">
        <div class="col-md-8 mx-auto">
            <div class="luxury-card glass-panel" style="padding: 40px; border-radius: 25px;">
                <form action="/admin/settings/update" method="POST">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">

                    <div style="margin-bottom: 40px; padding-bottom: 30px; border-bottom: 1px solid rgba(0,0,0,0.05); text-align: <%= langDir === 'rtl' ? 'right' : 'left' %>;">
                        <div style="display: flex; align-items: center; gap: 15px; margin-bottom: 25px;">
                            <div style="width: 50px; height: 50px; border-radius: 15px; background: rgba(226, 176, 100, 0.1); display: flex; align-items: center; justify-content: center; color: var(--secondary); font-size: 1.5rem;">
                                <i class="fas fa-percent"></i>
                            </div>
                            <div>
                                <h4 class="font-cairo" style="margin: 0; color: var(--primary); font-weight: 800;"><%= __('admin_settings_fee_label') %></h4>
                                <p style="margin: 0; font-size: 0.85rem; color: var(--text-muted);"><%= __('admin_settings_fee_desc_split') %></p>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group" style="margin-bottom: 20px;">
                                    <label class="form-label-luxury"><%= __('admin_settings_institution_fee_label') %></label>
                                    <div style="position: relative;">
                                        <input type="number" step="0.01" name="institution_fee_percentage" class="form-input" 
                                               value="<%= settings.institution_fee_percentage %>" 
                                               style="padding-<%= langDir === 'rtl' ? 'right' : 'left' %>: 50px; font-size: 1.2rem; font-weight: 700; color: var(--secondary);" required>
                                        <span style="position: absolute; <%= langDir === 'rtl' ? 'left' : 'right' %>: 20px; top: 50%; transform: translateY(-50%); font-weight: 800; color: var(--text-muted);">%</span>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group" style="margin-bottom: 20px;">
                                    <label class="form-label-luxury"><%= __('admin_settings_gateway_fee_label') %></label>
                                    <div style="position: relative;">
                                        <input type="number" step="0.01" name="gateway_fee_percentage" class="form-input" 
                                               value="<%= settings.gateway_fee_percentage %>" 
                                               style="padding-<%= langDir === 'rtl' ? 'right' : 'left' %>: 50px; font-size: 1.2rem; font-weight: 700; color: var(--secondary);" required>
                                        <span style="position: absolute; <%= langDir === 'rtl' ? 'left' : 'right' %>: 20px; top: 50%; transform: translateY(-50%); font-weight: 800; color: var(--text-muted);">%</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                        
                        <div style="margin-top: 5px; padding: 12px; background: #fffcf0; border-radius: 10px; border: 1px dashed #f0e68c; display: flex; gap: 10px; align-items: center;">
                            <i class="fas fa-info-circle" style="color: #b8860b;"></i>
                            <span style="font-size: 0.8rem; color: #856404;"><%= __('admin_settings_fee_breakdown_help') %></span>
                        </div>
                    </div>
                    </div>

                    <div style="margin-bottom: 40px; padding-bottom: 30px; border-bottom: 1px solid rgba(0,0,0,0.05); text-align: <%= langDir === 'rtl' ? 'right' : 'left' %>;">
                        <div style="display: flex; align-items: center; gap: 15px; margin-bottom: 25px;">
                            <div style="width: 50px; height: 50px; border-radius: 15px; background: rgba(16, 185, 129, 0.1); display: flex; align-items: center; justify-content: center; color: var(--success); font-size: 1.5rem;">
                                <i class="fas fa-list-check"></i>
                            </div>
                            <div>
                                <h4 class="font-cairo" style="margin: 0; color: var(--primary); font-weight: 800;"><%= __('admin_settings_needs_label') %></h4>
                                <p style="margin: 0; font-size: 0.85rem; color: var(--text-muted);"><%= __('admin_settings_needs_desc') %></p>
                            </div>
                        </div>

                        <div class="form-group">
                            <label class="form-label-luxury"><%= __('admin_settings_needs_input_label') %></label>
                            <input type="text" name="case_needs" class="form-input" 
                                   value="<%= settings.case_needs %>" 
                                   placeholder="<%= __('admin_settings_needs_placeholder') %>" 
                                   style="font-size: 1rem; font-weight: 600; color: var(--secondary);" required>
                            <div style="margin-top: 15px; padding: 12px; background: #f0fdf4; border-radius: 10px; border: 1px dashed #86efac; display: flex; gap: 10px; align-items: center;">
                                <i class="fas fa-info-circle" style="color: #166534;"></i>
                                <span style="font-size: 0.8rem; color: #14532d;"><%= __('admin_settings_needs_info') %></span>
                            </div>
                        </div>
                    </div>

                    <div style="margin-bottom: 40px; padding-bottom: 30px; border-bottom: 1px solid rgba(0,0,0,0.05); text-align: <%= langDir === 'rtl' ? 'right' : 'left' %>;">
                        <div style="display: flex; align-items: center; gap: 15px; margin-bottom: 25px;">
                            <div style="width: 50px; height: 50px; border-radius: 15px; background: rgba(99, 102, 241, 0.1); display: flex; align-items: center; justify-content: center; color: #6366f1; font-size: 1.5rem;">
                                <i class="fas fa-calendar-day"></i>
                            </div>
                            <div>
                                <h4 class="font-cairo" style="margin: 0; color: var(--primary); font-weight: 800;"><%= __('admin_settings_chat_day_label') %></h4>
                                <p style="margin: 0; font-size: 0.85rem; color: var(--text-muted);"><%= __('admin_settings_chat_day_desc') %></p>
                            </div>
                        </div>

                        <div class="form-group">
                            <label class="form-label-luxury"><%= __('admin_settings_chat_day_select_label') %></label>
                            <select name="chat_day" class="form-input" style="font-size: 1rem; font-weight: 700; color: var(--secondary);">
                                <option value="0" <%= settings.chat_day == 0 ? 'selected' : '' %>><%= __('common_day_0') %></option>
                                <option value="1" <%= settings.chat_day == 1 ? 'selected' : '' %>><%= __('common_day_1') %></option>
                                <option value="2" <%= settings.chat_day == 2 ? 'selected' : '' %>><%= __('common_day_2') %></option>
                                <option value="3" <%= settings.chat_day == 3 ? 'selected' : '' %>><%= __('common_day_3') %></option>
                                <option value="4" <%= settings.chat_day == 4 ? 'selected' : '' %>><%= __('common_day_4') %></option>
                                <option value="5" <%= settings.chat_day == 5 ? 'selected' : '' %>><%= __('common_day_5') %></option>
                                <option value="6" <%= settings.chat_day == 6 ? 'selected' : '' %>><%= __('common_day_6') %></option>
                            </select>
                            <div style="margin-top: 15px; padding: 12px; background: #eef2ff; border-radius: 10px; border: 1px dashed #a5b4fc; display: flex; gap: 10px; align-items: center;">
                                <i class="fas fa-info-circle" style="color: #4338ca;"></i>
                                <span style="font-size: 0.8rem; color: #312e81;"><%= __('admin_settings_chat_day_info') %></span>
                            </div>
                        </div>
                    </div>

                    <div style="display: flex; justify-content: flex-end; gap: 15px;">
                        <button type="submit" class="btn-lux btn-lux-primary" style="padding: 15px 40px; border-radius: 15px; font-weight: 800;">
                            <i class="fas fa-save"></i> <%= __('common_save_settings') %>
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<style>
    .form-label-luxury {
        display: block;
        margin-bottom: 12px;
        font-weight: 800;
        color: var(--primary);
        font-size: 0.95rem;
    }
</style>

<%- include('../../partials/admin-layout-bottom') %>
