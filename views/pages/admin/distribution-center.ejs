        </div>

        <!-- Variance Warning Block -->
        <div id="bcVarianceAlert" style="display: none; padding: 18px; border-radius: 16px; margin-bottom: 25px; background: #fff1f2; border: 1px solid #fecaca; color: #991b1b; animation: slideDown 0.3s ease-out;">
            <div style="display: flex; gap: 12px; align-items: flex-start;">
                <i class="fas fa-exclamation-triangle" style="margin-top: 3px; font-size: 1.1rem;"></i>
                <div style="flex: 1;">
                    <strong style="display: block; margin-bottom: 4px; font-size: 0.95rem;"><%= __('admin_dist_shortfall_detected') %></strong>
                    <div style="font-size: 0.85rem; opacity: 0.9; margin-bottom: 12px;">
                        <span><%= __('admin_dist_variance') %>:</span> 
                        <span style="font-weight: 950; font-size: 1rem;">$<span id="bcVarianceAmount"></span></span>
                    </div>
                    <label style="font-size: 0.75rem; font-weight: 700; color: #b91c1c; display: block; margin-bottom: 5px;"><%= __('admin_dist_shortfall_action') || 'إجراء معالجة النقص' %></label>
                    <select id="bcShortfallAction" class="form-control-lux" style="width: 100%; padding: 8px 12px; border-radius: 10px; border-color: #fecaca; font-size: 0.85rem;">
                        <option value="deduct_from_fees"><%= __('admin_dist_deduct_fees') %></option>
                        <option value="deduct_from_cases"><%= __('admin_dist_deduct_cases') %></option>
                    </select>
                </div>
            </div>
        </div>

        <div style="margin-bottom: 30px;">
            <label style="display: block; font-size: 0.85rem; font-weight: 700; color: #475569; margin-bottom: 8px;"><%= __('common_notes') %></label>
            <textarea id="bcNotes" class="form-control-lux" rows="3" style="width: 100%; border-radius: 14px; padding: 12px; border: 1px solid #e2e8f0; font-size: 0.9rem;" placeholder="<%= __('common_notes_placeholder') || 'أضف ملاحظاتك هنا...' %>"></textarea>
        </div>

        <div style="display: flex; gap: 12px;">
            <button class="btn-lux btn-lux-outline" style="flex: 1; padding: 14px; font-weight: 700;" onclick="closeBankConfirmModal()"><%= __('common_cancel') %></button>
            <button class="btn-lux btn-lux-primary" style="flex: 2; padding: 14px; font-weight: 800; font-size: 1.05rem;" onclick="submitBankConfirm()">
