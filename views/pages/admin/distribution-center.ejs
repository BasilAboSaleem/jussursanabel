                <div style="font-size: 0.75rem; color: #94a3b8; font-weight: 800; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 4px;"><%= __('register_alt_phone') %></div>
                <div id="recipAltPhone" style="font-weight: 900; color: #1e293b;"></div>
            </div>
            <div style="grid-column: span 2; margin-top: 10px; padding-top: 15px; border-top: 1px solid #f1f5f9;">
                <div style="font-size: 0.75rem; color: #94a3b8; font-weight: 800; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 4px;"><%= __('common_address') %></div>
