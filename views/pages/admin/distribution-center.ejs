<%- include('../../partials/admin-layout-top') %>

<style>
    /* Modal & UI Refinements */
    .modal-lux {
        transition: all 0.3s ease-in-out;
    }
    
    .form-control-lux {
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        transition: all 0.2s;
    }
    
    .form-control-lux:focus {
        background: white;
        border-color: var(--primary);
        box-shadow: 0 0 0 4px rgba(30, 58, 138, 0.05);
        outline: none;
    }

    /* Professional Animations */
    @keyframes slideDown {
        from { opacity: 0; transform: translateY(-10px); }
        to { opacity: 1; transform: translateY(0); }
    }
    
    @keyframes fadeIn {
        from { opacity: 0; }
        to { opacity: 1; }
    }

    .animate-slide-down { animation: slideDown 0.3s ease-out; }
    .animate-fade-in { animation: fadeIn 0.3s ease-out; }

    /* Custom Scrollbar for Luxury feels */
    ::-webkit-scrollbar { width: 6px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: #e2e8f0; border-radius: 10px; }
    ::-webkit-scrollbar-thumb:hover { background: #cbd5e1; }
</style>

    <!-- 4. Bank Batch Details Modal -->
    <div id="bankBatchModal" class="modal-lux" style="display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.6); z-index: 9999; align-items: center; justify-content: center; backdrop-filter: blur(4px);">
        <div style="background: white; width: 800px; border-radius: 28px; padding: 40px; box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25); border: 1px solid #e2e8f0; text-align: <%= langDir === 'rtl' ? 'right' : 'left' %>; max-height: 90vh; overflow-y: auto;">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px;">
                <div style="display: flex; align-items: center; gap: 15px;">
                    <div style="width: 45px; height: 45px; background: #f8fafc; color: var(--primary); border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 1.2rem; border: 1px solid #e2e8f0;">
                        <i class="fas fa-list-check"></i>
                    </div>
                    <div>
                        <h5 class="font-cairo" style="margin: 0; font-weight: 900; color: var(--primary); font-size: 1.4rem;"><%= __('admin_dist_batch_details_title') || 'تفاصيل دفعة المطابقة' %></h5>
                        <p style="margin: 0; font-size: 0.85rem; color: #64748b;"><%= __('admin_dist_batch_details_desc') || 'قائمة بكافة التبرعات المدرجة في هذا الوصل البنكي' %></p>
                    </div>
                </div>
                <button onclick="closeBankBatchModal()" style="background: #f1f5f9; border: none; width: 40px; height: 40px; border-radius: 50%; color: #64748b; font-size: 1.2rem; cursor: pointer; transition: all 0.2s;" onmouseover="this.style.background='#e2e8f0'" onmouseout="this.style.background='#f1f5f9'">&times;</button>
            </div>

            <div id="bankBatchInfo" style="margin-bottom: 30px; display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; padding: 20px; background: #f8fafc; border-radius: 18px; border: 1px solid #e2e8f0;">
                <!-- Filled via JS -->
            </div>

            <div class="table-responsive" style="border: 1px solid #f1f5f9; border-radius: 16px; overflow: hidden;">
                <table class="table" style="font-size: 0.9rem; margin-bottom: 0; vertical-align: middle;">
                    <thead>
                        <tr style="background: #f8fafc; border-bottom: 2px solid #f1f5f9;">
                            <th style="padding: 15px; border: none;"><%= __('common_date') %></th>
                            <th style="padding: 15px; border: none;"><%= __('common_case') %></th>
                            <th style="padding: 15px; border: none;"><%= __('common_donor') %></th>
                            <th style="padding: 15px; border: none;"><%= __('common_amount') %></th>
                        </tr>
                    </thead>
                    <tbody id="bankBatchTableBody" style="border: none;">
                        <!-- Filled via JS -->
                    </tbody>
                </table>
            </div>

            <div style="margin-top: 35px; text-align: <%= langDir === 'rtl' ? 'left' : 'right' %>;">
                <button class="btn-lux btn-lux-outline" style="min-width: 120px; padding: 12px 25px; font-weight: 700;" onclick="closeBankBatchModal()"><%= __('common_close') %></button>
            </div>
        </div>
    </div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/moment.js/2.29.4/moment-with-locales.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>

<div class="distribution-container" style="padding-bottom: 50px; text-align: <%= langDir === 'rtl' ? 'right' : 'left' %>;">
    <!-- Header -->
    <div style="display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 40px;">
        <div>
            <h2 class="font-cairo" style="margin: 0; color: var(--primary); font-weight: 900; font-size: 2.2rem;"><%= __('admin_dist_title') %></h2>
            <p style="color: #64748b; margin-top: 5px; font-size: 1.1rem;"><%= __('admin_dist_desc') %></p>
        </div>
        <div style="background: white; padding: 12px 25px; border-radius: 15px; border: 1px solid #e2e8f0; box-shadow: var(--shadow-sm);">
            <div style="font-size: 0.75rem; color: #94a3b8; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 4px;"><%= __('admin_analytics_last_update') %></div>
            <div style="font-weight: 800; color: var(--primary); font-size: 1.1rem;"><%= new Date().toLocaleString(lang === 'ar' ? 'ar-EG' : 'en-US') %></div>
        </div>
    </div>

    <!-- Analytics Widgets -->
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 20px; margin-bottom: 40px;">
        <div style="background: white; padding: 20px; border-radius: 20px; border: 1px solid #e2e8f0; box-shadow: var(--shadow-sm); border-right: 4px solid var(--secondary);">
            <div style="color: #64748b; font-size: 0.85rem; font-weight: 700; margin-bottom: 10px;"><%= __('admin_dist_stat_stripe_pending') %></div>
            <div style="font-size: 1.8rem; font-weight: 900; color: var(--primary);">$<%= stats.pendingStripeTotal.toLocaleString() %></div>
            <div style="margin-top: 10px; font-size: 0.75rem; color: #94a3b8; display: flex; justify-content: space-between;">
                <span><%= __('admin_dist_donations') %> $<%= stats.pendingStripeDonations.toLocaleString() %></span>
                <span><%= __('admin_dist_fees') %>: $<%= stats.pendingStripeFees.toLocaleString() %></span>
            </div>
        </div>

        <div style="background: white; padding: 20px; border-radius: 20px; border: 1px solid #e2e8f0; box-shadow: var(--shadow-sm); border-right: 4px solid #16a34a;">
            <div style="color: #64748b; font-size: 0.85rem; font-weight: 700; margin-bottom: 10px;"><%= __('admin_dist_stat_bank_ready') %></div>
            <div style="font-size: 1.8rem; font-weight: 900; color: #16a34a;">$<%= stats.readyBankTotal.toLocaleString() %></div>
        </div>

        <div style="background: white; padding: 20px; border-radius: 20px; border: 1px solid #e2e8f0; box-shadow: var(--shadow-sm); border-right: 4px solid #2563eb;">
            <div style="color: #64748b; font-size: 0.85rem; font-weight: 700; margin-bottom: 10px;"><%= __('admin_dist_stat_total_disbursed') %></div>
            <div style="font-size: 1.8rem; font-weight: 900; color: #2563eb;">$<%= stats.totalDisbursed.toLocaleString() %></div>
        </div>
        
        <div style="background: <%= stats.remainingLiquidity < 0 ? '#fff1f2' : '#f0fdf4' %>; padding: 20px; border-radius: 20px; border: 1px solid <%= stats.remainingLiquidity < 0 ? '#fecaca' : '#bbf7d0' %>; box-shadow: var(--shadow-sm); border-right: 4px solid <%= stats.remainingLiquidity < 0 ? '#ef4444' : '#16a34a' %>;">
            <div style="color: #64748b; font-size: 0.85rem; font-weight: 700; margin-bottom: 10px;"><%= __('admin_dist_stat_liquidity') || 'السيولة المتاحة بنكياً' %></div>
            <div style="font-size: 1.8rem; font-weight: 900; color: <%= stats.remainingLiquidity < 0 ? '#ef4444' : '#16a34a' %>;">$<%= stats.remainingLiquidity.toLocaleString() %></div>
            <div style="font-size: 0.7rem; color: #94a3b8; margin-top: 5px;"><%= __('admin_dist_liquidity_desc') || 'الرصيد المؤكد مطروحاً منه إجمالي التوزيعات' %></div>
        </div>
    </div>

    <div class="dist-main-grid" style="display: grid; grid-template-columns: 3fr 2fr; gap: 30px; margin-bottom: 40px;">
        <!-- 1. Bank Reconciliation Section -->
        <div class="chart-container-lux" style="background: white; padding: 25px; border-radius: 20px; border: 1px solid #e2e8f0;">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 25px;">
                <div>
                    <h5 class="font-cairo" style="margin: 0; font-weight: 800; color: var(--primary);"><%= __('admin_dist_bank_confirm_title') %></h5>
                    <p style="margin: 0; font-size: 0.85rem; color: #64748b;"><%= __('admin_dist_bank_confirm_desc') %></p>
                </div>
                <% if (user.role === 'super_admin' && pendingBankConfirmation.length > 0) { %>
                    <button class="btn-lux btn-lux-primary" onclick="openBankConfirmModal()">
                        <i class="fas fa-check-double"></i> <%= __('admin_dist_confirm_selected') %>
                    </button>
                <% } %>
            </div>

            <!-- Date Filter Bar -->
            <div style="background: #f8fafc; padding: 15px; border-radius: 12px; margin-bottom: 25px; border: 1px solid #e2e8f0;">
                <form action="/admin/distribution" method="GET" style="display: flex; align-items: flex-end; gap: 15px; flex-wrap: wrap;">
                    <div style="flex: 1; min-width: 150px;">
                        <label style="font-size: 0.75rem; color: #94a3b8; display: block; margin-bottom: 5px;"><%= __('common_from') %></label>
                        <input type="date" name="bankFrom" value="<%= bankFrom %>" class="form-control-lux" style="width: 100%; padding: 8px 12px; border-radius: 8px;">
                    </div>
                    <div style="flex: 1; min-width: 150px;">
                        <label style="font-size: 0.75rem; color: #94a3b8; display: block; margin-bottom: 5px;"><%= __('common_to') %></label>
                        <input type="date" name="bankTo" value="<%= bankTo %>" class="form-control-lux" style="width: 100%; padding: 8px 12px; border-radius: 8px;">
                    </div>
                    <div style="display: flex; gap: 8px;">
                        <button type="submit" class="btn-lux btn-lux-primary" style="padding: 10px 20px;">
                            <i class="fas fa-filter"></i> <%= __('common_filter') %>
                        </button>
                        <a href="/admin/distribution" class="btn-lux btn-lux-outline" style="padding: 10px 15px; text-decoration: none;" title="<%= __('common_reset') || 'إعادة ضبط' %>">
                            <i class="fas fa-redo"></i>
                        </a>
                        <a href="/admin/distribution/export/bank-transactions?from=<%=bankFrom||''%>&to=<%=bankTo||''%>" target="_blank" class="btn-lux btn-lux-outline" style="padding: 10px 20px; text-decoration: none; color: #16a34a; border-color: #bbf7d0; background: #f0fdf4;">
                            <i class="fas fa-file-excel"></i> <%= __('common_export_excel') || 'تصدير إكسيل' %>
                        </a>
                    </div>
                </form>

                <% if (bankFrom || bankTo) { %>
                    <div style="margin-top: 20px; padding: 15px; background: white; border: 1px solid #e2e8f0; border-radius: 12px; display: flex; justify-content: space-between; align-items: center; box-shadow: inset 0 2px 4px rgba(0,0,0,0.02);">
                        <div style="display: flex; gap: 25px;">
                            <div>
                                <small style="color: #94a3b8; display: block; font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 4px;"><%= __('admin_dist_donations') %></small>
                                <span style="font-weight: 800; color: var(--primary); font-size: 1.1rem;">$<%= bankFilteredTotals.donations.toLocaleString() %></span>
                            </div>
                            <div style="padding-right: 25px; border-right: 1px solid #f1f5f9;">
                                <small style="color: #94a3b8; display: block; font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 4px;"><%= __('admin_dist_fees') %></small>
                                <span style="font-weight: 800; color: var(--primary); font-size: 1.1rem;">$<%= bankFilteredTotals.fees.toLocaleString() %></span>
                            </div>
                        </div>
                        <div style="text-align: <%= langDir === 'rtl' ? 'left' : 'right' %>;">
                            <small style="color: #16a34a; display: block; font-size: 0.75rem; font-weight: 800; margin-bottom: 2px;"><%= __('admin_dist_period_total') %></small>
                            <span style="font-weight: 900; color: #16a34a; font-size: 1.4rem;">$<%= bankFilteredTotals.grandTotal.toLocaleString() %></span>
                        </div>
                    </div>
                <% } %>
            </div>

            <div class="table-responsive">
                <table class="table" style="vertical-align: middle; margin: 0;">
                    <thead>
                        <tr style="font-size: 0.85rem; color: #94a3b8; border-bottom: 2px solid #f1f5f9; background: #fcfdfe;">
                            <th style="width: 45px; text-align: center; vertical-align: middle; padding: 12px 8px;">
                                <input type="checkbox" id="selectAllBank" onclick="toggleAllBank(this)" style="width: 16px; height: 16px; cursor: pointer; accent-color: var(--primary);">
                            </th>
                            <th style="padding: 12px 8px; vertical-align: middle;"><%= __('common_date') %></th>
                            <th style="padding: 12px 8px; vertical-align: middle;"><%= __('common_donor') %></th>
                            <th style="padding: 12px 8px; vertical-align: middle;"><%= __('common_case') %></th>
                            <th style="padding: 12px 8px; vertical-align: middle; text-align: <%= langDir === 'rtl' ? 'left' : 'right' %>;"><%= __('common_amount') %></th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (pendingBankConfirmation.length === 0) { %>
                            <tr><td colspan="5" style="text-align: center; padding: 60px; color: #94a3b8; font-family: 'Cairo', sans-serif;"><%= __('common_no_data') %></td></tr>
                        <% } else { %>
                            <% pendingBankConfirmation.forEach(trans => { %>
                                <tr style="border-bottom: 1px solid #f1f5f9; transition: background 0.2s;" onmouseover="this.style.background='#f8fafc'" onmouseout="this.style.background='white'">
                                    <td style="text-align: center; vertical-align: middle; padding: 12px 8px;">
                                        <input type="checkbox" class="bank-check" value="<%= trans._id %>" style="width: 16px; height: 16px; cursor: pointer; accent-color: var(--primary);">
                                    </td>
                                    <td style="font-size: 0.82rem; vertical-align: middle; color: #64748b; white-space: nowrap;">
                                        <i class="far fa-calendar-alt" style="margin-<%= langDir === 'rtl' ? 'left' : 'right' %>: 5px;"></i>
                                        <%= trans.createdAt.toLocaleDateString(lang === 'ar' ? 'ar-EG' : 'en-US') %>
                                    </td>
                                    <td style="vertical-align: middle; padding: 12px 8px;">
                                        <div style="font-weight: 700; color: var(--primary); font-size: 0.9rem;"><%= trans.donor ? trans.donor.name : __('common_system') %></div>
                                    </td>
                                    <td style="vertical-align: middle; padding: 12px 8px;">
                                        <div style="font-weight: 700; color: #334155; font-size: 0.85rem; max-width: 180px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;" title="<%= trans.case ? trans.case.title : '---' %>">
                                            <%= trans.case ? trans.case.title : '---' %>
                                        </div>
                                        <div style="font-size: 0.75rem; color: #64748b; margin-top: 2px;">
                                            <i class="fas fa-user-circle"></i> <%= (trans.case && trans.case.guardian) ? trans.case.guardian.name : '---' %>
                                        </div>
                                    </td>
                                    <td style="text-align: <%= langDir === 'rtl' ? 'left' : 'right' %>; vertical-align: middle; padding: 12px 8px;">
                                        <div style="font-weight: 900; color: var(--secondary); font-size: 1rem;">$<%= (trans.amount + (trans.institutionFee || 0)).toLocaleString() %></div>
                                        <div style="font-size: 0.68rem; color: #94a3b8; margin-top: 2px;">
                                            <%= __('admin_dist_donation') %>: $<%= trans.amount %>, <%= __('admin_dist_fees') %>: $<%= trans.institutionFee || 0 %>
                                        </div>
                                        <input type="hidden" class="trans-net" value="<%= trans.amount %>">
                                        <input type="hidden" class="trans-fee" value="<%= trans.institutionFee || 0 %>">
                                    </td>
                                </tr>
                            <% }) %>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- 2. Ready for Payout Section -->
        <div class="payout-wizard-box" style="background: #f8fafc; padding: 25px; border-radius: 20px; border: 1px dashed #cbd5e1;">
            <h5 class="font-cairo" style="margin-bottom: 10px; font-weight: 800; color: var(--primary);"><%= __('admin_dist_payout_title') %></h5>
            <p style="margin-bottom: 25px; font-size: 0.85rem; color: #64748b;"><%= __('admin_dist_payout_desc') %></p>

            <div style="display: flex; flex-direction: column; gap: 15px;">
                <% if (readyForDisbursement.length === 0) { %>
                    <div style="text-align: center; padding: 30px; background: white; border-radius: 15px; color: #94a3b8;"><%= __('common_no_data') %></div>
                <% } else { %>
                    <script id="disbursementRegistryData" type="application/json">
                        <%- JSON.stringify(readyForDisbursement.map(item => ({
                            id: item._id,
                            caseId: item._id,
                            title: item.caseDetails.title,
                            amount: item.totalAmount,
                            transactionIds: item.transactionIds,
                            recipient: item.recipientDetails || {}
                        }))) %>
                    </script>
                    <script>
                        // Load the registry data safely from the script tag
                        try {
                            const rawData = JSON.parse(document.getElementById('disbursementRegistryData').textContent);
                            window.DISBURSEMENT_REGISTRY = {};
                            rawData.forEach(item => {
                                window.DISBURSEMENT_REGISTRY[item.id] = item;
                            });
                        } catch (e) {
                            console.error('Failed to parse disbursement registry data', e);
                        }
                    </script>
                    <% readyForDisbursement.forEach(item => { %>
                        <div class="case-payout-card" style="background: white; padding: 20px; border-radius: 20px; box-shadow: var(--shadow-sm); border-right: 4px solid #16a34a;">
                            <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 15px;">
                                <div>
                                    <div style="font-weight: 800; color: var(--primary); font-size: 1.1rem; margin-bottom: 5px;"><%= item.caseDetails.title %></div>
                                    <div style="display: flex; align-items: center; gap: 8px;">
                                        <span class="badge badge-navy" style="font-size: 0.7rem;"><%= item.totalQuantity %> <%= __('common_donation') %></span>
                                        <% if (item.recipientDetails) { %>
                                            <span style="font-size: 0.75rem; color: #64748b;"><i class="fas fa-user-circle"></i> <%= item.recipientDetails.name %></span>
                                        <% } %>
                                    </div>
                                </div>
                                <div style="text-align: <%= langDir === 'rtl' ? 'left' : 'right' %>;">
                                    <div style="font-weight: 900; color: var(--secondary); font-size: 1.4rem;">$<%= item.totalAmount %></div>
                                </div>
                            </div>
                            <div style="display: grid; grid-template-columns: <% if (user.role === 'super_admin') { %>1fr 1fr<% } else { %>1fr<% } %>; gap: 10px;">
                                <button class="btn-lux btn-lux-outline" style="font-size: 0.8rem; padding: 8px;" onclick="openRecipientModalById('<%= item._id %>')">
                                    <i class="fas fa-id-card"></i> <%= __('admin_dist_view_recipient') %>
                                </button>
                                <% if (user.role === 'super_admin') { %>
                                <button class="btn-lux btn-lux-success" style="font-size: 0.8rem; padding: 8px;" onclick="openPayoutModalById('<%= item._id %>')">
                                    <i class="fas fa-paper-plane"></i> <%= __('admin_dist_generate_payout') %>
                                </button>
                                <% } %>
                            </div>
                        </div>
                    <% }) %>
                <% } %>
            </div>
        </div>
    </div>

    <!-- 3. Recent Payouts History -->
    <div class="chart-container-lux" style="background: white; padding: 25px; border-radius: 20px; border: 1px solid #e2e8f0; margin-bottom: 40px;">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 25px;">
            <div>
                <h5 class="font-cairo" style="margin: 0; font-weight: 800; color: var(--primary);"><%= __('admin_dist_recent_payouts') %></h5>
                <p style="margin: 0; font-size: 0.85rem; color: #64748b;"><%= __('admin_dist_payout_history_desc') || "سجل بكافة عمليات الصرف التي تمت مطابقتها" %></p>
            </div>
            <div style="text-align: <%= langDir === 'rtl' ? 'left' : 'right' %>;">
                <div style="font-size: 0.8rem; color: #94a3b8;"><%= __('admin_dist_total_disbursed_period') || "إجمالي المصروفات للفترة" %></div>
                <div style="font-size: 1.5rem; font-weight: 900; color: #16a34a;">$<%= (payoutPeriodTotals.totalAmount || 0).toLocaleString() %></div>
            </div>
        </div>

        <!-- History Filter Bar -->
        <div style="background: #f8fafc; padding: 15px; border-radius: 12px; margin-bottom: 25px; border: 1px solid #e2e8f0;">
            <form action="/admin/distribution" method="GET" style="display: flex; align-items: flex-end; gap: 15px; flex-wrap: wrap;">
                <input type="hidden" name="bankFrom" value="<%= bankFrom %>">
                <input type="hidden" name="bankTo" value="<%= bankTo %>">
                <input type="hidden" name="receiptFrom" value="<%= receiptFrom %>">
                <input type="hidden" name="receiptTo" value="<%= receiptTo %>">

                <div style="flex: 1; min-width: 150px;">
                    <label style="font-size: 0.75rem; color: #94a3b8; display: block; margin-bottom: 5px;"><%= __('common_from') %></label>
                    <input type="date" name="payoutFrom" value="<%= payoutFrom %>" class="form-control-lux" style="width: 100%; padding: 8px 12px; border-radius: 8px;">
                </div>
                <div style="flex: 1; min-width: 150px;">
                    <label style="font-size: 0.75rem; color: #94a3b8; display: block; margin-bottom: 5px;"><%= __('common_to') %></label>
                    <input type="date" name="payoutTo" value="<%= payoutTo %>" class="form-control-lux" style="width: 100%; padding: 8px 12px; border-radius: 8px;">
                </div>
                <div style="display: flex; gap: 8px;">
                    <button type="submit" class="btn-lux btn-lux-primary" style="padding: 10px 20px;">
                        <i class="fas fa-filter"></i> <%= __('common_filter') %>
                    </button>
                    <a href="/admin/distribution" class="btn-lux btn-lux-outline" style="padding: 10px 15px; text-decoration: none;" title="<%= __('common_reset') || 'إعادة ضبط' %>">
                        <i class="fas fa-redo"></i>
                    </a>
