    <div style="background: white; width: 550px; border-radius: 24px; padding: 35px; box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25); border: 1px solid #e2e8f0; text-align: <%= langDir === 'rtl' ? 'right' : 'left' %>; max-height: 90vh; overflow-y: auto;">
