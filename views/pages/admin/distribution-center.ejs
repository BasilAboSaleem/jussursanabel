<script>
    let currentPayoutData = null;
    let currentBankExpectedTotal = 0;

    function toggleAllBank(master) {
        document.querySelectorAll('.bank-check').forEach(cb => cb.checked = master.checked);
    }

    let currentBankProofBase64 = '';

    function handleBankProofSelect(event) {
        const file = event.target.files[0];
        if (!file) return;
        
        const reader = new FileReader();
        reader.onload = function(e) {
            currentBankProofBase64 = e.target.result;
            document.getElementById('bankProofPreview').style.display = 'block';
            document.getElementById('bankProofPrompt').style.display = 'none';
        };
        reader.readAsDataURL(file);
    }

    function exportToExcel(tableId, filename) {
        const table = document.getElementById(tableId);
        const wb = XLSX.utils.table_to_book(table, { sheet: "SheetJS" });
        XLSX.writeFile(wb, `${filename}_${new Date().toISOString().slice(0,10)}.xlsx`);
    }

    function changePage(type, page) {
        const url = new URL(window.location.href);
        if (type === 'receipt') url.searchParams.set('receiptPage', page);
        if (type === 'payout') url.searchParams.set('payoutPage', page);
        window.location.href = url.toString();
    }

    function openBankConfirmModal() {
        const selected = Array.from(document.querySelectorAll('.bank-check:checked'));
        if (selected.length === 0) return Swal.fire({ icon: 'warning', text: 'Please select items first' });

        let expDonations = 0; let expFees = 0;
        selected.forEach(cb => {
            const tr = cb.closest('tr');
            expDonations += parseFloat(tr.querySelector('.trans-net').value || 0);
            expFees += parseFloat(tr.querySelector('.trans-fee').value || 0);
        });

        currentBankExpectedTotal = expDonations + expFees;
        document.getElementById('bcExpectedDonations').textContent = '$' + expDonations.toFixed(2);
        document.getElementById('bcExpectedFees').textContent = '$' + expFees.toFixed(2);
        document.getElementById('bcExpectedTotal').textContent = '$' + currentBankExpectedTotal.toFixed(2);
        document.getElementById('bcActualReceived').value = currentBankExpectedTotal.toFixed(2);
        
        // Reset and Calculate
        calculateVariance();
        
        const modal = document.getElementById('bankConfirmModal');
        modal.querySelector('div').classList.add('animate-slide-down');
        modal.style.display = 'flex';
    }

    function closeBankConfirmModal() { document.getElementById('bankConfirmModal').style.display = 'none'; }

    function calculateVariance() {
        const actual = parseFloat(document.getElementById('bcActualReceived').value || 0);
        const variance = currentBankExpectedTotal - actual;
        const alertBox = document.getElementById('bcVarianceAlert');
        
        if (variance > 0.01) {
            document.getElementById('bcVarianceAmount').textContent = variance.toFixed(2);
            alertBox.style.display = 'block';
            alertBox.classList.add('animate-slide-down');
        } else {
            alertBox.style.display = 'none';
        }
    }

    async function submitBankConfirm() {
        const selected = Array.from(document.querySelectorAll('.bank-check:checked')).map(cb => cb.value);
        const actualReceived = document.getElementById('bcActualReceived').value;
        const shortfallAction = document.getElementById('bcShortfallAction').value;
        const notes = document.getElementById('bcNotes').value;

        if (selected.length === 0) return Swal.fire({ icon: 'warning', text: '<%= __('admin_dist_no_selection_error') %>' });
        if (!actualReceived) return Swal.fire({ icon: 'warning', text: '<%= __('admin_dist_actual_amount_error') %>' });

        try {
            const res = await fetch('/admin/distribution/confirm-bank', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'x-csrf-token': '<%= csrfToken %>' },
                body: JSON.stringify({ 
                    transactionIds: selected, 
                    actualReceived, 
                    shortfallAction, 
                    notes,
                    bankProofImage: currentBankProofBase64
                })
            });
            const data = await res.json();
            if (data.success) {
                Swal.fire({ icon: 'success', text: data.message }).then(() => window.location.reload());
            } else {
                Swal.fire({ icon: 'error', text: data.message });
            }
        } catch (err) { 
            console.error(err);
            Swal.fire({ icon: 'error', text: 'Error processing reconciliation' });
        }
    }

    function openPayoutModalById(id) {
        const registry = window.DISBURSEMENT_REGISTRY || {};
        const data = registry[id];
        if (!data) return Swal.fire({ icon: 'error', text: 'Data not found' });
        
        currentPayoutData = { 
            caseId: data.caseId, 
            amount: data.amount, 
            transactionIds: data.transactionIds, 
            recipient: data.recipient 
        };
        
        document.getElementById('payoutMethodDetails').style.display = 'none';
        document.getElementById('payoutMethod').value = '';
        document.getElementById('payoutCaseTitle').textContent = data.title;
        document.getElementById('payoutAmountTitle').textContent = data.amount.toLocaleString();
        
        const modal = document.getElementById('payoutModal');
        modal.querySelector('div').classList.add('animate-slide-down');
        modal.style.display = 'flex';
    }

    function openRecipientModalById(id) {
        const registry = window.DISBURSEMENT_REGISTRY || {};
        const data = registry[id];
        if (!data) return Swal.fire({ icon: 'error', text: 'Case data not found' });
        
        const r = data.recipient || {};
        document.getElementById('recipName').textContent = r.name || '---';
        document.getElementById('recipId').textContent = r.idNumber || '---';
        document.getElementById('recipPhone').textContent = r.phone || '---';
        document.getElementById('recipAltPhone').textContent = r.altPhone || '---';
        document.getElementById('recipAddress').textContent = r.address || '---';
        
        if (r.phone) {
            document.getElementById('recipWhatsapp').href = `https://wa.me/${r.phone.replace(/\D/g,'')}`;
            document.getElementById('recipWhatsapp').style.display = 'flex';
        } else {
            document.getElementById('recipWhatsapp').style.display = 'none';
        }

        const p = (r.paymentDetails) || {};
        document.getElementById('recipBankName').textContent = p.bankName ? `${p.bankName} (${p.bankBranch || ''})` : '---';
        document.getElementById('recipIban').textContent = p.iban || p.accountNumber || '---';
        document.getElementById('recipPalpay').textContent = p.palpayNumber || '---';
        document.getElementById('recipJawwal').textContent = p.jawwalPayNumber || '---';
        
        const modal = document.getElementById('recipientModal');
        modal.querySelector('div').classList.add('animate-slide-down');
        modal.style.display = 'flex';
    }

    function updatePayoutMethodUI() {
        const method = document.getElementById('payoutMethod').value;
        const detailsBox = document.getElementById('payoutMethodDetails');
        const valueBox = document.getElementById('payoutMethodValue');
        
        if (!method || !currentPayoutData || !currentPayoutData.recipient) {
            detailsBox.style.display = 'none';
            return;
        }

        const p = currentPayoutData.recipient.paymentDetails || {};
        let value = '';
        
        if (method === 'Bank Transfer') value = p.iban || p.accountNumber;
        else if (method === 'PalPay') value = p.palpayNumber;
        else if (method === 'Jawwal Pay') value = p.jawwalPayNumber;
        else value = p.otherMethod;

        valueBox.textContent = value || '<%= __('common_not_available') %>';
        detailsBox.style.display = 'block';
        detailsBox.classList.add('animate-fade-in');
    }

    function closePayoutModal() { document.getElementById('payoutModal').style.display = 'none'; }

    async function confirmPayout() {
        if (!currentPayoutData) return;
        const method = document.getElementById('payoutMethod').value;
        const notes = document.getElementById('payoutNotes').value;
        if (!method) return Swal.fire({ icon: 'warning', text: '<%= __('admin_dist_select_method_error') %>' });

        const btn = document.getElementById('btnConfirmPayout');
        const originalHtml = btn.innerHTML;
        btn.disabled = true;
        btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Processing...';

        try {
            moment.locale('<%= lang %>');
            const dateStr = moment().format('LL');
            const timestamp = moment().format('YYYY-MM-DD HH:mm:ss');
            const payoutNum = 'PAY-' + moment().format('YYYYMMDD') + '-' + Math.floor(1000 + Math.random() * 9000);

            // Populate Receipt Template
            document.getElementById('rctNumber').textContent = '#' + payoutNum;
            document.getElementById('rctDate').textContent = dateStr;
            document.getElementById('rctCase').textContent = document.getElementById('payoutCaseTitle').textContent;
            document.getElementById('rctRecipient').textContent = currentPayoutData.recipient ? currentPayoutData.recipient.name : '---';
            document.getElementById('rctMethod').textContent = method;
            document.getElementById('rctAmount').textContent = '$' + currentPayoutData.amount.toLocaleString();
            document.getElementById('rctNotes').textContent = notes || '---';
            document.getElementById('rctTimestamp').textContent = timestamp;

            const template = document.getElementById('payoutReceiptTemplate');
            const canvas = await html2canvas(template, { 
                scale: 2, 
                logging: false, 
                backgroundColor: '#ffffff',
                useCORS: true
            });
            const receiptBase64 = canvas.toDataURL('image/png');

            const res = await fetch('/admin/distribution/generate-payout', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'x-csrf-token': '<%= csrfToken %>' },
                body: JSON.stringify({ 
                    caseId: currentPayoutData.caseId, 
                    transactionIds: currentPayoutData.transactionIds, 
                    notes, paymentMethod: method, 
                    recipientName: currentPayoutData.recipient ? currentPayoutData.recipient.name : '---', 
                    receiptImage: receiptBase64 
                })
            });
            
            const data = await res.json();
            if (data.success) {
                Swal.fire({ icon: 'success', text: data.message }).then(() => {
                    window.location.reload();
                });
            } else {
                Swal.fire({ icon: 'error', title: 'Error', text: data.message || 'Server error' });
            }
        } catch (err) { 
            console.error('System Capture Error:', err);
            Swal.fire({ icon: 'error', title: 'System Error', text: err.message || 'Capture failed' });
        } finally { 
            btn.disabled = false; 
            btn.innerHTML = originalHtml; 
        }
    }

    function closeRecipientModal() { document.getElementById('recipientModal').style.display = 'none'; }
    
    // Detailed View for Recent Payouts
    document.addEventListener('click', function(e) {
        if (e.target.closest('.btn-view-payout')) {
            const btn = e.target.closest('.btn-view-payout');
            const data = btn.dataset;
            
            let html = `
                <div style="text-align: <%= langDir === 'rtl' ? 'right' : 'left' %>; font-family: 'Cairo', sans-serif;">
                    <div style="background: #f8fafc; padding: 15px; border-radius: 12px; margin-bottom: 20px; border: 1px solid #e2e8f0;">
                        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px;">
                            <div><small style="color: #94a3b8;"><%= __('admin_dist_payout_method') %></small><div style="font-weight: 800; color: var(--primary);">${data.method}</div></div>
                            <div><small style="color: #94a3b8;"><%= __('common_amount') %></small><div style="font-weight: 900; color: #16a34a; font-size: 1.2rem;">$${data.amount}</div></div>
                        </div>
                        <div style="margin-top: 15px;"><small style="color: #94a3b8;"><%= __('common_notes') %></small><div style="font-style: italic; color: #64748b;">${data.notes || '---'}</div></div>
                    </div>
            `;
            
            if (data.image) {
                html += `
                    <div style="margin-top: 10px;">
                        <small style="color: #94a3b8; display: block; margin-bottom: 8px;"><%= __('admin_payout_receipt_title') %></small>
                        <img src="${data.image}" style="width: 100%; border-radius: 12px; border: 1px solid #e2e8f0; box-shadow: var(--shadow-sm); cursor: pointer;" onclick="window.open('${data.image}', '_blank')">
                        <small style="display: block; text-align: center; margin-top: 8px; color: var(--secondary);"><%= __('admin_dist_click_to_expand') || 'انقر لتوسيع الصورة' %></small>
                    </div>
                `;
            } else {
                html += `<div style="text-align: center; padding: 20px; color: #94a3b8; border: 1px dashed #cbd5e1; border-radius: 12px;"><%= __('admin_dist_no_receipt_image') || 'لا توجد صورة وصل لهذا السند' %></div>`;
            }
            
            html += `</div>`;
            
            Swal.fire({
                title: '<%= __('admin_payout_receipt_title') %> #' + data.number,
                html: html,
                width: '600px',
                showCloseButton: true,
                confirmButtonText: '<%= __('common_close') %>',
                confirmButtonColor: 'var(--primary--800)'
            });
        }
    });

    async function viewBankReceiptTransactions(id) {
        try {
            const res = await fetch(`/admin/distribution/receipt/${id}`);
            const data = await res.json();
            if (data.success) {
                const r = data.receipt;
                document.getElementById('bankBatchInfo').innerHTML = `
                    <div><small style="color: #94a3b8;"><%= __('admin_dist_receipt_ref') %></small><div style="font-weight: 800;">${r.reference}</div></div>
                    <div><small style="color: #94a3b8;"><%= __('admin_dist_expected') %></small><div style="font-weight: 800;">$${r.expectedTotal}</div></div>
                    <div><small style="color: #94a3b8;"><%= __('admin_dist_actual') %></small><div style="font-weight: 800; color: #16a34a;">$${r.actualReceived}</div></div>
                `;
                
                let rows = '';
                r.transactions.forEach(t => {
                    rows += `
                        <tr style="border-bottom: 1px solid #f1f5f9;">
                            <td>${new Date(t.createdAt).toLocaleDateString()}</td>
                            <td style="font-weight: 700;">${t.case ? t.case.title : '---'}</td>
                            <td>${t.donor ? t.donor.name : '---'}</td>
                            <td style="font-weight: 800;">$${t.amount}</td>
                        </tr>
                    `;
                });
                document.getElementById('bankBatchTableBody').innerHTML = rows;
                document.getElementById('bankBatchModal').style.display = 'flex';
                document.getElementById('bankBatchModal').querySelector('div').classList.add('animate-slide-down');
            }
        } catch (err) {
            Swal.fire({ icon: 'error', text: 'Failed to fetch details' });
        }
    }

    function closeBankBatchModal() { document.getElementById('bankBatchModal').style.display = 'none'; }

    async function confirmRevertBankBatch(id, ref) {
        const result = await Swal.fire({
            title: '<%= __('common_revert') %> ' + ref,
            text: '<%= __('admin_dist_revert_warning') || 'Are you sure? This will un-confirm all transactions in this batch.' %>',
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#ef4444',
            confirmButtonText: '<%= __('common_yes_revert') || 'Yes, Revert' %>'
        });

        if (result.isConfirmed) {
            try {
                const res = await fetch(`/admin/distribution/revert-bank/${id}`, {
                    method: 'POST',
                    headers: { 'x-csrf-token': '<%= csrfToken %>' }
                });
                const data = await res.json();
                if (data.success) {
                    Swal.fire({ icon: 'success', text: data.message }).then(() => window.location.reload());
                } else {
                    Swal.fire({ icon: 'error', text: data.message });
                }
            } catch (err) {
                Swal.fire({ icon: 'error', text: 'Action failed' });
            }
        }
    }

    async function revertPayout(id) {
        const result = await Swal.fire({
            title: '<%= __('common_revert_payout') || 'إلغاء سند الصرف' %>',
            text: '<%= __('admin_dist_revert_payout_warning') || 'سيتم استعادة المبالغ لعهدة التوزيع المعلقة وإضافة تنبيه في سجل الحالة.' %>',
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#ef4444',
            confirmButtonText: '<%= __('common_yes_cancel') || 'نعم، إلغاء السند' %>'
        });

        if (result.isConfirmed) {
            try {
                const res = await fetch(`/admin/distribution/revert-payout/${id}`, {
                    method: 'POST',
                    headers: { 'x-csrf-token': '<%= csrfToken %>' }
                });
                const data = await res.json();
                if (data.success) {
                    Swal.fire({ icon: 'success', text: data.message }).then(() => window.location.reload());
                } else {
                    Swal.fire({ icon: 'error', text: data.message });
                }
            } catch (err) {
                Swal.fire({ icon: 'error', text: 'Action failed' });
            }
        }
    }
</script>

