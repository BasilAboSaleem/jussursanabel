                                    <%= receipt.createdAt.toLocaleDateString(lang === 'ar' ? 'ar-EG' : 'en-US') %>
                                </td>
                                <td style="vertical-align: middle; padding: 12px 8px; font-weight: 800; color: var(--primary); font-size: 1rem; text-align: center;">$<%= receipt.expectedTotal.toLocaleString() %></td>
