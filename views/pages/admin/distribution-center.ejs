            <div id="payoutMethodValue" style="font-family: monospace; word-break: break-all; font-weight: 900; color: #c2410c; background: white; padding: 12px; border-radius: 10px; border: 1px solid #fed7aa; text-align: center; font-size: 1.1rem; box-shadow: inset 0 2px 4px rgba(0,0,0,0.02);"></div>
