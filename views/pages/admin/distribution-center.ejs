        <div style="margin-bottom: 30px;">
            <label style="display: block; font-size: 0.85rem; font-weight: 700; color: #475569; margin-bottom: 8px;"><%= __('common_note') %></label>
            <textarea id="payoutNotes" class="form-control-lux" rows="3" style="width: 100%; border-radius: 14px; padding: 12px; border: 1px solid #e2e8f0; font-size: 0.9rem;"></textarea>
        </div>

        <div style="display: flex; gap: 12px;">
            <button class="btn-lux btn-lux-outline" style="flex: 1; padding: 14px; font-weight: 700;" onclick="closePayoutModal()"><%= __('common_cancel') %></button>
            <button id="btnConfirmPayout" class="btn-lux btn-lux-success" style="flex: 2; padding: 14px; font-weight: 900; font-size: 1.05rem;" onclick="confirmPayout()">
