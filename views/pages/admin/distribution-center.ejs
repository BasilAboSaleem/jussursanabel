            <div style="background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 20px; padding: 20px;">
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px;">
                    <span style="font-weight: 800; color: #475569; font-size: 0.85rem;"><%= __('admin_dist_bank_details') %></span>
                    <span id="recipBankName" style="background: white; border: 1px solid #e2e8f0; padding: 4px 12px; border-radius: 12px; font-weight: 900; color: var(--primary); font-size: 0.8rem;"></span>
                </div>
                <div style="background: white; padding: 12px 15px; border-radius: 14px; display: flex; justify-content: space-between; align-items: center; border: 1px solid #f1f5f9; box-shadow: inset 0 2px 4px rgba(0,0,0,0.02);">
                    <div id="recipIban" style="font-family: monospace; font-weight: 950; color: #334155; font-size: 1.05rem; letter-spacing: 0.5px;"></div>
                    <button onclick="copyToClipboard('recipIban')" class="btn-lux" style="padding: 6px 15px; font-size: 0.75rem; background: #e0f2fe; color: #0369a1; border: none; font-weight: 800; border-radius: 8px;">
