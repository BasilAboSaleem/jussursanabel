    .help-card-lux {
        padding: 25px;
    }

    .help-item {
        padding: 15px;
        border-radius: 15px;
        margin-bottom: 15px;
    }

    .help-item.teal-border { background: rgba(20, 184, 166, 0.04); border-right: 4px solid var(--accent); }
    .help-item.gold-border { background: rgba(217, 119, 6, 0.04); border-right: 4px solid var(--secondary); }

    .help-item h5 { margin-bottom: 5px; color: var(--primary); font-weight: 800; }
    .help-item p { font-size: 0.85rem; color: var(--text-muted); line-height: 1.5; margin: 0; }

    .support-CTA-lux {
        background: var(--grad-navy);
        padding: 25px;
        border-radius: 20px;
        color: white;
        text-align: center;
        margin-top: 10px;
    }

    .support-CTA-lux i { font-size: 2.2rem; margin-bottom: 15px; opacity: 0.5; }
