</style>

<!-- Case Impact Proof Upload Modal -->
<div id="uploadProofModal" class="modal-lux">
    <div class="modal-content-lux" style="max-width: 600px;">
        <div class="modal-header-lux">
            <h4 class="font-cairo" style="margin:0;"><i class="fa-solid fa-upload"></i> رفع إثبات أثر (فواتير/صور)</h4>
            <span class="close-lux" onclick="closeUploadModal()" style="cursor:pointer; font-size: 1.5rem; color: white;">&times;</span>
        </div>
        <div class="modal-body-lux">
            <p style="font-size: 0.85rem; color: #64748b; margin-bottom: 20px;">
                قم برفع صور الفواتير أو صور الحالة أثناء استلام المساعدة لتوثيق الأثر للمتبرعين. سيخضع الطلب لمراجعة الإدارة قبل النشر.
            </p>
            <form id="uploadProofForm" action="" method="POST" enctype="multipart/form-data">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <div class="form-group-lux" style="margin-bottom: 15px;">
                    <label style="display: block; margin-bottom: 8px; font-weight: 700; color: var(--primary);">عنوان التحديث (مثال: شراء كسوة شتاء)</label>
                    <input type="text" name="title" required placeholder="مثلاً: استلام مخصصات يناير" style="width: 100%; padding: 10px; border-radius: 10px; border: 1px solid #e2e8f0;">
                </div>
                <div class="form-group-lux" style="margin-bottom: 15px;">
                    <label style="display: block; margin-bottom: 8px; font-weight: 700; color: var(--primary);">وصف مختصر</label>
                    <textarea name="content" rows="3" required placeholder="اشرح للمتبرع كيف ساعده هذا العطاء..." style="width: 100%; padding: 10px; border-radius: 10px; border: 1px solid #e2e8f0;"></textarea>
                </div>
                <div class="form-group-lux" style="margin-bottom: 15px;">
                    <label style="display: block; margin-bottom: 8px; font-weight: 700; color: var(--primary);">الصور والإثباتات (يمكنك اختيار عدة صور)</label>
                    <input type="file" name="images" multiple accept="image/*" required style="width: 100%; padding: 10px; border: 1px dashed #cbd5e1; border-radius: 10px;">
                    <small style="color: #94a3b8; display: block; margin-top: 5px;">يفضل رفع صور واضحة للفواتير أو السلع المستلمة.</small>
                </div>
                <div style="margin-top: 25px; display: flex; gap: 10px;">
                    <button type="submit" class="btn-lux btn-lux-primary" style="flex: 1;">إرسال المراجعة</button>
                    <button type="button" onclick="closeUploadModal()" class="btn-lux btn-lux-outline" style="flex: 1;">إلغاء</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Donations Modal -->
<div id="donationsModal" class="modal-lux">
    <div class="modal-content-lux">
        <div class="modal-header-lux">
            <h4 class="font-cairo" style="margin:0;"><i class="fas fa-hand-holding-dollar"></i> سجل التبرعات: <span id="modalCaseTitle"></span></h4>
            <button onclick="closeModal()" style="background:none; border:none; color:white; font-size:1.5rem; cursor:pointer;"><i class="fas fa-times"></i></button>
        </div>
        <div class="modal-body-lux">
            <div id="transactionsList">
                <div style="text-align: center; padding: 40px; color: var(--text-muted);">
                    <i class="fas fa-spinner fa-spin fa-2x"></i>
                    <p>جاري تحميل السجل...</p>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    async function viewDonations(id, title) {
        const modal = document.getElementById('donationsModal');
        const list = document.getElementById('transactionsList');
        const titleSpan = document.getElementById('modalCaseTitle');
        
        titleSpan.innerText = title;
        modal.style.display = 'flex';
        list.innerHTML = `<div style="text-align: center; padding: 40px; color: var(--text-muted);"><i class="fas fa-spinner fa-spin fa-2x"></i><p>جاري تحميل السجل...</p></div>`;

        try {
            const res = await fetch(`/dashboard/case/${id}/transactions`);
            const data = await res.json();
            
            if (data.success) {
                if (data.transactions.length === 0) {
                    list.innerHTML = `<div style="text-align: center; padding: 60px; color: #94a3b8;"><i class="fas fa-heart-crack fa-3x" style="opacity:0.2; margin-bottom:15px;"></i><p>لم يتم استلام أي تبرعات موثقة لهذه الحالة بعد.</p></div>`;
                } else {
                    list.innerHTML = data.transactions.map(t => `
                        <div class="donation-history-item">
                            <div>
                                <div style="font-weight:700; color:var(--primary);">${t.donor ? t.donor.name : 'فاعل خير'}</div>
                                <div style="font-size:0.75rem; color:var(--text-muted);">${new Date(t.createdAt).toLocaleDateString('ar-EG')}</div>
                            </div>
                            <div style="text-align:left;">
                                <div style="font-weight:900; color:var(--secondary); font-size:1.1rem;">$${t.amount}</div>
                                <div style="font-size:0.7rem; color:#10b981; font-weight:700;">${t.type === 'monthly' ? 'كفالة شهرية' : 'تبرع مباشر'}</div>
                            </div>
                        </div>
                    `).join('');
                }
            }
        } catch (err) {
            list.innerHTML = '<p style="color:var(--danger); text-align:center;">حدث خطأ أثناء تحميل البيانات.</p>';
        }
    }

    function closeModal() {
        document.getElementById('donationsModal').style.display = 'none';
    }

    window.onclick = function(event) {
        if (event.target == document.getElementById('donationsModal')) {
            closeModal();
        }
        if (event.target == document.getElementById('uploadProofModal')) {
            closeUploadModal();
        }
    }

    // --- Proof Upload Modal Logic ---
    function openUploadProofModal(caseId, caseTitle) {
        const modal = document.getElementById('uploadProofModal');
        const form = document.getElementById('uploadProofForm');
        form.action = `/dashboard/case/${caseId}/proof-of-impact`;
        modal.style.display = 'flex'; // Centered via flex
    }

    function closeUploadModal() {
        document.getElementById('uploadProofModal').style.display = 'none';
    }

    // --- Premium Real-time Countdown Logic ---
    function updateCommCountdown() {
        let chatDay = '<%= chatDay %>'; // e.g., '1' or 'Monday'
        const now = new Date();
        const days = ['Sunday', 'Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday'];
        const daysAr = ['الأحد', 'الإثنين', 'الثلاثاء', 'الأربعاء', 'الخميس', 'الجمعة', 'السبت'];
        
        let targetDayIndex;
        if (!isNaN(chatDay)) {
            targetDayIndex = parseInt(chatDay);
        } else {
            targetDayIndex = days.indexOf(chatDay);
        }
        
        if (targetDayIndex === -1) targetDayIndex = 1; // Default to Monday if invalid
        
        let nextChat = new Date();
        nextChat.setDate(now.getDate() + (targetDayIndex + 7 - now.getDay()) % 7);
        nextChat.setHours(9, 0, 0, 0); // Open at 9 AM

        if (nextChat < now) nextChat.setDate(nextChat.getDate() + 7);

        const diff = nextChat - now;
        
        const d = Math.floor(diff / (1000 * 60 * 60 * 24));
        const h = Math.floor((diff / (1000 * 60 * 60)) % 24);
        const m = Math.floor((diff / (1000 * 60)) % 60);
        const s = Math.floor((diff / 1000) % 60);
        
        const display = document.getElementById('countdownDisplay');
        const timeStr = `${h < 10 ? '0'+h : h} : ${m < 10 ? '0'+m : m} : ${s < 10 ? '0'+s : s}`;

        if (d > 0) {
            display.innerHTML = `<span style="font-size: 1.2rem;">${d} أيام و </span>${timeStr}`;
        } else {
            display.innerHTML = timeStr;
        }

        // Ensure the sub-label shows the correct day name in Arabic
        const subLabel = document.querySelector('.countdown-sub-lux');
        if (subLabel) {
            subLabel.innerHTML = `يوم التواصل القادم: <strong>${daysAr[targetDayIndex]}</strong>`;
        }
    }

    setInterval(updateCommCountdown, 1000);
    updateCommCountdown();
</script>

