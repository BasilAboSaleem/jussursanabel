<%- include('../../partials/header-top') %>

<main style="overflow: hidden;">
    <!-- 1. Majestic Hero Section -->
    <section class="hero-luxury" style="min-height: 55vh; padding: 90px 5% 100px; display: flex; align-items: center; background: var(--grad-navy); position: relative; overflow: hidden; text-align: center;">
        <!-- Brand Gradient Overlay -->
        <div style="position: absolute; inset: 0; background: radial-gradient(circle at center, rgba(16, 185, 129, 0.25) 0%, transparent 70%);"></div>
        <div class="bg-mesh" style="opacity: 0.6;"></div>
        
        <div class="container" style="position: relative; z-index: 20;">
            <span class="hero-badge-luxury reveal-on-scroll" style="background: rgba(16, 185, 129, 0.15); border: 1px solid rgba(16, 185, 129, 0.3); color: var(--secondary-light); padding: 8px 25px; font-size: 0.9rem; letter-spacing: 1px;">
                <i class="fas fa-sparkles"></i> <%= __('index_features_badge') %>
            </span>
            <h1 class="hero-title-luxury reveal-on-scroll" style="font-size: clamp(3rem, 6vw, 5.5rem); margin-top: 25px; margin-bottom: 25px; color: #fff; line-height: 1.1; font-weight: 950; text-shadow: 0 20px 40px rgba(0,0,0,0.3);">
                <%= __('cases_hero_title') %>
            </h1>
            <p class="hero-desc-luxury reveal-on-scroll" style="transition-delay: 0.2s; color: rgba(255,255,255,0.85); max-width: 750px; margin: 0 auto; font-size: 1.25rem; line-height: 1.8; font-weight: 500;">
                <%= __('cases_hero_desc') %>
            </p>
        </div>

        <!-- Hero Bottom Fade -->
        <div style="position: absolute; bottom: 0; left: 0; right: 0; height: 150px; background: linear-gradient(to top, #ffffff, transparent); z-index: 10;"></div>
    </section>

    <!-- 2. The Floating Filter Bridge -->
    <div class="container" style="position: relative; z-index: 50; margin-top: -55px; display: flex; justify-content: center;">
        <div class="reveal-on-scroll filter-bar-capsule" style="background: rgba(255, 255, 255, 0.85); backdrop-filter: blur(25px); -webkit-backdrop-filter: blur(25px); border: 1px solid rgba(255,255,255,0.7); box-shadow: 0 30px 70px rgba(0,0,0,0.1); padding: 15px; border-radius: 40px; display: inline-flex; align-items: center; gap: 10px; position: relative;">
            <a href="/cases?type=all&limit=<%= pagination?.limit || 24 %>" class="filter-btn-lux <%= (selectedType || 'all') === 'all' ? 'active' : '' %>" data-filter="all">
                <i class="fas fa-border-all"></i> <%= __('cases_filter_all') %>
            </a>
            <a href="/cases?type=orphan&limit=<%= pagination?.limit || 24 %>" class="filter-btn-lux <%= selectedType === 'orphan' ? 'active' : '' %>" data-filter="orphan">
                <i class="fas fa-child-reaching"></i> <%= __('cases_type_orphan') %>
            </a>
            <a href="/cases?type=family&limit=<%= pagination?.limit || 24 %>" class="filter-btn-lux <%= selectedType === 'family' ? 'active' : '' %>" data-filter="family">
                <i class="fas fa-users-gear"></i> <%= __('cases_type_family') %>
            </a>
        </div>
    </div>

    <!-- 3. Content Section -->
    <section class="section-luxury container" style="padding-top: 80px;">
        <div class="cases-toolbar reveal-on-scroll" style="display: flex; align-items: center; justify-content: space-between; gap: 12px; margin-bottom: 26px; flex-wrap: wrap;">
            <div style="display: flex; align-items: center; gap: 10px; color: var(--text-muted); font-weight: 700;">
                <i class="fas fa-layer-group" style="color: var(--secondary);"></i>
                <span>
                    <%= pagination?.total || 0 %>
                    <%= locals.currentLocale === 'ar' ? 'حالة متاحة' : 'available cases' %>
                </span>
            </div>

            <div style="display: flex; align-items: center; gap: 8px;">
                <% if ((pagination?.total || 0) > (pagination?.limit || 24)) { %>
                    <span style="font-size: 0.85rem; color: var(--text-muted); font-weight: 700;"><%= locals.currentLocale === 'ar' ? 'العدد في الصفحة:' : 'Per page:' %></span>
                    <a href="/cases?type=<%= selectedType || 'all' %>&limit=24" class="per-page-chip <%= (pagination?.limit || 24) === 24 ? 'active' : '' %>">24</a>
                    <a href="/cases?type=<%= selectedType || 'all' %>&limit=36" class="per-page-chip <%= (pagination?.limit || 24) === 36 ? 'active' : '' %>">36</a>
                    <a href="/cases?type=<%= selectedType || 'all' %>&limit=48" class="per-page-chip <%= (pagination?.limit || 24) === 48 ? 'active' : '' %>">48</a>
                <% } else { %>
                    <span class="single-page-status" style="font-size: 0.85rem; color: var(--text-muted); font-weight: 700;">
                        <%= locals.currentLocale === 'ar' ? 'صفحة 1 من 1' : 'Page 1 of 1' %>
                    </span>
                <% } %>
            </div>
        </div>

        <div class="grid-3" id="casesGrid" style="gap: 40px;">
            <% if (typeof cases !== 'undefined' && cases.length > 0) { %>
                <% cases.forEach((item, index) => { %>
                    <div class="luxury-card case-card h-100 reveal-on-scroll" data-type="<%= item.type %>" style="transition-delay: <%= index * 0.1 %>s">
                        <!-- Image Container with improved aesthetics -->
                        <div class="card-image-wrapper">
                            <img src="<%= item.image %>" alt="<%= item.title %>" class="case-image">
                            <!-- Soft Overlay for depth -->
                            <div class="image-overlay"></div>
                            <!-- Badge -->
                            <div class="badge <%= item.type === 'orphan' ? 'badge-gold' : 'badge-teal' %> case-badge">
                                <i class="fas <%= item.type === 'orphan' ? 'fa-child' : 'fa-users' %>"></i>
                                <%= item.type === 'orphan' ? __('cases_type_orphan') : __('cases_type_family') %>
                            </div>

                            <% if (item.isFieldVerified) { %>
                                <div class="verified-badge" title="<%= __('cases_verified_tooltip') %>">
                                    <i class="fas fa-check-circle"></i> <%= __('cases_verified_text') %>
                                </div>
                            <% } %>

                            <% if (item.isSatisfied) { %>
                                <div class="satisfied-overlay">
                                    <span class="badge" style="background: var(--secondary); color: white; border: none; padding: 10px 20px; font-weight: 900; box-shadow: 0 4px 15px rgba(16, 185, 129, 0.4);">
                                        <i class="fas fa-heart-circle-check"></i> <%= __('cases_satisfied_text') %>
                                    </span>
                                </div>
                            <% } %>
                        </div>
                        
                        <div class="card-body-content" style="position: relative;">
                            <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 8px;">
                                <h3 class="font-cairo case-title" style="margin: 0;">
                                    <%= item.title %>
                                </h3>
                                <% if (item.area) { %>
                                    <span style="font-size: 0.75rem; color: var(--secondary); font-weight: 700; background: rgba(16, 185, 129, 0.1); padding: 2px 8px; border-radius: 5px;">
                                        <i class="fas fa-location-dot"></i> <%= item.area %>
                                    </span>
                                <% } %>
                            </div>
                            <p class="case-description">
                                <%= item.description %>
                            </p>

                            <div class="card-footer-stats">
                                <div class="progress-track">
                                    <div class="progress-fill" style="width: <%= Math.min((item.raisedAmount / (item.targetAmount || 1) * 100), 100) %>%;"></div>
                                </div>
                                <div class="stats-labels">
                                    <span class="raised-text"><%= __('cases_raised_text') %> $<%= item.raisedAmount %></span>
                                    <span class="target-text"><%= __('cases_target_text') %> $<%= item.targetAmount || __('cases_target_open') %></span>
                                </div>

                                <a href="/cases/<%= item._id %>" class="btn-lux btn-lux-primary btn-sm btn-full-width" style="background: var(--grad-green); color: #fff; box-shadow: 0 10px 20px rgba(16, 185, 129, 0.2);">
                                    <%= __('cases_btn_details') %> <i class="fas fa-arrow-<%= langDir === 'rtl' ? 'left' : 'right' %>"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                <% }) %>
            <% } else { %>
                <div style="grid-column: 1 / -1; text-align: center; padding: 100px 5%; background: white; border-radius: 30px; border: 2px dashed #f1f5f9;" class="reveal-on-scroll">
                    <div style="width: 100px; height: 100px; background: #f8fafc; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 25px; color: #cbd5e1;">
                        <i class="fas fa-magnifying-glass-chart fa-3x"></i>
                    </div>
                    <h3 class="font-cairo" style="color: var(--primary); font-weight: 900;"><%= __('cases_empty_title') %></h3>
                    <p style="color: var(--text-muted); max-width: 400px; margin: 0 auto;"><%= __('cases_empty_desc') %></p>
                </div>
            <% } %>
        </div>

        <% if ((pagination?.totalPages || 1) > 1) { %>
            <% 
                const currentPage = pagination.page;
                const totalPages = pagination.totalPages;
                const startPage = Math.max(1, currentPage - 2);
                const endPage = Math.min(totalPages, currentPage + 2);
                const typeParam = selectedType || 'all';
                const limitParam = pagination.limit || 24;
                const pageUrl = (p) => `/cases?type=${typeParam}&limit=${limitParam}&page=${p}`;
            %>

            <nav aria-label="Cases pagination" class="cases-pagination" style="display: flex; justify-content: center; margin-top: 38px;">
                <ul class="pagination-lux" style="display: flex; list-style: none; padding: 0; gap: 8px; flex-wrap: wrap; justify-content: center;">
                    <% if (currentPage > 1) { %>
                        <li><a class="page-link-lux" href="<%= pageUrl(currentPage - 1) %>" aria-label="Previous"><i class="fas fa-chevron-<%= langDir === 'rtl' ? 'right' : 'left' %>"></i></a></li>
                    <% } %>

                    <% if (startPage > 1) { %>
                        <li><a class="page-link-lux" href="<%= pageUrl(1) %>">1</a></li>
                        <% if (startPage > 2) { %>
                            <li><span class="page-link-lux disabled">...</span></li>
                        <% } %>
                    <% } %>

                    <% for(let i = startPage; i <= endPage; i++) { %>
                        <li><a class="page-link-lux <%= currentPage === i ? 'active' : '' %>" href="<%= pageUrl(i) %>"><%= i %></a></li>
                    <% } %>

                    <% if (endPage < totalPages) { %>
                        <% if (endPage < totalPages - 1) { %>
                            <li><span class="page-link-lux disabled">...</span></li>
                        <% } %>
                        <li><a class="page-link-lux" href="<%= pageUrl(totalPages) %>"><%= totalPages %></a></li>
                    <% } %>

                    <% if (currentPage < totalPages) { %>
                        <li><a class="page-link-lux" href="<%= pageUrl(currentPage + 1) %>" aria-label="Next"><i class="fas fa-chevron-<%= langDir === 'rtl' ? 'left' : 'right' %>"></i></a></li>
                    <% } %>
                </ul>
            </nav>
        <% } %>
    </section>
</main>

<style>
    .filter-bar-capsule {
        z-index: 100;
        min-width: fit-content;
    }

    .filter-btn-lux {
        padding: 12px 28px;
        font-size: 0.95rem;
        cursor: pointer;
        border-radius: 30px;
        border: 1px solid transparent;
        background: transparent;
        color: var(--primary);
        font-weight: 750;
        transition: all 0.4s var(--ease-smooth);
        font-family: 'Cairo', sans-serif;
        display: flex;
        align-items: center;
        gap: 10px;
        text-decoration: none;
    }

    .filter-btn-lux i {
        font-size: 1.1rem;
        opacity: 0.6;
        transition: 0.3s;
    }

    .filter-btn-lux:hover {
        background: rgba(16, 185, 129, 0.05);
        color: var(--secondary);
    }

    .filter-btn-lux.active {
        background: var(--primary);
        color: white;
        box-shadow: 0 15px 35px rgba(2, 6, 23, 0.2);
    }

    .filter-btn-lux.active i {
        opacity: 1;
        color: var(--secondary);
    }

    /* Card Improvements */
    .case-card {
        padding: 0 !important;
        transition: all 0.5s cubic-bezier(0.165, 0.84, 0.44, 1);
        overflow: hidden;
        display: flex;
        flex-direction: column;
        border: 1px solid rgba(0,0,0,0.05);
        background: #fff;
    }

    .card-image-wrapper {
        height: 280px;
        position: relative;
        overflow: hidden;
        background: #0f172a;
        margin: 12px;
        border-radius: 20px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
    }

    .case-image {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.8s cubic-bezier(0.165, 0.84, 0.44, 1);
        display: block;
    }

    .image-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(to top, rgba(2, 6, 23, 0.8) 0%, transparent 40%, rgba(2, 6, 23, 0.2) 100%);
        opacity: 0.6;
        transition: opacity 0.4s ease;
    }

    /* Shimmer effect for images */
    .card-image-wrapper::after {
        content: "";
        position: absolute;
        top: 0; right: 0; bottom: 0; left: 0;
        background: linear-gradient(to right, transparent, rgba(255,255,255,0.1), transparent);
        transform: translateX(-100%);
        transition: transform 0.6s ease;
    }

    .case-card:hover .card-image-wrapper::after {
        transform: translateX(100%);
    }

    .case-badge {
        position: absolute;
        top: 15px;
        right: 15px;
        z-index: 10;
        box-shadow: 0 8px 20px rgba(0,0,0,0.2);
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        border: 1px solid rgba(255,255,255,0.1);
    }

    .verified-badge {
        position: absolute;
        top: 15px;
        left: 15px;
        z-index: 10;
        background: #10b981;
        color: white;
        padding: 5px 12px;
        border-radius: 50px;
        font-size: 0.7rem;
        font-weight: 800;
        display: flex;
        align-items: center;
        gap: 5px;
        box-shadow: 0 4px 12px rgba(16, 185, 129, 0.3);
        border: 1px solid rgba(255,255,255,0.2);
    }

    .card-body-content {
        padding: 20px 30px 30px;
        flex-grow: 1;
        display: flex;
        flex-direction: column;
    }

    .case-title {
        font-size: 1.4rem;
        margin-bottom: 12px;
        font-weight: 850;
        color: var(--primary);
        transition: color 0.3s ease;
        line-height: 1.3;
    }

    .case-description {
        color: var(--text-muted);
        font-size: 0.95rem;
        margin-bottom: 25px;
        line-height: 1.8;
        height: 3.6em;
        overflow: hidden;
        display: -webkit- box;
        -webkit-line-clamp: 2;
        line-clamp: 2;
        -webkit-box-orient: vertical;
    }

    .card-footer-stats {
        margin-top: auto;
    }

    .progress-track {
        margin-bottom: 15px;
        height: 10px;
        background: #f8fafc;
        border-radius: 20px;
        overflow: hidden;
        border: 1px solid #f1f5f9;
    }

    .stats-labels {
        display: flex;
        justify-content: space-between;
        font-size: 0.9rem;
        font-weight: 800;
        margin-bottom: 25px;
    }

    .raised-text { color: var(--secondary); }
    .target-text { color: #94a3b8; }

    .btn-full-width {
        width: 100%;
        justify-content: center;
        border-radius: 16px;
        padding: 14px 20px;
        font-weight: 800;
        box-shadow: 0 4px 12px rgba(2, 6, 23, 0.1);
    }

    .case-card:hover {
        transform: translateY(-12px);
        box-shadow: 0 40px 80px rgba(2, 6, 23, 0.12), 0 0 30px rgba(226, 176, 100, 0.08);
        border-color: var(--secondary);
    }

    .case-card:hover .case-image {
        transform: scale(1.12);
    }

    .case-card:hover .image-overlay {
        opacity: 0.4;
    }
    
    .case-card:hover .case-title {
        color: var(--secondary);
    }

    /* Animation for filtering */
    @keyframes fadeScale {
        from { opacity: 0; transform: translateY(20px) scale(0.98); }
        to { opacity: 1; transform: translateY(0) scale(1); }
    }

    .case-card.filtering {
        animation: fadeScale 0.5s cubic-bezier(0.165, 0.84, 0.44, 1) forwards;
    }

    .per-page-chip {
        min-width: 42px;
        height: 34px;
        border-radius: 999px;
        border: 1px solid #e2e8f0;
        color: var(--text-muted);
        background: #fff;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-weight: 800;
        font-size: 0.82rem;
        transition: all 0.25s ease;
        padding: 0 12px;
    }

    .per-page-chip:hover {
        border-color: rgba(16, 185, 129, 0.4);
        color: var(--secondary);
        transform: translateY(-1px);
    }

    .per-page-chip.active {
        background: var(--primary);
        color: #fff;
        border-color: var(--primary);
    }

    .page-link-lux {
        width: 40px;
        height: 40px;
        border-radius: 10px;
        border: 1px solid #e2e8f0;
        color: var(--text-muted);
        background: #fff;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-weight: 800;
        transition: all 0.25s ease;
    }

    .page-link-lux:hover {
        border-color: rgba(16, 185, 129, 0.4);
        color: var(--secondary);
        transform: translateY(-1px);
    }

    .page-link-lux.active {
        background: var(--secondary);
        border-color: var(--secondary);
        color: #fff;
        box-shadow: 0 8px 18px rgba(16, 185, 129, 0.22);
    }

    .page-link-lux.disabled {
        pointer-events: none;
        background: #f8fafc;
        color: #94a3b8;
    }

    .satisfied-overlay {
        position: absolute;
        inset: 0;
        background: rgba(255,255,255,0.7);
        backdrop-filter: blur(2px);
        z-index: 10;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 20px;
    }
</style>

<script>
    // Reveal on scroll logic
    const observerOptions = { threshold: 0.1 };
    const revealObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                entry.target.classList.add('active');
            }
        });
    }, observerOptions);

    document.querySelectorAll('.reveal-on-scroll').forEach(el => revealObserver.observe(el));

    // Cards are now filtered/paginated server-side for better performance at large scale.
</script>

<%- include('../../partials/footer-bottom') %>