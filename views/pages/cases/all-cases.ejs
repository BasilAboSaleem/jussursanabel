<%- include('../../partials/header-top') %>

<main style="overflow: hidden;">
    <!-- Hero Section -->
    <section class="hero-luxury" style="min-height: 45vh; padding: 160px 5% 80px;">
        <div class="bg-mesh"></div>
        
        <!-- Floating Elements -->
        <div class="float-element" style="position: absolute; top: 15%; right: 5%; font-size: 2.5rem; color: var(--secondary); opacity: 0.15; filter: blur(1px);">
            <i class="fas fa-handshake-angle"></i>
        </div>
        <div class="float-element" style="position: absolute; bottom: 15%; left: 5%; font-size: 3rem; color: var(--accent); opacity: 0.15; filter: blur(2px); animation-delay: -3s;">
            <i class="fas fa-dove"></i>
        </div>

        <div class="hero-content-luxury container">
            <h1 class="hero-title-luxury reveal-on-scroll" style="font-size: min(3.5rem, 8vw);">
                <% 
                    const casesHeroTitle = __('cases_hero_title');
                    const casesHighlight = currentLocale === 'ar' ? 'جسور' : 'Jussur';
                    const casesShimmered = casesHeroTitle.includes(casesHighlight) ? casesHeroTitle.replace(casesHighlight, `<span class="shimmer-text">${casesHighlight}</span>`) : casesHeroTitle;
                %>
                <%- casesShimmered %>
            </h1>
            <p class="hero-desc-luxury reveal-on-scroll" style="transition-delay: 0.2s;">
                <%= __('cases_hero_desc') %>
            </p>
        </div>
    </section>

    <!-- Content Section -->
    <section class="section-luxury container" style="margin-top: -40px; position: relative; z-index: 10;">
        <!-- Categories / Filters -->
        <div class="reveal-on-scroll" style="display: flex; gap: 12px; margin-bottom: 50px; flex-wrap: wrap; justify-content: center;">
            <button onclick="filterCases('all')" class="filter-btn active" data-filter="all"><%= __('cases_filter_all') %></button>
            <button onclick="filterCases('orphan')" class="filter-btn" data-filter="orphan"><%= __('cases_type_orphan') %></button>
            <button onclick="filterCases('family')" class="filter-btn" data-filter="family"><%= __('cases_type_family') %></button>
        </div>

        <div class="grid-3" id="casesGrid" style="gap: 30px;">
            <% if (typeof cases !== 'undefined' && cases.length > 0) { %>
                <% cases.forEach((item, index) => { %>
                    <div class="luxury-card case-card h-100 reveal-on-scroll" data-type="<%= item.type %>" style="transition-delay: <%= index * 0.1 %>s">
                        <!-- Image Container with improved aesthetics -->
                        <div class="card-image-wrapper">
                            <img src="<%= item.image %>" alt="<%= item.title %>" class="case-image">
                            <!-- Soft Overlay for depth -->
                            <div class="image-overlay"></div>
                            <!-- Badge -->
                            <div class="badge <%= item.type === 'orphan' ? 'badge-gold' : 'badge-teal' %> case-badge">
                                <i class="fas <%= item.type === 'orphan' ? 'fa-child' : 'fa-users' %>"></i>
                                <%= item.type === 'orphan' ? __('cases_type_orphan') : __('cases_type_family') %>
                            </div>

                            <% if (item.isFieldVerified) { %>
                                <div class="verified-badge" title="<%= __('cases_verified_tooltip') %>">
                                    <i class="fas fa-check-circle"></i> <%= __('cases_verified_text') %>
                                </div>
                            <% } %>

                            <% if (item.isSatisfied) { %>
                                <div class="satisfied-overlay">
                                    <span class="badge" style="background: var(--secondary); color: white; border: none; padding: 10px 20px; font-weight: 900; box-shadow: 0 4px 15px rgba(212, 175, 55, 0.4);">
                                        <i class="fas fa-heart-circle-check"></i> <%= __('cases_satisfied_text') %>
                                    </span>
                                </div>
                            <% } %>
                        </div>
                        
                        <div class="card-body-content" style="position: relative;">
                            <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 8px;">
                                <h3 class="font-cairo case-title" style="margin: 0;">
                                    <%= item.title %>
                                </h3>
                                <% if (item.area) { %>
                                    <span style="font-size: 0.75rem; color: var(--secondary); font-weight: 700; background: rgba(212, 175, 55, 0.1); padding: 2px 8px; border-radius: 5px;">
                                        <i class="fas fa-location-dot"></i> <%= item.area %>
                                    </span>
                                <% } %>
                            </div>
                            <p class="case-description">
                                <%= item.description %>
                            </p>

                            <div class="card-footer-stats">
                                <div class="progress-track">
                                    <div class="progress-fill" style="width: <%= Math.min((item.raisedAmount / (item.targetAmount || 1) * 100), 100) %>%;"></div>
                                </div>
                                <div class="stats-labels">
                                    <span class="raised-text"><%= __('cases_raised_text') %> $<%= item.raisedAmount %></span>
                                    <span class="target-text"><%= __('cases_target_text') %> $<%= item.targetAmount || __('cases_target_open') %></span>
                                </div>

                                <a href="/cases/<%= item._id %>" class="btn-lux btn-lux-navy btn-sm btn-full-width">
                                    <%= __('cases_btn_details') %> <i class="fas fa-arrow-<%= langDir === 'rtl' ? 'left' : 'right' %>"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                <% }) %>
            <% } else { %>
                <div style="grid-column: 1 / -1; text-align: center; padding: 100px 5%; background: white; border-radius: 30px; border: 2px dashed #f1f5f9;" class="reveal-on-scroll">
                    <div style="width: 100px; height: 100px; background: #f8fafc; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 25px; color: #cbd5e1;">
                        <i class="fas fa-magnifying-glass-chart fa-3x"></i>
                    </div>
                    <h3 class="font-cairo" style="color: var(--primary); font-weight: 900;"><%= __('cases_empty_title') %></h3>
                    <p style="color: var(--text-muted); max-width: 400px; margin: 0 auto;"><%= __('cases_empty_desc') %></p>
                </div>
            <% } %>
        </div>
    </section>
</main>

<style>
    .filter-btn {
        padding: 10px 25px;
        font-size: 0.9rem;
        cursor: pointer;
        border-radius: 50px;
        border: 1px solid rgba(15, 23, 42, 0.1);
        background: white;
        color: var(--primary);
        font-weight: 700;
        transition: all 0.3s ease;
        font-family: 'Cairo', sans-serif;
    }

    .filter-btn:hover {
        background: #f8fafc;
        transform: translateY(-2px);
        border-color: var(--secondary);
    }

    .filter-btn.active {
        background: var(--primary);
        color: white;
        border-color: var(--primary);
        box-shadow: 0 10px 20px rgba(2, 6, 23, 0.15);
    }

    /* Card Improvements */
    .case-card {
        padding: 0 !important;
        transition: all 0.5s cubic-bezier(0.165, 0.84, 0.44, 1);
        overflow: hidden;
        display: flex;
        flex-direction: column;
        border: 1px solid rgba(0,0,0,0.05);
        background: #fff;
    }

    .card-image-wrapper {
        height: 280px;
        position: relative;
        overflow: hidden;
        background: #0f172a;
        margin: 12px;
        border-radius: 20px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
    }

    .case-image {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.8s cubic-bezier(0.165, 0.84, 0.44, 1);
        display: block;
    }

    .image-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(to top, rgba(2, 6, 23, 0.8) 0%, transparent 40%, rgba(2, 6, 23, 0.2) 100%);
        opacity: 0.6;
        transition: opacity 0.4s ease;
    }

    /* Shimmer effect for images */
    .card-image-wrapper::after {
        content: "";
        position: absolute;
        top: 0; right: 0; bottom: 0; left: 0;
        background: linear-gradient(to right, transparent, rgba(255,255,255,0.1), transparent);
        transform: translateX(-100%);
        transition: transform 0.6s ease;
    }

    .case-card:hover .card-image-wrapper::after {
        transform: translateX(100%);
    }

    .case-badge {
        position: absolute;
        top: 15px;
        right: 15px;
        z-index: 10;
        box-shadow: 0 8px 20px rgba(0,0,0,0.2);
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        border: 1px solid rgba(255,255,255,0.1);
    }

    .verified-badge {
        position: absolute;
        top: 15px;
        left: 15px;
        z-index: 10;
        background: #10b981;
        color: white;
        padding: 5px 12px;
        border-radius: 50px;
        font-size: 0.7rem;
        font-weight: 800;
        display: flex;
        align-items: center;
        gap: 5px;
        box-shadow: 0 4px 12px rgba(16, 185, 129, 0.3);
        border: 1px solid rgba(255,255,255,0.2);
    }

    .card-body-content {
        padding: 20px 30px 30px;
        flex-grow: 1;
        display: flex;
        flex-direction: column;
    }

    .case-title {
        font-size: 1.4rem;
        margin-bottom: 12px;
        font-weight: 850;
        color: var(--primary);
        transition: color 0.3s ease;
        line-height: 1.3;
    }

    .case-description {
        color: var(--text-muted);
        font-size: 0.95rem;
        margin-bottom: 25px;
        line-height: 1.8;
        height: 3.6em;
        overflow: hidden;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        line-clamp: 2;
        -webkit-box-orient: vertical;
    }

    .card-footer-stats {
        margin-top: auto;
    }

    .progress-track {
        margin-bottom: 15px;
        height: 10px;
        background: #f8fafc;
        border-radius: 20px;
        overflow: hidden;
        border: 1px solid #f1f5f9;
    }

    .stats-labels {
        display: flex;
        justify-content: space-between;
        font-size: 0.9rem;
        font-weight: 800;
        margin-bottom: 25px;
    }

    .raised-text { color: var(--secondary); }
    .target-text { color: #94a3b8; }

    .btn-full-width {
        width: 100%;
        justify-content: center;
        border-radius: 16px;
        padding: 14px 20px;
        font-weight: 800;
        box-shadow: 0 4px 12px rgba(2, 6, 23, 0.1);
    }

    .case-card:hover {
        transform: translateY(-12px);
        box-shadow: 0 40px 80px rgba(2, 6, 23, 0.12), 0 0 30px rgba(226, 176, 100, 0.08);
        border-color: var(--secondary);
    }

    .case-card:hover .case-image {
        transform: scale(1.12);
    }

    .case-card:hover .image-overlay {
        opacity: 0.4;
    }
    
    .case-card:hover .case-title {
        color: var(--secondary);
    }

    /* Animation for filtering */
    @keyframes fadeScale {
        from { opacity: 0; transform: translateY(20px) scale(0.98); }
        to { opacity: 1; transform: translateY(0) scale(1); }
    }

    .case-card.filtering {
        animation: fadeScale 0.5s cubic-bezier(0.165, 0.84, 0.44, 1) forwards;
    }
    .satisfied-overlay {
        position: absolute;
        inset: 0;
        background: rgba(255,255,255,0.7);
        backdrop-filter: blur(2px);
        z-index: 10;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 20px;
    }
</style>

<script>
    // Reveal on scroll logic
    const observerOptions = { threshold: 0.1 };
    const revealObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                entry.target.classList.add('active');
            }
        });
    }, observerOptions);

    document.querySelectorAll('.reveal-on-scroll').forEach(el => revealObserver.observe(el));

    // Filtering logic
    function filterCases(type) {
        const cards = document.querySelectorAll('.case-card');
        const buttons = document.querySelectorAll('.filter-btn');

        // Update active button
        buttons.forEach(btn => {
            if (btn.getAttribute('data-filter') === type) {
                btn.classList.add('active');
            } else {
                btn.classList.remove('active');
            }
        });

        // Filter cards
        cards.forEach(card => {
            const cardType = card.getAttribute('data-type');
            if (type === 'all' || cardType === type) {
                card.style.display = 'flex';
                card.classList.add('filtering');
                // Remove class after animation
                setTimeout(() => card.classList.remove('filtering'), 400);
            } else {
                card.style.display = 'none';
            }
        });
    }
</script>

<%- include('../../partials/footer-bottom') %>