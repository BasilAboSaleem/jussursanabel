<%- include('../../partials/header-top') %>

<main class="case-details-page">
    <!-- Hero -->
    <section class="hero-luxury case-hero" style="min-height: 55vh;">
        <div class="case-hero-bg" style="background-image: url('<%= foundCase.image %>');"></div>
        <div class="bg-mesh"></div>
        <div class="case-hero-overlay"></div>

        <div class="container case-hero-content">
            <div class="case-hero-grid">
                <div class="case-hero-info">
                    <nav class="reveal-on-scroll case-breadcrumb">
                        <a href="/cases" class="case-breadcrumb-link"><%= __('case_details_breadcrumb_list') %></a>
                        <span class="case-breadcrumb-sep">/</span>
                        <span class="case-breadcrumb-current"><%= foundCase.title %></span>
                    </nav>

                    <h1 class="hero-title-luxury reveal-on-scroll case-hero-title">
                        <%= foundCase.title %>
                    </h1>

                    <div class="reveal-on-scroll case-hero-badges">
                        <span class="badge badge-gold case-hero-badge">
                            <i class="fas fa-certificate"></i>
                            <%= foundCase.type === 'orphan' ? __('cases_type_orphan') : __('cases_type_family') %>
                        </span>
                        <span class="badge badge-navy case-hero-badge case-hero-badge-dark">
                            <i class="fas fa-location-dot"></i> <%= foundCase.location %>
                        </span>
                        <% if (foundCase.storyVideo) { %>
                        <a href="/stories?caseId=<%= foundCase._id %>" class="badge badge-gold case-hero-badge" style="background: linear-gradient(135deg, #ef4444, #b91c1c); color: white; border: none; text-decoration: none; animation: pulse 2s infinite;">
                            <i class="fas fa-play-circle"></i> شاهد القصة
                        </a>
                        <style>
                            @keyframes pulse {
                                0% { box-shadow: 0 0 0 0 rgba(239, 68, 68, 0.7); }
                                70% { box-shadow: 0 0 0 10px rgba(239, 68, 68, 0); }
                                100% { box-shadow: 0 0 0 0 rgba(239, 68, 68, 0); }
                            }
                        </style>
                        <% } %>
                    </div>
                </div>
                
                <div class="case-hero-action reveal-on-scroll" style="transition-delay: 0.4s;">
                    <div style="margin-bottom: 20px; font-family: 'Cairo', sans-serif;">
                        <span style="display: block; font-size: 0.85rem; color: rgba(255,255,255,0.7); font-weight: 700; margin-bottom: 5px;">كن جزءاً من الأمل</span>
                        <h3 style="color: #fff; font-weight: 800; font-size: 1.4rem; margin: 0;">
                            ساهم في التغيير الإيجابي <i class="fas fa-hand-holding-heart" style="color: var(--secondary);"></i>
                        </h3>
                    </div>
                    
                    <div class="quick-donate-stats">
                        <div class="stat">
                            <span class="label"><%= __('cases_raised_text') %></span>
                            <span class="value" style="color: var(--secondary);">$<%= foundCase.raisedAmount %></span>
                        </div>
                        <div class="stat text-start" dir="ltr">
                            <span class="label text-end" dir="rtl"><%= __('cases_target_text') %></span>
                            <span class="value">$<%= foundCase.targetAmount %></span>
                        </div>
                    </div>
                    
                    <% const heroProgress = Math.min((foundCase.raisedAmount / (foundCase.targetAmount || 1) * 100), 100); %>
                    <div class="case-hero-progress-track">
                        <div class="case-hero-progress-fill" style="width: <%= heroProgress %>%;"></div>
                    </div>
                    
                    <% if (foundCase.isSatisfied || foundCase.status === 'fully_sponsored') { %>
                        <div class="case-hero-satisfied-badge">
                            <div class="satisfied-glow"></div>
                            <i class="fas fa-heart-circle-check"></i>
                            <div class="satisfied-text">
                                <span class="satisfied-main"><%= __('case_details_satisfied_title') %></span>
                                <span class="satisfied-sub">بفضل الله وكرمه تم اكتفاء الحالة</span>
                            </div>
                        </div>
                    <% } else { %>
                        <a href="/donations/checkout?case=<%= foundCase._id %>&type=direct" class="hero-donate-btn w-100 d-flex justify-content-center align-items-center gap-2">
                            <i class="fas fa-donate"></i> تبرع الآن
                        </a>
                    <% } %>
                </div>
            </div>
        </div>

        <div class="case-hero-fade"></div>
    </section>

    <!-- Content -->
    <section class="container case-details-section">
        <div class="layout-split case-details-layout">

            <!-- Left: Case Detailed Information -->
            <div class="reveal-on-scroll case-details-main">
                <div class="case-main-stack">
                    <!-- Panel 1: Cinematic Story Spotlight -->
                    <div class="luxury-card case-card-main case-panel case-panel-story">
                        <div class="case-panel-rail"></div>
                        <div class="case-panel-head">
                            <div class="case-panel-kicker">
                                <span class="badge badge-gold"><i class="fas fa-sparkles"></i> <%= __('case_details_story_title') %></span>
                                <span class="badge badge-navy"><i class="fas fa-location-dot"></i> <%= foundCase.location %></span>
                            </div>
                        </div>

                        <div class="case-story-grid">
                            <div class="media-frame case-cover case-cover-compact">
                                <img src="<%= foundCase.image %>" alt="<%= foundCase.title %>">
                                <div class="media-overlay-brand"></div>
                            </div>

                            <div class="case-story-side">
                                <h3 class="font-cairo case-section-title case-section-title-story">
                                    <%= __('case_details_story_title') %>
                                </h3>
                                <div class="case-story">
                                    <%= foundCase.details.storyAr %>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Panel 2: Family Structure -->
                    <% if (foundCase.familyStructure) { %>
                    <div class="luxury-card case-panel case-panel-family">
                        <div class="case-panel-rail"></div>
                        <h3 class="font-cairo case-section-title case-section-title-sm">
                            <i class="fas fa-users-viewfinder"></i> <%= __('family_structure_title') %>
                        </h3>

                        <!-- Father -->
                        <% if (foundCase.familyStructure.father && foundCase.familyStructure.father.name) { %>
                        <div class="case-subblock">
                            <h5 class="case-subtitle"><i class="fas fa-user-tie"></i> <%= __('father_details') %></h5>
                            <div class="case-kv-grid">
                                <div><strong class="case-kv-key"><%= __('father_name') %>:</strong> <%= foundCase.familyStructure.father.name %></div>
                                <div><strong class="case-kv-key"><%= __('death_date') %>:</strong> <%= foundCase.familyStructure.father.deathDate ? new Date(foundCase.familyStructure.father.deathDate).toLocaleDateString() : '---' %></div>
                                <div class="case-kv-span"><strong class="case-kv-key"><%= __('death_reason') %>:</strong> <%= foundCase.familyStructure.father.deathReason || '---' %></div>
                            </div>
                        </div>
                        <% } %>

                        <!-- Mother -->
                        <% if (foundCase.familyStructure.mother) { %>
                        <div class="case-subblock">
                            <h5 class="case-subtitle"><i class="fas fa-person-breastfeeding"></i> <%= __('mother_details') %></h5>
                            <div class="case-kv-grid">
                                <% if (foundCase.familyStructure.mother.isDeceased) { %>
                                    <div><strong class="case-kv-key case-kv-key-danger"><%= __('death_date') %>:</strong> <%= foundCase.familyStructure.mother.deathDate ? new Date(foundCase.familyStructure.mother.deathDate).toLocaleDateString() : '---' %></div>
                                    <div><strong class="case-kv-key case-kv-key-danger"><%= __('death_reason') %>:</strong> <%= foundCase.familyStructure.mother.deathReason || '---' %></div>
                                <% } else { %>
                                    <div><strong class="case-kv-key"><%= __('mother_name') %>:</strong> <%= foundCase.familyStructure.mother.name || '---' %></div>
                                    <div><strong class="case-kv-key"><%= __('age') %>:</strong> <%= foundCase.familyStructure.mother.age || '---' %></div>
                                    <div><strong class="case-kv-key"><%= __('health_status') %>:</strong> <%= (foundCase.familyStructure.mother.healthStatus) ? __('health_' + foundCase.familyStructure.mother.healthStatus) : '---' %></div>
                                <% } %>
                            </div>
                        </div>
                        <% } %>

                        <!-- Guardian -->
                        <% if (foundCase.familyStructure.guardian) { %>
                        <div class="case-subblock">
                            <h5 class="case-subtitle"><i class="fas fa-user-shield"></i> <%= __('guardian_details') %></h5>
                            <div class="case-kv-grid">
                                <div><strong class="case-kv-key"><%= __('guardian_name') %>:</strong> <%= foundCase.familyStructure.guardian.name || '---' %></div>
                                <div><strong class="case-kv-key"><%= __('birth_date') %>:</strong> <%= foundCase.familyStructure.guardian.birthDate ? new Date(foundCase.familyStructure.guardian.birthDate).toLocaleDateString() : '---' %></div>
                                <div><strong class="case-kv-key"><%= __('family_size') %>:</strong> <%= foundCase.familyStructure.guardian.familySize || '---' %></div>
                                <div><strong class="case-kv-key"><%= __('health_status') %>:</strong> <%= foundCase.familyStructure.guardian.healthStatus ? __('health_' + foundCase.familyStructure.guardian.healthStatus) : '---' %></div>
                                <% 
                                    const housingMap = { tent: 'tent', rent: 'rent', damaged_home: 'damaged', host_family: 'host' }; 
                                    const hKey = foundCase.familyStructure.guardian.housingStatus ? housingMap[foundCase.familyStructure.guardian.housingStatus] : null; 
                                %>
                                <div><strong class="case-kv-key"><%= __('guardian_housing_status') %>:</strong> <%= hKey ? __('housing_' + hKey) : '---' %></div>
                                <div><strong class="case-kv-key"><%= __('guardian_residency_status') %>:</strong> <%= foundCase.familyStructure.guardian.residencyStatus ? __('residency_' + foundCase.familyStructure.guardian.residencyStatus) : '---' %></div>
                                
                                <!-- Privacy Info (Admins only) -->
                                <% if (typeof user !== 'undefined' && user && (user.role === 'admin' || user.role === 'super_admin')) { %>
                                    <div class="case-private-row">
                                        <div>
                                            <strong class="case-private-key"><i class="fas fa-id-card"></i> <%= __('common_id_number') %>:</strong>
                                            <span class="case-private-val"><%= foundCase.familyStructure.guardian.idNumber || '---' %></span>
                                        </div>
                                        <div>
                                            <strong class="case-private-key"><i class="fas fa-phone"></i> <%= __('common_phone') %>:</strong>
                                            <span class="case-private-val" dir="ltr"><%= foundCase.familyStructure.guardian.phone || '---' %></span>
                                        </div>
                                    </div>
                                <% } %>
                            </div>
                        </div>
                        <% } %>

                        <!-- Family Members / Orphans -->
                        <% if (foundCase.familyStructure.orphans && foundCase.familyStructure.orphans.length > 0) { %>
                        <div>
                            <h5 class="case-subtitle case-subtitle-divider">
                                <i class="fas fa-children"></i>
                                <%= foundCase.type === 'orphan' ? __('orphan_details') : __('family_members_details') %>
                                (<%= foundCase.familyStructure.orphans.length %>)
                            </h5>
                            <div class="case-orphans-list">
                                <% foundCase.familyStructure.orphans.forEach((orphan, i) => { %>
                                    <div class="case-orphan-row">
                                        <div class="case-orphan-name">
                                            <i class="fas fa-child"></i> <%= orphan.name %>
                                        </div>
                                        <div class="case-orphan-meta"><i class="far fa-calendar-alt text-muted"></i> <%= orphan.birthDate ? new Date(orphan.birthDate).toLocaleDateString() : '---' %></div>
                                        <div class="case-orphan-meta"><i class="fas fa-heart-pulse text-muted"></i> <%= orphan.healthStatus ? __('health_' + orphan.healthStatus) : '---' %></div>
                                        <div class="case-orphan-meta"><i class="fas fa-graduation-cap text-muted"></i> <%= orphan.educationStage ? __('edu_' + orphan.educationStage) : '---' %></div>
                                    </div>
                                <% }) %>
                            </div>
                        </div>
                        <% } %>

                    </div>
                    <% } %>

                    <!-- Panel 3: Verification Evidence -->
                    <% if (foundCase.gallery && foundCase.gallery.length > 0) { %>
                    <div class="luxury-card case-panel case-docs">
                        <div class="case-panel-rail"></div>
                        <h4 class="font-cairo case-block-title case-block-title-success">
                            <i class="fas fa-file-shield"></i> <%= __('case_details_docs_title') %>
                        </h4>
                        <div class="grid-3 case-docs-grid">
                            <% foundCase.gallery.forEach((img, idx) => { %>
                                <a href="<%= img %>" target="_blank" class="case-doc-item gallery-item-lux" aria-label="<%= __('case_details_docs_title') %>">
                                    <img src="<%= img %>" alt="" class="case-doc-img">
                                    <span class="case-doc-overlay"><i class="fas fa-eye"></i></span>
                                </a>
                            <% }) %>
                        </div>
                        <p class="case-docs-disclaimer"><%= __('case_details_docs_disclaimer') %></p>
                    </div>
                    <% } %>

                    <!-- Panel 4: Updates Timeline -->
                    <div class="luxury-card case-panel case-panel-updates">
                        <div class="case-panel-rail"></div>
                        <h4 class="font-cairo case-section-title case-section-title-sm">
                            <i class="fas fa-timeline"></i> <%= __('case_details_updates_title') %>
                        </h4>
                        
                        <% if (foundCase.updates && foundCase.updates.length > 0) { %>
                            <div class="timeline-lux">
                                <% foundCase.updates.forEach((update, idx) => { %>
                                    <div class="timeline-item">
                                        <div class="timeline-dot"></div>
                                        <div class="timeline-date"><%= new Date(update.createdAt).toLocaleDateString(lang === 'ar' ? 'ar-EG' : 'en-US') %></div>
                                        <div class="timeline-content">
                                            <div class="case-update-head">
                                                <h5 class="case-update-title">
                                                    <i class="fa-solid fa-square-check"></i> <%= update.title %>
                                                </h5>
                                                <% if (update.postedBy === 'family') { %>
                                                    <span class="case-update-pill case-update-pill-family"><i class="fas fa-home"></i> <%= __('case_details_update_family') %></span>
                                                <% } else { %>
                                                    <span class="case-update-pill case-update-pill-admin"><i class="fas fa-shield-check"></i> <%= __('case_details_update_admin') %></span>
                                                <% } %>
                                            </div>
                                            <p class="case-update-content"><%= update.content %></p>
                                            
                                            <% if (update.images && update.images.length > 0) { %>
                                                <div class="case-attachments">
                                                    <% update.images.forEach(img => { 
                                                        const ext = img.split('.').pop().toLowerCase();
                                                        const isVideo = ['mp4', 'webm', 'ogg'].includes(ext);
                                                        const isDoc = ['pdf', 'doc', 'docx', 'txt'].includes(ext);
                                                        const isImage = ['jpg', 'jpeg', 'png', 'gif', 'webp'].includes(ext);
                                                    %>
                                                        <a href="<%= img %>" target="_blank" class="attachment-preview" aria-label="attachment">
                                                            <% if (isImage) { %>
                                                                <img src="<%= img %>" alt="" class="attachment-img">
                                                                <span class="attachment-hover"><i class="fas fa-expand-alt"></i></span>
                                                            <% } else if (isVideo) { %>
                                                                <i class="fas fa-file-video fa-2x attachment-ico attachment-ico-video"></i>
                                                                <span class="attachment-tag attachment-tag-video">فيديو</span>
                                                            <% } else if (isDoc) { %>
                                                                <i class="fas <%= ext === 'pdf' ? 'fa-file-pdf' : 'fa-file-word' %> fa-2x attachment-ico <%= ext === 'pdf' ? 'attachment-ico-pdf' : 'attachment-ico-doc' %>"></i>
                                                                <span class="attachment-tag <%= ext === 'pdf' ? 'attachment-tag-pdf' : 'attachment-tag-doc' %>">ملف</span>
                                                            <% } else { %>
                                                                <i class="fas fa-file fa-2x attachment-ico attachment-ico-file"></i>
                                                            <% } %>
                                                        </a>
                                                    <% }) %>
                                                </div>
                                            <% } %>
                                        </div>
                                    </div>
                                <% }) %>
                            </div>
                        <% } else { %>
                            <div class="case-empty">
                                <i class="fas fa-hourglass-start fa-2x"></i>
                                <p><%= __('case_details_updates_empty') %></p>
                            </div>
                        <% } %>
                    </div>
                </div> <!-- /case-main-stack -->
            </div>

            <!-- Right: Donation Sidebar -->
            <aside class="sticky-sidebar reveal-on-scroll case-sidebar">
                <div class="luxury-card case-card-side">
                    <div class="case-side-head">
                        <div class="case-side-icon">
                            <i class="fas fa-hand-holding-heart fa-3x"></i>
                        </div>
                        <h3 class="font-cairo case-side-title"><%= __('case_details_cta_title') %></h3>
                        <p class="case-side-desc"><%= __('case_details_cta_desc') %></p>
                    </div>

                    <div class="case-side-progress">
                        <div class="case-side-progress-top">
                            <span class="case-side-raised"><%= __('cases_raised_text') %> $<%= foundCase.raisedAmount %></span>
                            <span class="case-side-target"><%= __('cases_target_text') %>: $<%= foundCase.targetAmount %></span>
                        </div>
                        <div class="progress-track case-progress-track">
                            <% const progressPercent = Math.min((foundCase.raisedAmount / (foundCase.targetAmount || 1) * 100), 100); %>
                            <div class="progress-fill" data-progress="<%= progressPercent %>"></div>
                            
                            <!-- Milestone Markers -->
                            <div class="case-progress-mark" style="left: 25%;"></div>
                            <div class="case-progress-mark" style="left: 50%;"></div>
                            <div class="case-progress-mark" style="left: 75%;"></div>
                            
                            <% if (progressPercent >= 25) { %>
                                <div title="وصلنا لـ 25%" class="case-progress-award" style="left: 25%;"><i class="fas fa-star"></i></div>
                            <% } %>
                            <% if (progressPercent >= 50) { %>
                                <div title="وصلنا لـ 50%" class="case-progress-award" style="left: 50%;"><i class="fas fa-medal"></i></div>
                            <% } %>
                            <% if (progressPercent >= 75) { %>
                                <div title="وصلنا لـ 75%" class="case-progress-award" style="left: 75%;"><i class="fas fa-crown"></i></div>
                            <% } %>
                        </div>
                    </div>

                    <!-- Impact Metrics (Phase 2) -->
                    <div class="case-side-box case-impact">
                        <h4 class="font-cairo case-side-box-title">
                            <i class="fas fa-chart-line"></i> <%= __('case_details_impact_title') %>
                        </h4>
                        <div class="case-impact-list">
                            <% if (foundCase.impactMetrics && foundCase.impactMetrics.length > 0) { %>
                                <% foundCase.impactMetrics.forEach(metric => { %>
                                    <div class="case-impact-row">
                                        <span class="case-impact-amount">$<%= metric.amount %></span>
                                        <span class="case-impact-desc"><%= metric.descriptionAr %></span>
                                    </div>
                                <% }) %>
                            <% } else { %>
                                <!-- Default metrics if none defined -->
                                <div class="case-impact-row"><span class="case-impact-amount">$20</span><span class="case-impact-desc"><%= __('case_details_impact_edu') %></span></div>
                                <div class="case-impact-row"><span class="case-impact-amount">$50</span><span class="case-impact-desc"><%= __('case_details_impact_food') %></span></div>
                                <div class="case-impact-row case-impact-row-last"><span class="case-impact-amount">$100</span><span class="case-impact-desc"><%= __('case_details_impact_health') %></span></div>
                            <% } %>
                        </div>
                    </div>

                    <div class="case-side-box case-sponsorship">
                        <h4 class="font-cairo case-sponsorship-title">
                            <i class="fas fa-crown"></i> <%= __('case_details_sponsorship_title') %>
                        </h4>
                        <p class="case-sponsorship-price">
                            $<%= foundCase.monthlySponsorshipAmount %>
                            <span class="case-sponsorship-period"><%= __('case_details_sponsorship_period') %></span>
                        </p>
                    </div>

                    <% 
                        const isSponsored = foundCase.sponsorshipExpiryDate && foundCase.sponsorshipExpiryDate > new Date();
                    %>

                    <% if (foundCase.isSatisfied || foundCase.status === 'fully_sponsored') { %>
                        <div class="case-side-box case-satisfied-premium">
                            <div class="case-satisfied-icon"><i class="fas fa-heart-circle-check fa-3x"></i></div>
                            <h4 class="font-cairo"><%= __('case_details_satisfied_title') %></h4>
                            <p><%= __('case_details_satisfied_desc') %></p>
                        </div>
                    <% } else { %>
                        <% if (isSponsored) { %>
                            <div class="case-sponsored-note">
                                <i class="fas fa-check-circle"></i>
                                <span>
                                    <%= __('case_details_sponsored_until') %> <%= new Date(foundCase.sponsorshipExpiryDate).toLocaleDateString(lang === 'ar' ? 'ar-EG' : 'en-US') %>
                                </span>
                            </div>
                        <% } %>

                        <div class="case-side-actions">
                            <a href="/donations/checkout?case=<%= foundCase._id %>&type=direct" class="btn-lux btn-lux-primary case-side-btn">
                                <i class="fas fa-donate"></i> <%= __('case_details_btn_direct') %>
                            </a>

                            <% if (isSponsored) { %>
                                <button class="btn-lux btn-lux-outline case-side-btn case-side-btn-disabled" disabled title="<%= __('case_details_btn_sponsored_done') %>">
                                    <i class="fas fa-lock"></i> <%= __('case_details_btn_sponsored_done') %>
                                </button>
                            <% } else { %>
                                <a href="/donations/checkout?case=<%= foundCase._id %>&type=monthly" class="btn-lux btn-lux-navy case-side-btn">
                                    <i class="fas fa-arrows-rotate"></i> <%= __('case_details_btn_monthly') %>
                                </a>
                            <% } %>
                        </div>
                    <% } %>

                    <div class="case-side-actions" style="margin-top: 0;">
                        <% if (typeof user !== 'undefined' && user && user.role === 'donor') { %>
                                <div class="case-divider">
                                    <span><%= __('case_details_contact_divider') %></span>
                                </div>
                                
                                <% if (chatRequest) { %>
                                    <% if (chatRequest.status === 'pending') { %>
                                        <div class="case-chat case-chat-pending">
                                            <i class="fas fa-hourglass-half"></i>
                                            <p class="case-chat-title"><%= __('case_details_chat_pending_title') %></p>
                                            <p class="case-chat-desc"><%= __('case_details_chat_pending_desc') %></p>
                                            <p class="case-chat-help"><%= __('case_details_chat_pending_delay') %> <a href="/support"><%= __('case_details_chat_support') %></a>.</p>
                                        </div>
                                    <% } else if (chatRequest.status === 'approved') { %>
                                        <a href="/messages/<%= foundCase.guardian._id %>" class="btn-lux btn-lux-primary case-side-btn" style="background: #10b981;">
                                            <i class="fas fa-comments"></i> <%= __('case_details_chat_approved') %>
                                        </a>
                                    <% } else if (chatRequest.status === 'rejected') { %>
                                        <div class="case-chat-rejected">
                                            <p><%= __('case_details_chat_rejected') %></p>
                                            <button class="btn-lux btn-lux-outline case-side-btn" style="border-color: var(--accent); color: var(--accent);" onclick="requestCommunication('<%= foundCase._id %>')">
                                                <i class="fas fa-redo"></i> <%= __('case_details_chat_retry') %>
                                            </button>
                                        </div>
                                    <% } %>
                                <% } else { %>
                                    <button class="btn-lux btn-lux-outline case-side-btn" style="border-color: var(--accent); color: var(--accent);" onclick="requestCommunication('<%= foundCase._id %>')">
                                        <i class="fas fa-comments"></i> <%= __('case_details_chat_request') %>
                                    </button>
                                <% } %>
                            <% } %>
                        </div>

                        <!-- Social Sharing Section -->
                        <div class="case-share">
                            <h4 class="font-cairo case-share-title"><%= __('case_details_share_title') %></h4>
                            <div class="case-share-grid">
                                <a href="https://wa.me/?text=<%= encodeURIComponent('ساهم معنا في دعم حالة ' + foundCase.title + ' عبر منصة جسور السنابل') %>" target="_blank" class="case-share-btn case-share-whatsapp" aria-label="whatsapp">
                                    <i class="fab fa-whatsapp"></i>
                                </a>
                                <a href="https://www.facebook.com/sharer/sharer.php?u=<%= typeof fullUrl !== 'undefined' ? encodeURIComponent(fullUrl) : '' %>" target="_blank" class="case-share-btn case-share-facebook" aria-label="facebook">
                                    <i class="fab fa-facebook-f"></i>
                                </a>
                                <a href="https://www.linkedin.com/shareArticle?mini=true&url=<%= typeof fullUrl !== 'undefined' ? encodeURIComponent(fullUrl) : '' %>" target="_blank" class="case-share-btn case-share-linkedin" aria-label="linkedin">
                                    <i class="fab fa-linkedin-in"></i>
                                </a>
                                <button onclick="copyCaseLink()" class="case-share-btn case-share-copy" aria-label="copy link">
                                    <i class="fas fa-link"></i>
                                </button>
                            </div>
                        </div>

                        <!-- Follow System (Phase 2) -->
                        <% if (typeof user !== 'undefined' && user) { %>
                        <div class="case-follow">
                            <% const isFollowing = foundCase.followers && foundCase.followers.includes(user._id); %>
                            <button id="followBtn" onclick="toggleFollow('<%= foundCase._id %>')" class="btn-lux <%= isFollowing ? 'btn-lux-outline' : 'btn-lux-navy' %> case-follow-btn">
                                <i class="fas <%= isFollowing ? 'fa-bell-slash' : 'fa-bell' %>"></i>
                                <span id="followText"><%= isFollowing ? __('case_details_unfollow') : __('case_details_follow') %></span>
                            </button>
                            <p class="case-follow-desc"><%= __('case_details_follow_desc') %></p>
                        </div>
                        <% } %>

                        <!-- Team Fundraising Section (Phase 3) -->
                        <div class="case-teams">
                            <div class="case-teams-head">
                                <h4 class="font-cairo case-teams-title">
                                    <i class="fas fa-users-rays"></i> <%= __('case_details_teams_title') %>
                                </h4>
                                <% if (typeof user !== 'undefined' && user) { %>
                                    <button onclick="openTeamModal()" class="btn-lux btn-sm btn-lux-outline case-teams-create"><i class="fas fa-plus"></i> <%= __('case_details_teams_create') %></button>
                                <% } %>
                            </div>

                            <% if (typeof teams !== 'undefined' && teams && teams.length > 0) { %>
                                <div class="case-teams-grid">
                                    <% teams.forEach(team => { %>
                                        <div class="glass-panel case-team-card">
                                            <div class="case-team-name"><%= team.name %></div>
                                            <div class="case-team-total">$<%= team.totalRaised %></div>
                                            <div class="case-team-meta"><%= team.donorCount %> <%= __('case_details_teams_donors') %></div>
                                            <a href="/donations/checkout?case=<%= foundCase._id %>&type=direct&team=<%= team._id %>" class="btn-lux btn-sm btn-lux-primary case-team-btn"><%= __('case_details_teams_support') %></a>
                                        </div>
                                    <% }) %>
                                </div>
                            <% } else { %>
                                <div class="case-empty case-empty-sm">
                                    <p><%= __('case_details_teams_empty') %></p>
                                </div>
                            <% } %>
                        </div>

                        <!-- Donor Feed Section -->
                        <% if (typeof recentDonors !== 'undefined' && recentDonors && recentDonors.length > 0) { %>
                        <div class="case-donors">
                            <h4 class="font-cairo case-donors-title">
                                <i class="fas fa-users"></i> <%= __('case_details_donors_title') %> (<%= recentDonors.length %>)
                            </h4>
                            
                            <div class="case-donors-list">
                                <% recentDonors.forEach(transaction => { %>
                                    <div class="case-donor-row">
                                        <div class="case-donor-avatar">
                                            <% if (transaction.isAnonymous || !transaction.donor) { %>
                                                <i class="fas fa-user-secret"></i>
                                            <% } else { %>
                                                <img src="<%= transaction.donor.avatar || '/assets/images/placeholder-avatar.jpg' %>" alt="">
                                            <% } %>
                                        </div>
                                        <div class="case-donor-body">
                                            <div class="case-donor-top">
                                                <span class="case-donor-name">
                                                    <%= (transaction.isAnonymous || !transaction.donor) ? __('case_details_donor_anonymous') : transaction.donor.name %>
                                                </span>
                                                <strong class="case-donor-amount">$<%= transaction.amount %></strong>
                                            </div>
                                            <% if (transaction.encouragementMessage) { %>
                                                <div class="case-donor-msg">
                                                    <i class="fas fa-quote-right"></i>
                                                    "<%= transaction.encouragementMessage %>"
                                                </div>
                                            <% } %>
                                            <div class="case-donor-date">
                                                <i class="far fa-clock"></i> <%= new Date(transaction.createdAt).toLocaleDateString(lang === 'ar' ? 'ar-EG' : 'en-US') %>
                                            </div>
                                        </div>
                                    </div>
                                <% }); %>
                            </div>
                        </div>
                        <% } %>
                    <% if (typeof user !== 'undefined' && user && (user.role === 'admin' || user.role === 'super_admin')) { %>
                        <!-- Admin Control Center -->
                        <div class="case-admin">
                            <h4 class="font-cairo case-admin-title">
                                <i class="fas fa-user-shield"></i> <%= __('case_details_admin_title') %>
                            </h4>
                            
                            <form action="/admin/cases/<%= foundCase._id %>/toggle-satisfaction" method="POST">
                                <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
                                <button type="submit" class="btn-lux <%= foundCase.isSatisfied ? 'btn-lux-primary' : 'btn-lux-outline' %> case-admin-btn" style="border-color: #991b1b; color: #991b1b;">
                                    <i class="fas <%= foundCase.isSatisfied ? 'fa-hand-holding-heart' : 'fa-check-double' %>"></i>
                                    <%= foundCase.isSatisfied ? __('case_details_admin_resume') : __('case_details_admin_stop') %>
                                </button>
                            </form>
                            
                            <p class="case-admin-note">
                                <i class="fas fa-circle-info"></i> <%= __('case_details_admin_disclaimer') %>
                            </p>
                        </div>
                    <% } %>

                    <div class="case-trust">
                        <div class="case-trust-ico"><i class="fas fa-shield-check"></i></div>
                        <span class="case-trust-text"><%= __('case_details_trust_disclaimer') %></span>
                    </div>
                </div>
            </aside>

        </div>
    </section>
</main>

<script>
    // Reveal on scroll logic
    const observerOptions = { threshold: 0.1 };
    const revealObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                entry.target.classList.add('active');
            }
        });
    }, observerOptions);

    document.querySelectorAll('.reveal-on-scroll').forEach(el => revealObserver.observe(el));

    // Avoid EJS-in-CSS lint issues by applying widths in JS
    document.querySelectorAll('.progress-fill[data-progress]').forEach((el) => {
        const value = Number(el.dataset.progress);
        if (!Number.isNaN(value)) el.style.width = `${Math.min(Math.max(value, 0), 100)}%`;
    });

    function copyCaseLink() {
        const url = window.location.href;
        navigator.clipboard.writeText(url).then(() => {
            alert("<%= __('case_details_copy_success') %>");
        }).catch(err => {
            console.error('Failed to copy: ', err);
        });
    }

    async function requestCommunication(caseId) {
        try {
            const response = await fetch('/messages/request-chat', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ 
                    caseId: caseId,
                    _csrf: '<%= typeof csrfToken !== "undefined" ? csrfToken : "" %>'
                })
            });
            
            const data = await response.json();
            
            if (data.success) {
                alert(data.message);
                location.reload();
            } else {
                alert(data.message || 'حدث خطأ أثناء إرسال الطلب.');
            }
        } catch (err) {
            console.error(err);
            alert('حدث خطأ في الاتصال بالسيرفر.');
        }
    }

    async function toggleFollow(caseId) {
        const btn = document.getElementById('followBtn');
        const text = document.getElementById('followText');
        const icon = btn.querySelector('i');
        
        try {
            const response = await fetch(`/cases/${caseId}/follow`, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'x-csrf-token': '<%= typeof csrfToken !== "undefined" ? csrfToken : "" %>'
                }
            });
            
            const data = await response.json();
            if (data.success) {
                if (data.isFollowing) {
                    btn.classList.remove('btn-lux-navy');
                    btn.classList.add('btn-lux-outline');
                    icon.classList.remove('fa-bell');
                    icon.classList.add('fa-bell-slash');
                    text.innerText = 'إلغاء المتابعة';
                } else {
                    btn.classList.remove('btn-lux-outline');
                    btn.classList.add('btn-lux-navy');
                    icon.classList.remove('fa-bell-slash');
                    icon.classList.add('fa-bell');
                    text.innerText = 'تابع هذه الحالة';
                }
            } else {
                alert(data.message || 'حدث خطأ ما');
            }
        } catch (err) {
            console.error(err);
            alert('فشل الاتصال بالسيرفر');
        }
    }

    /* Phase 3: Team Fundraising Modals */
    function openTeamModal() {
        document.getElementById('teamModal').style.display = 'flex';
    }
    
    function closeTeamModal() {
        document.getElementById('teamModal').style.display = 'none';
    }

    async function handleCreateTeam(event) {
        event.preventDefault();
        const name = document.getElementById('teamNameInput').value;
        const description = document.getElementById('teamDescInput').value;
        
        try {
            const response = await fetch('/cases/<%= foundCase._id %>/teams', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'x-csrf-token': '<%= typeof csrfToken !== "undefined" ? csrfToken : "" %>'
                },
                body: JSON.stringify({ name, description })
            });
            
            const data = await response.json();
            if (data.success) {
                alert('تهانينا! تم إنشاء فريقك بنجاح. سنقوم بتحديث الصفحة الآن.');
                window.location.reload();
            } else {
                alert(data.message || 'حدث خطأ ما');
            }
        } catch (err) {
            console.error(err);
            alert('فشل الاتصال بالسيرفر');
        }
    }
</script>

<!-- Team Modal -->
<div id="teamModal" class="modal-overlay" style="display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.7); backdrop-filter: blur(8px); z-index: 2000; align-items: center; justify-content: center;">
    <div class="luxury-card" style="width: 100%; max-width: 500px; padding: 35px; background: white;">
        <h3 class="font-cairo" style="margin-bottom: 20px; border-bottom: 1px solid #eee; padding-bottom: 15px; color: var(--primary);">
            <i class="fas fa-users-rays" style="color: var(--secondary);"></i> <%= __('case_details_modal_title') %>
        </h3>
        <p style="font-size: 0.85rem; color: var(--text-muted); margin-bottom: 25px;"><%= __('case_details_modal_desc') %></p>
        
        <form onsubmit="handleCreateTeam(event)">
            <div class="form-group" style="margin-bottom: 20px;">
                <label class="form-label-luxury"><%= __('case_details_modal_label_name') %></label>
                <input type="text" id="teamNameInput" class="form-input" placeholder="<%= __('case_details_modal_label_name') %>" required>
            </div>
            <div class="form-group" style="margin-bottom: 25px;">
                <label class="form-label-luxury"><%= __('case_details_modal_label_prompt') %></label>
                <textarea id="teamDescInput" class="form-input" rows="3" placeholder="<%= __('case_details_modal_placeholder_prompt') %>"></textarea>
            </div>
            
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px;">
                <button type="submit" class="btn-lux btn-lux-primary" style="justify-content: center; padding: 12px;"><%= __('case_details_modal_btn_create') %></button>
                <button type="button" onclick="closeTeamModal()" class="btn-lux btn-lux-outline" style="justify-content: center; padding: 12px; color: #666;"><%= __('case_details_modal_btn_cancel') %></button>
            </div>
        </form>
    </div>
</div>

<style>
