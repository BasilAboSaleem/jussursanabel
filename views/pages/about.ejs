                </div>
                <!-- Decorative element -->
                <div style="posi                <div class="luxury-card reveal-on-scroll" style="background: white; border: 1px solid #e2e8f0; padding: 50px; text-align: center;">
                    <div style="width: 80px; height: 80px; background: #fffcf0; color: var(--secondary); border-radius: 20px; display: flex; align-items: center; justify-content: center; font-size: 2.5rem; margin: 0 auto 30px; box-shadow: var(--shadow-sm);">
