                <a href="/contact" class="btn-lux btn-lux-outline btn-lg" style="padding: 18px 45px; border-color: rgba(255,255,255,0.4); color: white;">
                    <i class="fas fa-envelope"></i> <%= __('about_cta_btn_contact') %>
                </a>
            </div>
        </div>
    </section>
</main>

<script>
    // Reveal on scroll logic
    const observerOptions = { threshold: 0.1 };
    const revealObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                entry.target.classList.add('active');
            }
        });
    }, observerOptions);

    document.querySelectorAll('.reveal-on-scroll').forEach(el => revealObserver.observe(el));
</script>

<%- include('../partials/footer-bottom') %>
