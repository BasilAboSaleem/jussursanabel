        </div>
    </section>

    <!-- Final Call to Action -->
    <section class="section-luxury" style="background: var(--grad-navy); color: white; text-align: center; padding: 100px 5%; position: relative;">
        <div style="position: absolute; inset: 0; background: radial-gradient(circle at center, rgba(16, 185, 129, 0.1) 0%, transparent 70%);"></div>
        <div class="container reveal-on-scroll" style="position: relative; z-index: 2;">
            <h2 class="font-cairo" style="font-size: clamp(2rem, 4vw, 3rem); font-weight: 900; margin-bottom: 25px;"><%= __('about_cta_title') %></h2>
