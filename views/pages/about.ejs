            <div class="reveal-on-scroll" style="text-align: center; padding: 20px; transition-delay: 0.1s;">
                <div style="font-size: 3rem; color: var(--accent); margin-bottom: 20px; opacity: 0.8;"><i class="fas fa-book-open"></i></div>
                <h4 class="font-cairo" style="font-weight: 800; margin-bottom: 15px;"><%= __('about_value_2_title') %></h4>
                <p style="font-size: 0.95rem; color: var(--text-muted);"><%= __('about_value_2_desc') %></p>
            </div>
            <div class="reveal-on-scroll" style="text-align: center; padding: 20px; transition-delay: 0.2s;">
