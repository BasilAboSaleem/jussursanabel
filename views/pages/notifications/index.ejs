<% if (user.role === 'super_admin' || user.role === 'admin') { %>
    <%- include('../../partials/admin-layout-top') %>
<% } else if (user.role === 'donor') { %>
    <%- include('../../partials/donor-layout-top') %>
<% } else { %>
    <%- include('../../partials/family-layout-top') %>
<% } %>

<div class="container py-5">
    <div class="row mb-5 animate__animated animate__fadeIn">
        <div class="col-12 text-start">
            <h2 class="font-cairo fw-bold text-primary" style="font-size: 2.2rem; margin-bottom: 10px;">مركز الإشعارات</h2>
            <p style="color: #64748b; font-size: 1.1rem;">تتبع كافة التنبيهات، التحديثات، والتواصل الخاص بحسابك في مكان واحد</p>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-9 mx-auto">
            <div class="glass-card shadow-premium" style="background: white; border-radius: 28px; overflow: hidden; border: 1px solid #e2e8f0;">
                <div class="p-4 border-bottom d-flex justify-content-between align-items-center" style="background: #f8fafc;">
                    <span class="font-cairo fw-bold" style="color: var(--primary);"><i class="fa-solid fa-list-ul me-2"></i> سجل التنبيهات الواردة</span>
                    <span class="badge badge-soft-primary"><%= notifications.length %> إشعار</span>
                </div>
                
                <div id="notifPageList">
                    <% if (!notifications || notifications.length === 0) { %>
                        <div class="text-center py-5" style="color:#9ca3af; font-family:'Cairo',sans-serif;">
                            <i class="fa-solid fa-bell-slash" style="font-size:4rem; margin-bottom:20px; display:block; opacity:0.2;"></i>
                            <h5 class="fw-bold">صندوق الإشعارات فارغ حالياً</h5>
                            <p class="small">سنقوم بتنبيهك عند حدوث أي مستجدات تتعلق بنشاطك</p>
                        </div>
                    <% } else { %>
                        <% notifications.forEach(n => { %>
                            <div class="notif-row-lux <%= !n.isReadByMe ? 'unread' : '' %>" 
                                 onclick="markFullRead('<%= n._id %>', '<%= n.link || '#' %>')">
                                
                                <div class="notif-item-icon <%= n.type || 'info' %>">
                                    <i class="fa-solid <%= n.type === 'success' ? 'fa-circle-check' : (n.type === 'danger' ? 'fa-triangle-exclamation' : (n.type === 'warning' ? 'fa-circle-exclamation' : 'fa-circle-info')) %>"></i>
                                </div>

                                <div style="flex:1; min-width: 0;">
                                    <div style="display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:6px; gap: 15px;">
                                        <h5 class="font-cairo fw-bold m-0" style="color: var(--primary); font-size:1.05rem;"><%= n.title %></h5>
                                        <div style="display: flex; flex-direction: column; align-items: flex-end; gap: 4px;">
                                            <span style="color:#94a3b8; font-size:0.7rem; white-space:nowrap;">
                                                <i class="fa-regular fa-clock me-1"></i> <%= new Date(n.createdAt).toLocaleDateString('ar-EG', {month:'long', day:'numeric', hour:'2-digit', minute:'2-digit'}) %>
                                            </span>
                                        </div>
                                    </div>
                                    <p class="m-0" style="color:#475569; font-size:0.95rem; line-height:1.7;"><%= n.message %></p>
                                    
                                    <div class="mt-3 d-flex align-items-center justify-content-between">
                                        <div class="d-flex align-items-center gap-2">
                                            <img src="<%= (n.sender && n.sender.avatar) || '/assets/images/placeholder-avatar.jpg' %>" style="width: 22px; height: 22px; border-radius: 50%; border: 1px solid #e2e8f0;">
                                            <span style="font-size:0.75rem; color:#64748b; font-weight: 600;">بواسطة: <%= n.sender ? n.sender.name : 'النظام' %></span>
                                        </div>
                                        <% if (!n.isReadByMe) { %>
                                            <span class="badge bg-primary" style="font-size: 0.6rem; padding: 4px 8px;">جديد</span>
                                        <% } %>
                                    </div>
                                </div>
                            </div>
                        <% }) %>
                    <% } %>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    // Notifications are rendered server-side, just handle mark-as-read
    window.markFullRead = async (id, link) => {
        try {
            await fetch(`/notifications/${id}/read`, { 
                method: 'POST',
                headers: { 'X-CSRF-Token': '<%= locals.csrfToken || "" %>' }
            });
            if (link && link !== '#') {
                window.location.href = link;
            } else {
                // Mark row as read visually
                event.currentTarget.classList.remove('unread');
                window.location.reload();
            }
        } catch (err) { console.error(err); }
    };
</script>

<style>
    .notif-row-lux { 
        padding: 25px 30px; 
        border-bottom: 1px solid #f1f5f9; 
        cursor: pointer; 
        transition: all 0.3s ease; 
        display: flex; 
        align-items: flex-start; 
        gap: 20px; 
    }
    .notif-row-lux:hover { background-color: #f8fafc; transform: translateX(-5px); }
    .notif-row-lux.unread { background-color: rgba(30, 64, 175, 0.02); border-right: 5px solid var(--primary); }
    
    .notif-item-icon {
        width: 52px; height: 52px; border-radius: 16px;
        flex-shrink: 0; display: flex; align-items: center; justify-content: center;
        font-size: 1.4rem;
    }
    .notif-item-icon.info { background: #eff6ff; color: #3b82f6; }
    .notif-item-icon.success { background: #f0fdf4; color: #16a34a; }
    .notif-item-icon.danger { background: #fef2f2; color: #ef4444; }
    .notif-item-icon.warning { background: #fffbeb; color: #d97706; }

    .shadow-premium { box-shadow: 0 20px 50px rgba(0,0,0,0.06) !important; }
</style>

<% if (user.role === 'super_admin' || user.role === 'admin') { %>
    <%- include('../../partials/admin-layout-bottom') %>
<% } else if (user.role === 'donor') { %>
    <%- include('../../partials/donor-layout-bottom') %>
<% } else { %>
    <%- include('../../partials/family-layout-bottom') %>
<% } %>
