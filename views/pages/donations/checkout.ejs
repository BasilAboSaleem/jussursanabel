<%- include('../../partials/header-top') %>

<main class="checkout-page">
<div class="container checkout-wrap">
    <section class="checkout-hero luxury-card">
        <div class="checkout-hero-bg"></div>
        <div class="checkout-hero-content">
            <span class="section-badge"><i class="fas fa-credit-card"></i> بوابة العطاء الآمنة</span>
            <h2 class="section-title-luxury checkout-title">تفاصيل مساهمتك الإنسانية</h2>
            <p class="section-subtitle-luxury checkout-subtitle">عطاؤك يصنع فرقاً حقيقياً. اختر الطريقة التي تفضل بها دعم هذه الحالة.</p>
            <div class="checkout-stripe-ready">
                <i class="fab fa-stripe-s"></i>
                <span>واجهة الدفع مهيّأة بصريًا للربط مع Stripe لاحقًا.</span>
            </div>
        </div>
    </section>

    <div class="luxury-grid-checkout">
        <!-- Left Column: Settings -->
        <div class="luxury-card glass-panel checkout-form-card">
            <form action="/donations/process" method="POST" id="payment-form">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <input type="hidden" name="caseId" value="<%= foundCase._id %>">
                <input type="hidden" name="amount" id="finalAmount" value="<%= amount %>">
                <input type="hidden" name="type" id="finalType" value="<%= type %>">
                <input type="hidden" name="teamId" value="<%= typeof teamId !== 'undefined' ? teamId : '' %>">

                <!-- Donation Type Toggle -->
                <div class="checkout-block">
                    <label class="form-label-luxury">نوع المساهمة</label>
                    <div class="type-selector-luxury">
                        <div class="type-option <%= type === 'monthly' ? 'active' : '' %>" id="typeMonthly">
                            <i class="fas fa-calendar-check"></i>
                            <div>
                                <span class="type-title">كفالة شهرية</span>
                                <span class="type-desc">دعم مستمر كل شهر</span>
                            </div>
                        </div>
                        <div class="type-option <%= type !== 'monthly' ? 'active' : '' %>" id="typeDirect">
                            <i class="fas fa-bolt"></i>
                            <div>
                                <span class="type-title">تبرع لمرة واحدة</span>
                                <span class="type-desc">دعم فوري الآن</span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Amount Presets & Custom -->
                <div class="checkout-block">
                    <label class="form-label-luxury">حدد مبلغ المساهمة ($)</label>
                    <div class="amount-presets">
                        <div class="preset-btn preset-amount" data-amount="10">$10</div>
                        <div class="preset-btn preset-amount <%= amount == 50 ? 'active' : '' %>" data-amount="50">$50</div>
                        <div class="preset-btn preset-amount <%= amount == 100 ? 'active' : '' %>" data-amount="100">$100</div>
                        <div class="preset-btn preset-custom">آخر</div>
                    </div>
                    <div class="custom-amount-group" id="customAmountGroup">
                        <input type="number" id="customAmountInput" class="form-input" placeholder="أدخل مبلغاً مخصصاً..." value="<%= amount %>">
                        <span class="currency-label">$</span>
                    </div>
                </div>

                <!-- Operation Fee Alert -->
                <% if (operationPercentage > 0) { %>
                <div class="checkout-fee-alert">
                    <i class="fas fa-info-circle"></i>
                    <div class="checkout-fee-text">
                        <strong class="font-cairo"><%= __('admin_settings_fee_label') %>:</strong>
                        <%= __('checkout_fee_breakdown', operationPercentage, institutionPercentage, gatewayPercentage) %>
                    </div>
                </div>
                <% } %>

                <!-- Payment Details -->
                <div class="checkout-block checkout-block-separated">
                    <label class="form-label-luxury">إعدادات العطاء</label>
                    <div class="checkout-settings">
                        <div class="form-group checkout-anonymous-row">
                            <div class="checkout-anonymous-info">
                                <i class="fas fa-user-secret"></i>
                                <div>
                                    <span class="checkout-anonymous-title">إخفاء هويتي (تبرع مجهول)</span>
                                    <span class="checkout-anonymous-desc">لن يظهر اسمك في جدار الداعمين العلني</span>
                                </div>
                            </div>
                            <label class="switch-lux">
                                <input type="checkbox" name="isAnonymous" value="true">
                                <span class="slider-lux"></span>
                            </label>
                        </div>
                        
                        <div class="form-group">
                            <label class="form-label-luxury checkout-small-label">كلمة تحفيز للأهل (اختياري)</label>
                            <textarea name="encouragementMessage" class="form-input checkout-message" placeholder="اكتب كلمة طيبة تشجع بها اليتيم أو الأسرة..."></textarea>
                        </div>
                    </div>
                </div>

                <!-- Stripe Checkout Details -->
                <div class="checkout-block checkout-block-separated">
                    <label class="form-label-luxury">الدفع عبر Stripe Checkout</label>
                    <div class="checkout-fee-alert" style="margin-bottom: 0;">
                        <i class="fas fa-shield-halved"></i>
                        <div class="checkout-fee-text">
                            <strong class="font-cairo">بوابة دفع مؤمنة:</strong>
                            سيتم تحويلك إلى صفحة Stripe لإدخال بيانات البطاقة بشكل آمن دون تخزينها داخل النظام.
                        </div>
                    </div>

                    <!-- Phase 3: Cover Fees Toggle -->
                    <div class="checkout-cover-fees" id="coverFeesBtn">
                        <div id="feeToggleTrack" class="fee-toggle-track">
                            <div id="feeToggleCircle" class="fee-toggle-circle"></div>
                        </div>
                        <input type="checkbox" id="coverFeesCheckbox" name="isFeeCovered" value="true" checked style="display: none;">
                        <div class="checkout-cover-fees-content">
                            <div class="checkout-cover-fees-title">تغطية رسوم المعاملة</div>
                            <div class="checkout-cover-fees-desc">أضف مبلغاً بسيطاً لضمان وصول 100% من تبرعك للحالة.</div>
                        </div>
                    </div>
                </div>

                <button type="button" id="submitDonationBtn" class="btn-lux btn-lux-primary checkout-submit-btn">
                    <i class="fas fa-heart"></i> تأكيد العطاء الإنساني
                </button>
            </form>
        </div>

        <!-- Right Column: Summary Card -->
        <div class="summary-column">
            <div class="luxury-card glass-panel summary-sticky">
                <img src="<%= foundCase.image || '/assets/images/placeholder-case.jpg' %>" class="checkout-summary-image">
                
                <h4 class="font-cairo checkout-summary-title"><%= foundCase.title %></h4>
                
                <div class="summary-details">
                    <div class="summary-row">
                        <span>نوع الدعم:</span>
                        <strong id="summaryTypeLabel"><%= type === 'monthly' ? 'كفالة شهرية' : 'تبرع مباشر' %></strong>
                    </div>
                    <div class="summary-row">
                        <span>قيمة المساهمة:</span>
                        <strong id="summaryAmountLabel" style="color: var(--primary);">$<%= amount %></strong>
                    </div>
                    <div class="summary-row" style="color: var(--text-muted); font-size: 0.85rem;">
                        <span><%= __('admin_settings_fee_label') %> (<%= operationPercentage %>%):</span>
                        <strong id="summaryFeeAmount">$0.00</strong>
                    </div>
                    <div id="feeBreakdown" class="checkout-fee-breakdown" style="text-align: <%= langDir === 'rtl' ? 'left' : 'right' %>;">
                        (<%= institutionPercentage %>% <%= __('admin_settings_institution_fee_label').replace(' (%)', '') %> + <%= gatewayPercentage %>% <%= __('admin_settings_gateway_fee_label').replace(' (%)', '') %>)
                    </div>
                    <div class="summary-row" style="border-top: 2px solid rgba(0,0,0,0.05); padding-top: 10px; margin-top: 10px;">
                        <span style="font-weight: 800; color: var(--primary);">الإجمالي المطلوب:</span>
                        <strong id="summaryTotalAmount" style="color: var(--secondary); font-size: 1.4rem;">$<%= amount %></strong>
                    </div>
                    <% if (type === 'monthly') { %>
                    <div class="summary-row" id="monthlyNote" style="font-size: 0.8rem; color: var(--text-muted); border-top: 1px dashed #eee; padding-top: 10px; margin-top: 10px;">
                        <i class="fas fa-info-circle"></i> سيتم استقطاع هذا المبلغ شهرياً لدعم الحالة.
                    </div>
                    <% } %>
                </div>

                <div class="trust-badges checkout-trust">
                    <div class="checkout-trust-text">
                        <i class="fas fa-lock"></i> تشفير آمن 256-بت بمعايير PCI-DSS
                    </div>
                    <div class="checkout-trust-icons">
                        <i class="fab fa-cc-visa fa-lg"></i>
                        <i class="fab fa-cc-mastercard fa-lg"></i>
                        <i class="fab fa-cc-stripe fa-lg"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
</main>

<style>
    .checkout-page {
        background: var(--bg-subtle);
        min-height: 100vh;
    }
    .checkout-wrap {
        padding-top: 110px;
        padding-bottom: 90px;
        max-width: 1120px;
    }
    .checkout-hero {
        margin-bottom: 26px;
        padding: 34px;
        position: relative;
        overflow: hidden;
        border: 1px solid rgba(16,185,129,0.25);
    }
    .checkout-hero-bg {
        position: absolute;
        inset: 0;
        background:
            radial-gradient(circle at 10% 10%, rgba(16,185,129,0.18), transparent 35%),
            radial-gradient(circle at 90% 90%, rgba(10,37,64,0.15), transparent 40%);
    }
    .checkout-hero-content { position: relative; z-index: 2; }
    .checkout-title { margin-bottom: 8px; }
    .checkout-subtitle { max-width: 700px; }
    .checkout-stripe-ready {
        margin-top: 16px;
        display: inline-flex;
        align-items: center;
        gap: 10px;
        padding: 10px 14px;
        background: rgba(99, 102, 241, 0.08);
        border: 1px dashed rgba(99, 102, 241, 0.4);
        border-radius: 12px;
        color: #3730a3;
        font-size: 0.85rem;
        font-weight: 700;
    }

    .form-label-luxury { 
        display: block; 
        margin-bottom: 12px; 
        font-weight: 800; 
        color: var(--primary); 
        font-size: 0.95rem; 
        font-family: 'Cairo', sans-serif;
    }
    .checkout-form-card { padding: 35px; }
    .luxury-grid-checkout {
        display: grid;
        grid-template-columns: 1.2fr 0.8fr;
        gap: 26px;
        align-items: start;
    }
    .checkout-block { margin-bottom: 35px; }
    .checkout-block-separated {
        border-top: 1px solid rgba(0,0,0,0.05);
        padding-top: 30px;
    }
    .amount-presets {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 10px;
        margin-bottom: 15px;
    }
    .checkout-fee-alert {
        margin-bottom: 25px;
        padding: 15px;
        background: rgba(226, 176, 100, 0.1);
        border-radius: 12px;
        border: 1px dashed var(--secondary);
        display: flex;
        gap: 12px;
        align-items: flex-start;
    }
    .checkout-fee-alert i { color: var(--secondary); margin-top: 3px; }
    .checkout-fee-text {
        font-size: 0.85rem;
        color: var(--primary);
        line-height: 1.5;
    }
    .checkout-settings { display: flex; gap: 20px; flex-direction: column; }
    .checkout-anonymous-row {
        background: #f8fafc;
        padding: 15px;
        border-radius: 12px;
        border: 1px solid #e2e8f0;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 14px;
    }
    .checkout-anonymous-info {
        display: flex;
        align-items: center;
        gap: 10px;
    }
    .checkout-anonymous-info i {
        color: var(--primary);
        font-size: 1.2rem;
    }
    .checkout-anonymous-title {
        display: block;
        font-weight: 800;
        font-size: 0.9rem;
    }
    .checkout-anonymous-desc {
        display: block;
        font-size: 0.72rem;
        color: var(--text-muted);
    }
    .checkout-small-label { font-size: 0.85rem; }
    .checkout-message {
        height: 88px;
        resize: none;
        padding: 12px;
    }
    .checkout-field { margin-bottom: 20px; }
    .checkout-field-icon { position: relative; }
    .checkout-field-icon i {
        position: absolute;
        left: 15px;
        top: 50%;
        transform: translateY(-50%);
        color: var(--text-light);
        opacity: 0.5;
    }
    .checkout-grid-2 {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
    }
    .checkout-cover-fees {
        margin-top: 25px;
        padding: 15px;
        background: #f8fafc;
        border-radius: 12px;
        border: 1px solid #e2e8f0;
        display: flex;
        align-items: center;
        gap: 12px;
        cursor: pointer;
    }
    .fee-toggle-track {
        flex-shrink: 0;
        position: relative;
        width: 44px;
        height: 24px;
        background: var(--secondary);
        border-radius: 12px;
        transition: 0.3s;
    }
    .fee-toggle-circle {
        position: absolute;
        left: 22px;
        top: 2px;
        width: 20px;
        height: 20px;
        background: white;
        border-radius: 50%;
        transition: 0.3s;
    }
    .checkout-cover-fees-content { flex-grow: 1; }
    .checkout-cover-fees-title {
        font-weight: 800;
        font-size: 0.85rem;
        color: var(--primary);
    }
    .checkout-cover-fees-desc {
        font-size: 0.72rem;
        color: var(--text-muted);
        line-height: 1.3;
    }
    .checkout-submit-btn {
        width: 100%;
        justify-content: center;
        padding: 20px;
        margin-top: 35px;
        font-size: 1.15rem;
        gap: 12px;
        border-radius: 15px;
    }
    .checkout-summary-image {
        width: 100%;
        height: 190px;
        object-fit: cover;
        border-radius: 20px;
        margin-bottom: 20px;
        border: 1px solid rgba(255,255,255,0.5);
        box-shadow: 0 15px 30px rgba(2,6,23,0.08);
    }
    .checkout-summary-title {
        margin-bottom: 15px;
        color: var(--primary);
    }
    .checkout-fee-breakdown {
        font-size: 0.75rem;
        color: var(--text-light);
        margin-top: -8px;
        margin-bottom: 10px;
        opacity: 0.8;
    }
    .checkout-trust {
        margin-top: 30px;
        text-align: center;
        border-top: 1px solid rgba(0,0,0,0.05);
        padding-top: 20px;
    }
    .checkout-trust-text {
        font-size: 0.75rem;
        color: var(--text-muted);
        margin-bottom: 15px;
    }
    .checkout-trust-icons {
        display: flex;
        justify-content: center;
        gap: 15px;
        opacity: 0.6;
    }

    .type-selector-luxury {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 15px;
    }

    .type-option {
        padding: 20px;
        border-radius: 18px;
        background: #f8fafc;
        border: 2px solid #e2e8f0;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 15px;
        transition: all 0.3s var(--ease-smooth);
    }

    .type-option i {
        font-size: 1.5rem;
        color: var(--text-muted);
        transition: all 0.3s;
    }

    .type-option.active {
        border-color: var(--secondary);
        background: rgba(226, 176, 100, 0.05);
        box-shadow: 0 5px 15px rgba(226, 176, 100, 0.1);
    }

    .type-option.active i {
        color: var(--secondary);
        transform: scale(1.1);
    }

    .type-title { display: block; font-weight: 800; color: var(--primary); font-size: 0.95rem; }
    .type-desc { display: block; font-size: 0.75rem; color: var(--text-muted); }

    .preset-btn {
        padding: 12px;
        border: 1px solid #e2e8f0;
        border-radius: 12px;
        text-align: center;
        cursor: pointer;
        font-weight: 700;
        transition: all 0.2s;
        background: white;
    }

    .preset-btn:hover, .preset-btn.active {
        background: var(--primary);
        color: white;
        border-color: var(--primary);
    }

    .custom-amount-group {
        position: relative;
    }

    .custom-amount-group .currency-label {
        position: absolute;
        left: 20px;
        top: 50%;
        transform: translateY(-50%);
        font-weight: 800;
        color: var(--secondary);
    }

    .summary-row {
        display: flex;
        justify-content: space-between;
        margin-bottom: 10px;
        font-size: 0.95rem;
    }

    .summary-sticky {
        position: sticky;
        top: 100px;
        padding: 25px;
        border-radius: 25px;
    }

    .switch-lux {
        position: relative;
        display: inline-block;
        width: 50px;
        height: 26px;
    }

    .switch-lux input { 
        opacity: 0;
        width: 0;
        height: 0;
    }

    .slider-lux {
        position: absolute;
        cursor: pointer;
        top: 0; left: 0; right: 0; bottom: 0;
        background-color: #cbd5e1;
        transition: .4s;
        border-radius: 34px;
    }

    .slider-lux:before {
        position: absolute;
        content: "";
        height: 18px;
        width: 18px;
        left: 4px;
        bottom: 4px;
        background-color: white;
        transition: .4s;
        border-radius: 50%;
    }

    input:checked + .slider-lux {
        background-color: var(--secondary);
    }

    input:checked + .slider-lux:before {
        transform: translateX(24px);
    }

    @media (max-width: 991px) {
        .luxury-grid-checkout { grid-template-columns: 1fr; }
        .summary-column { order: -1; }
        .summary-sticky { position: static; margin-bottom: 30px; }
        .checkout-wrap { padding-top: 95px; }
        .checkout-hero { padding: 24px; }
        .checkout-form-card { padding: 24px; }
    }
    @media (max-width: 640px) {
        .type-selector-luxury { grid-template-columns: 1fr; }
        .amount-presets { grid-template-columns: repeat(2, 1fr); }
        .checkout-grid-2 { grid-template-columns: 1fr; gap: 14px; }
    }

    /* Modal Overlay Styles */
    .modal-overlay-luxury {
        position: fixed;
        inset: 0;
        background: rgba(2, 6, 23, 0.7);
        backdrop-filter: blur(8px);
        display: none;
        align-items: center;
        justify-content: center;
        z-index: 9999;
        padding: 20px;
    }

    .modal-content-luxury {
        animation: modalSlideUp 0.4s var(--ease-smooth);
    }

    @keyframes modalSlideUp {
        from { transform: translateY(30px); opacity: 0; }
        to { transform: translateY(0); opacity: 1; }
    }
</style>

<!-- Invoice Confirmation Modal -->
<div id="invoiceModal" class="modal-overlay-luxury" style="display: none;">
    <div class="luxury-card modal-content-luxury" style="max-width: 500px; width: 90%; padding: 0; overflow: hidden;">
        <div style="background: var(--grad-navy); padding: 30px; text-align: center; color: white;">
            <i class="fas fa-file-invoice-dollar" style="font-size: 3rem; margin-bottom: 15px; opacity: 0.8;"></i>
            <h3 class="font-cairo" style="margin: 0; font-weight: 800;">فاتورة التبرع المبدئية</h3>
            <p style="margin: 5px 0 0 0; font-size: 0.85rem; opacity: 0.7;">يرجى مراجعة تفاصيل عطاءك قبل الإتمام</p>
        </div>
        
        <div style="padding: 30px;">
            <div style="margin-bottom: 25px;">
                <div style="display: flex; justify-content: space-between; margin-bottom: 12px; font-size: 0.95rem;">
                    <span style="color: var(--text-muted);">الحالة المستفيدة:</span>
                    <strong style="color: var(--primary);"><%= foundCase.title %></strong>
                </div>
                <div style="display: flex; justify-content: space-between; margin-bottom: 12px; font-size: 0.95rem;">
                    <span style="color: var(--text-muted);">نوع المساهمة:</span>
                    <strong id="modalType" style="color: var(--primary);">تبرع مباشر</strong>
                </div>
                <hr style="border: 0; border-top: 1px dashed #eee; margin: 15px 0;">
                <div style="display: flex; justify-content: space-between; margin-bottom: 12px; font-size: 1rem;">
                    <span style="color: var(--text-muted);">مبلغ المساهمة:</span>
                    <strong id="modalBaseAmount" style="color: var(--primary); font-weight: 800;">$0.00</strong>
                </div>
                <div style="display: flex; justify-content: space-between; margin-bottom: 12px; font-size: 0.9rem;">
                    <span style="color: var(--text-muted);"><%= __('admin_settings_institution_fee_label') %> (<%= institutionPercentage %>%):</span>
                    <strong id="modalInstFeeAmount" style="color: var(--primary);">$0.00</strong>
                </div>
                <div style="display: flex; justify-content: space-between; margin-bottom: 12px; font-size: 0.9rem;">
                    <span style="color: var(--text-muted);"><%= __('admin_settings_gateway_fee_label') %> (<%= gatewayPercentage %>%):</span>
                    <strong id="modalGateFeeAmount" style="color: var(--primary);">$0.00</strong>
                </div>
                <div style="display: flex; justify-content: space-between; margin-bottom: 12px; font-size: 0.9rem; border-top: 1px solid #f1f5f9; pt-2;">
                    <span style="color: var(--text-muted); font-weight: 700;"><%= __('admin_settings_fee_label') %> (<%= operationPercentage %>%):</span>
                    <strong id="modalFeeAmount" style="color: var(--secondary); font-weight: 800;">$0.00</strong>
                </div>
                <div style="display: flex; justify-content: space-between; margin-top: 20px; padding-top: 15px; border-top: 2px solid #f8fafc; font-size: 1.3rem;">
                    <span style="font-weight: 800; color: var(--primary);">الإجمالي كلياً:</span>
                    <strong id="modalTotalAmount" style="color: var(--secondary); font-weight: 900;">$0.00</strong>
                </div>
            </div>

            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px;">
                <button id="cancelModalBtn" class="btn-lux btn-lux-navy" style="justify-content: center; padding: 12px;">إلغاء</button>
                <button id="confirmModalBtn" class="btn-lux btn-lux-primary" style="justify-content: center; padding: 12px;">تأكيد الدفع</button>
            </div>
        </div>
    </div>
</div>

<script>
    // Robust variable initialization
    let currentType = '<%= typeof type !== "undefined" ? type : "direct" %>';
    let currentAmount = Number('<%= typeof amount !== "undefined" ? amount : 50 %>') || 50;
    const jsInstPercentage = Number('<%= typeof institutionPercentage !== "undefined" ? institutionPercentage : 0 %>') || 0;
    const jsGatePercentage = Number('<%= typeof gatewayPercentage !== "undefined" ? gatewayPercentage : 0 %>') || 0;
    const jsOperationPercentage = jsInstPercentage + jsGatePercentage;
    let isFeeCovered = true;

    // Core Calculation & UI Update
    function calculateTotal() {
        const fee = (currentAmount * jsOperationPercentage) / 100;
        let total = isFeeCovered ? (currentAmount + fee) : currentAmount;
        
        // Update Summary Labels
        const feeLabel = document.getElementById('summaryFeeAmount');
        if (feeLabel) {
            if (isFeeCovered) {
                feeLabel.innerText = '$' + fee.toFixed(2);
                feeLabel.style.color = 'var(--secondary)';
            } else {
                feeLabel.innerText = 'خصم من التبرع (-$' + fee.toFixed(2) + ')';
                feeLabel.style.color = '#ef4444';
            }
        }
        
        const totalLabel = document.getElementById('summaryTotalAmount');
        if (totalLabel) totalLabel.innerText = '$' + total.toFixed(2);
        
        const amountLabel = document.getElementById('summaryAmountLabel');
        if (amountLabel) amountLabel.innerText = '$' + currentAmount.toFixed(2);
        
        // Update Hidden Field
        const finalAmountInput = document.getElementById('finalAmount');
        if (finalAmountInput) finalAmountInput.value = currentAmount;
    }

    function toggleCoverFees() {
        isFeeCovered = !isFeeCovered;
        const checkbox = document.getElementById('coverFeesCheckbox');
        if (checkbox) checkbox.checked = isFeeCovered;
        
        // UI Toggle Animation/Style
        const track = document.getElementById('feeToggleTrack');
        const circle = document.getElementById('feeToggleCircle');
        if (track && circle) {
            track.style.background = isFeeCovered ? 'var(--secondary)' : '#cbd5e1';
            circle.style.left = isFeeCovered ? '22px' : '2px';
        }
        
        calculateTotal();
    }

    function setDonationType(type) {
        currentType = type;
        const typeInput = document.getElementById('finalType');
        if (typeInput) typeInput.value = type;
        
        // Update UI Tabs
        const typeMonthly = document.getElementById('typeMonthly');
        if (typeMonthly) typeMonthly.classList.toggle('active', type === 'monthly');
        
        const typeDirect = document.getElementById('typeDirect');
        if (typeDirect) typeDirect.classList.toggle('active', type === 'direct');
        
        const typeLabel = document.getElementById('summaryTypeLabel');
        if (typeLabel) typeLabel.innerText = (type === 'monthly') ? 'كفالة شهرية' : 'تبرع مباشر';
        
        // Monthly Note Management
        const note = document.getElementById('monthlyNote');
        if (type === 'monthly' && !note) {
            const newNote = document.createElement('div');
            newNote.id = 'monthlyNote';
            newNote.className = 'summary-row';
            newNote.style = 'font-size: 0.8rem; color: var(--text-muted); border-top: 1px dashed #eee; padding-top: 10px; margin-top: 10px;';
            newNote.innerHTML = '<i class="fas fa-info-circle"></i> سيتم استقطاع هذا المبلغ شهرياً لدعم الحالة.';
            const summaryDetails = document.querySelector('.summary-details');
            if (summaryDetails) summaryDetails.appendChild(newNote);
        } else if (type === 'direct' && note) {
            note.remove();
        }
        calculateTotal();
    }

    function setAmount(amount) {
        currentAmount = Number(amount);
        const customInput = document.getElementById('customAmountInput');
        if (customInput) customInput.value = currentAmount;
        
        // Update Presets UI
        document.querySelectorAll('.preset-btn').forEach(btn => {
            const btnVal = btn.innerText.replace('$', '').trim();
            btn.classList.toggle('active', Number(btnVal) === currentAmount);
        });
        
        calculateTotal();
    }

    function updateAmountFromInput(val) {
        currentAmount = Number(val) || 0;
        // Clear preset selection when custom input is used and doesn't match a preset
        document.querySelectorAll('.preset-btn').forEach(btn => btn.classList.remove('active'));
        calculateTotal();
    }

    function focusCustom() {
        const input = document.getElementById('customAmountInput');
        if (input) input.focus();
    }

    // Modal Confirmation Logic
    function showInvoicePreview(e) {
        if (e) e.preventDefault();
        
        if (currentAmount <= 0) {
            alert('يرجى تحديد مبلغ التبرع بشكل صحيح');
            return false;
        }

        const instFee = (currentAmount * jsInstPercentage) / 100;
        const gateFee = (currentAmount * jsGatePercentage) / 100;
        const totalFee = instFee + gateFee;
        let finalDisplayTotal = isFeeCovered ? (currentAmount + totalFee) : currentAmount;

        // Populate Modal Fields
        const modalBase = document.getElementById('modalBaseAmount');
        const modalInst = document.getElementById('modalInstFeeAmount');
        const modalGate = document.getElementById('modalGateFeeAmount');
        const modalFee = document.getElementById('modalFeeAmount');
        const modalTotal = document.getElementById('modalTotalAmount');
        const modalType = document.getElementById('modalType');

        if (modalBase) modalBase.innerText = '$' + currentAmount.toFixed(2);
        if (modalInst) modalInst.innerText = '$' + instFee.toFixed(2);
        if (modalGate) modalGate.innerText = '$' + gateFee.toFixed(2);
        if (modalFee) modalFee.innerText = '$' + totalFee.toFixed(2) + (isFeeCovered ? '' : ' (سيتم خصمها)');
        if (modalTotal) modalTotal.innerText = '$' + finalDisplayTotal.toFixed(2);
        if (modalType) modalType.innerText = currentType === 'monthly' ? 'كفالة شهرية' : 'تبرع مباشر';
        
        // Show Modal
        const modal = document.getElementById('invoiceModal');
        if (modal) {
            modal.style.display = 'flex';
            document.body.style.overflow = 'hidden'; // Prevent background scroll
        }
    }

    function closeInvoiceModal() {
        const modal = document.getElementById('invoiceModal');
        if (modal) {
            modal.style.display = 'none';
            document.body.style.overflow = 'auto';
        }
    }

    function confirmDonation() {
        document.getElementById('payment-form').submit();
    }

    // Initialize UI on load
    window.addEventListener('DOMContentLoaded', () => {
        calculateTotal();

        // Attach Event Listeners to comply with CSP (No inline scripts)
        const typeMonthlyBtn = document.getElementById('typeMonthly');
        if (typeMonthlyBtn) typeMonthlyBtn.addEventListener('click', () => setDonationType('monthly'));
        
        const typeDirectBtn = document.getElementById('typeDirect');
        if (typeDirectBtn) typeDirectBtn.addEventListener('click', () => setDonationType('direct'));

        document.querySelectorAll('.preset-amount').forEach(btn => {
            btn.addEventListener('click', function() {
                setAmount(this.getAttribute('data-amount'));
            });
        });

        const presetCustomBtn = document.querySelector('.preset-custom');
        if (presetCustomBtn) presetCustomBtn.addEventListener('click', focusCustom);

        const customInputEl = document.getElementById('customAmountInput');
        if (customInputEl) {
            customInputEl.addEventListener('input', function() {
                updateAmountFromInput(this.value);
            });
        }

        const coverFeesBtn = document.getElementById('coverFeesBtn');
        if (coverFeesBtn) coverFeesBtn.addEventListener('click', toggleCoverFees);

        const submitDonBtn = document.getElementById('submitDonationBtn');
        if (submitDonBtn) submitDonBtn.addEventListener('click', showInvoicePreview);

        const cancelModBtn = document.getElementById('cancelModalBtn');
        if (cancelModBtn) cancelModBtn.addEventListener('click', closeInvoiceModal);

        const confirmModBtn = document.getElementById('confirmModalBtn');
        if (confirmModBtn) confirmModBtn.addEventListener('click', confirmDonation);
    });
</script>

