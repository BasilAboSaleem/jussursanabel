<%- include('../partials/header-top') %>

<main class="container" style="min-height: 70vh; display: flex; align-items: center; justify-content: center;">
    <div class="luxury-card glass-panel" style="padding: 60px 40px; text-align: center; max-width: 600px; border: 2px dashed var(--secondary);">
        <div style="font-size: 5rem; color: var(--secondary); margin-bottom: 25px; opacity: 0.8;">
            <i class="fas fa-ghost"></i>
        </div>
        <h1 class="font-cairo" style="font-size: 3.5rem; color: var(--primary); margin-bottom: 15px; font-weight: 900;">
            <%= title %>
        </h1>
        <p style="font-size: 1.2rem; color: var(--text-muted); margin-bottom: 40px; line-height: 1.8;">
            <%= message %>
        </p>
        <div style="display: flex; gap: 15px; justify-content: center;">
            <a href="/" class="btn-lux btn-lux-primary">
                <i class="fas fa-house"></i> العودة للرئيسية
            </a>
            <a href="/support" class="btn-lux btn-lux-outline">
                <i class="fas fa-headset"></i> اتصل بالدعم
            </a>
        </div>
    </div>
</main>

<%- include('../partials/footer-bottom') %>