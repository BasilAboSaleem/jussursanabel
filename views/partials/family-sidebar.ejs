<aside class="admin-sidebar" id="familySidebar">
    <div class="admin-sidebar-header">
        <a href="/" class="logo-luxury" style="color: white; font-size: 1.3rem;">
            <img src="/logoSanabel.png" alt="سُبُل" style="height: 32px; width: auto; border-radius: 8px;">
            <span class="font-cairo">سُبُل</span>
        </a>
    </div>

    <div class="admin-sidebar-nav">
        <div class="admin-nav-group-label" style="color: var(--secondary-light); font-size: 0.8rem; opacity: 0.9;">بوابة المستفيدين (الأمل)</div>
        
        <a href="/dashboard" class="admin-nav-item <%= (typeof title !== 'undefined' && (title === 'لوحة تحكم الأسرة' || title === 'لوحة تحكم المستفيد')) ? 'active' : '' %>">
            <i class="fas fa-home"></i>
            <span>الرئيسية</span>
        </a>

        <div class="admin-nav-group-label">إدارة الطلبات</div>
        <a href="/cases/register" class="admin-nav-item <%= (typeof title !== 'undefined' && title === 'تسجيل حالة جديدة') ? 'active' : '' %>">
            <i class="fas fa-file-circle-plus"></i>
            <span>تقديم طلب جديد</span>
        </a>
        
        <a href="/dashboard#cases" class="admin-nav-item">
            <i class="fas fa-folder-open"></i>
            <span>طلباتي السابقة</span>
        </a>

        <div class="admin-nav-group-label">التواصل</div>
        <a href="/messages" class="admin-nav-item <%= (typeof title !== 'undefined' && (title === 'الرسائل' || title.includes('المحادثة'))) ? 'active' : '' %>">
            <i class="fas fa-comments"></i>
            <span>مركز الرسائل</span>
            <span id="sidebar-unread-count" class="badge badge-danger <%= (typeof unreadCount === 'undefined' || unreadCount === 0) ? 'd-none' : '' %>" style="margin-right: auto; padding: 2px 8px; font-size: 0.7rem;">
                <%= (typeof unreadCount !== 'undefined') ? unreadCount : 0 %>
            </span>
            <span id="sidebar-active-status" class="badge badge-gold <%= (typeof unreadCount !== 'undefined' && unreadCount > 0) ? 'd-none' : '' %>" style="margin-right: auto; padding: 2px 8px; font-size: 0.7rem;">نشط</span>
        </a>

        <div class="admin-nav-group-label">الحساب</div>
        <a href="/profile/settings" class="admin-nav-item <%= (typeof title !== 'undefined' && title === 'إعدادات الحساب') ? 'active' : '' %>">
            <i class="fas fa-user-gear"></i>
            <span>إعدادات الحساب</span>
        </a>
        <a href="/auth/logout" class="admin-nav-item" style="color: #ef4444;">
            <i class="fas fa-sign-out-alt"></i>
            <span>تسجيل الخروج</span>
        </a>
    </div>

    <div class="admin-sidebar-footer">
        <% if (user) { %>
        <div style="display: flex; align-items: center; gap: 10px;">
            <div style="width: 35px; height: 35px; border-radius: 50%; background: var(--accent); display: flex; align-items: center; justify-content: center; color: white; font-weight: 800;">
                <%= user.name ? user.name.charAt(0) : 'U' %>
            </div>
            <div style="font-size: 0.85rem;">
                <div style="font-weight: 700; color: white;"><%= user.name %></div>
                <div style="color: rgba(255,255,255,0.4); font-size: 0.75rem;">مستفيد مسجل</div>
            </div>
        </div>
        <% } %>
    </div>
</aside>
