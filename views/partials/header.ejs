<header class="premium-nav">
    <a href="/" class="logo-luxury">
        <img src="/logoSanabel.png" alt="سُبُل">
        <span class="font-cairo"><%= __('hero_title') %></span>
    </a>

    <!-- Mobile Menu Toggle & Lang Switcher -->
    <div style="display: flex; align-items: center; gap: 10px; margin-inline-start: auto;">
        <style>
            .mobile-lang-wrapper { display: none; }
            @media (max-width: 992px) { .mobile-lang-wrapper { display: block; } }
        </style>
        <div class="lang-dropdown-lux mobile-lang-wrapper" style="position: relative;">
            <button id="mobileLangToggleBtn" style="background: none; border: none; font-size: 1.3rem; color: var(--primary); cursor: pointer; padding: 5px;">
                <i class="fas fa-globe"></i>
            </button>
            <div id="mobileLangMenu" class="shadow-sm" style="display: none; position: absolute; top: calc(100% + 15px); <%= locals.langDir === 'ltr' ? 'left' : 'right' %>: -10px; background: white; border-radius: 10px; padding: 8px; min-width: 140px; z-index: 1000; border: 1px solid rgba(0,0,0,0.05);">
                <a href="/lang/ar" style="display: flex; justify-content: space-between; align-items: center; padding: 10px 15px; text-decoration: none; background: <%= locals.currentLocale === 'ar' ? 'var(--secondary)' : 'transparent' %>; color: <%= locals.currentLocale === 'ar' ? '#fff' : 'var(--primary)' %>; border-radius: 6px; font-size: 0.95rem; font-weight: 800; margin-bottom: 5px;">
                    العربية <i class="fas fa-check" style="opacity: <%= locals.currentLocale === 'ar' ? '1' : '0' %>;"></i>
                </a>
                <a href="/lang/en" style="display: flex; justify-content: space-between; align-items: center; padding: 10px 15px; text-decoration: none; background: <%= locals.currentLocale === 'en' ? 'var(--secondary)' : 'transparent' %>; color: <%= locals.currentLocale === 'en' ? '#fff' : 'var(--primary)' %>; border-radius: 6px; font-size: 0.95rem; font-weight: 800;">
                    English <i class="fas fa-check" style="opacity: <%= locals.currentLocale === 'en' ? '1' : '0' %>;"></i>
                </a>
            </div>
        </div>
        <button class="mobile-menu-toggle" id="mobileMenuBtn" style="margin-right: 0;">
            <i class="fas fa-bars"></i>
        </button>
    </div>

    <nav class="nav-links-luxury" id="navLinks">
        <a href="/" class="nav-link-luxury"><%= __('home') %></a>
        <a href="/cases" class="nav-link-luxury"><%= __('cases') %></a>
        <a href="https://www.senabil-pal.org/ar/about" class="nav-link-luxury"><%= __('about_us') %></a>
        <a href="/transparency" class="nav-link-luxury"><%= __('navbar_transparency') %></a>
        <a href="/contact" class="nav-link-luxury"><%= __('navbar_contact') %></a>
        
        <!-- Mobile Actions -->
        <div class="mobile-only-actions" style="display: none; padding: 15px; border-top: 1px solid #eee; margin-top: 15px;">
            <% if (user) { %>
                <a href="/dashboard" class="btn-lux btn-lux-primary" style="width: 100%; justify-content: center; margin-bottom: 10px;"><%= __('dashboard') %></a>
                <a href="/auth/logout" class="btn-lux btn-lux-outline" style="width: 100%; justify-content: center;"><%= __('navbar_logout') %></a>
            <% } else { %>
                <a href="/auth/login" class="btn-lux btn-lux-outline" style="width: 100%; justify-content: center; margin-bottom: 10px;"><%= __('navbar_login') %></a>
                <a href="/auth/register" class="btn-lux btn-lux-primary" style="width: 100%; justify-content: center;"><%= __('navbar_register') %></a>
            <% } %>
        </div>
    </nav>

    <div class="nav-actions-luxury" style="display: flex; gap: 15px; align-items: center; flex-shrink: 0;">
        <% if (user) { %>
            <div style="display: flex; align-items: center; gap: 12px; background: rgba(16, 185, 129, 0.05); padding: 6px 16px; border-radius: 50px; border: 1px solid rgba(16, 185, 129, 0.15);">
                <span style="font-size: 0.85rem; font-weight: 800; color: var(--primary); white-space: nowrap; max-width: 140px; overflow: hidden; text-overflow: ellipsis;"><%= user.name %></span>
                <a href="/dashboard" class="btn-lux btn-lux-primary btn-sm" style="padding: 8px 18px; font-size: 0.8rem; background: var(--grad-green);">
                    <i class="fas fa-user-circle"></i> <%= __('dashboard') %>
                </a>
            </div>
            <a href="/auth/logout" style="color: var(--text-muted); font-size: 1.2rem;" title="<%= __('navbar_logout') %>"><i class="fas fa-sign-out-alt"></i></a>
        <% } else { %>
            <a href="/auth/login" style="color: var(--primary); text-decoration: none; font-weight: 800; font-size: 0.95rem;"><%= __('navbar_login') %></a>
            <a href="/auth/register" class="btn-lux btn-lux-primary btn-sm" style="background: var(--grad-green); padding: 12px 28px;">
                <%= __('navbar_register') %> <i class="fas fa-arrow-<%= locals.langDir === 'ltr' ? 'right' : 'left' %>" style="font-size: 0.8rem; margin: 0 8px;"></i>
            </a>
        <% } %>

        <!-- Language Switcher Dropdown -->
        <div class="lang-dropdown-lux" style="position: relative; margin-inline-start: 10px; padding-inline-start: 15px; border-inline-start: 2px solid rgba(0,0,0,0.05);">
            <button id="langToggleBtn" style="background: none; border: none; font-size: 1.2rem; color: var(--primary); cursor: pointer; display: flex; align-items: center; transition: color 0.2s; padding: 5px;" title="تغيير اللغة">
                <i class="fas fa-globe"></i>
            </button>
            <div id="langMenu" class="shadow-sm" style="display: none; position: absolute; top: calc(100% + 15px); <%= locals.langDir === 'ltr' ? 'right' : 'left' %>: 0; background: white; border-radius: 10px; padding: 8px; min-width: 140px; z-index: 1000; border: 1px solid rgba(0,0,0,0.05);">
                <a href="/lang/ar" style="display: flex; justify-content: space-between; align-items: center; padding: 10px 15px; text-decoration: none; background: <%= locals.currentLocale === 'ar' ? 'var(--secondary)' : 'transparent' %>; color: <%= locals.currentLocale === 'ar' ? '#fff' : 'var(--primary)' %>; border-radius: 6px; font-size: 0.95rem; font-weight: 800; margin-bottom: 5px; transition: all 0.2s;">
                    العربية <i class="fas fa-check" style="opacity: <%= locals.currentLocale === 'ar' ? '1' : '0' %>;"></i>
                </a>
                <a href="/lang/en" style="display: flex; justify-content: space-between; align-items: center; padding: 10px 15px; text-decoration: none; background: <%= locals.currentLocale === 'en' ? 'var(--secondary)' : 'transparent' %>; color: <%= locals.currentLocale === 'en' ? '#fff' : 'var(--primary)' %>; border-radius: 6px; font-size: 0.95rem; font-weight: 800; transition: all 0.2s;">
                    English <i class="fas fa-check" style="opacity: <%= locals.currentLocale === 'en' ? '1' : '0' %>;"></i>
                </a>
            </div>
        </div>
    </div>
</header>

<script>
    document.getElementById('mobileMenuBtn')?.addEventListener('click', function() {
        document.getElementById('navLinks').classList.toggle('active');
        this.querySelector('i').classList.toggle('fa-bars');
        this.querySelector('i').classList.toggle('fa-times');
    });

    // Language Dropdown Toggle Logic
    const langToggleBtn = document.getElementById('langToggleBtn');
    const langMenu = document.getElementById('langMenu');
    if (langToggleBtn && langMenu) {
        langToggleBtn.addEventListener('click', (e) => {
            e.stopPropagation();
            langMenu.style.display = langMenu.style.display === 'none' ? 'block' : 'none';
        });
        langMenu.addEventListener('click', (e) => e.stopPropagation());
    }

    const mobileLangToggleBtn = document.getElementById('mobileLangToggleBtn');
    const mobileLangMenu = document.getElementById('mobileLangMenu');
    if (mobileLangToggleBtn && mobileLangMenu) {
        mobileLangToggleBtn.addEventListener('click', (e) => {
            e.stopPropagation();
            mobileLangMenu.style.display = mobileLangMenu.style.display === 'none' ? 'block' : 'none';
        });
        document.addEventListener('click', () => mobileLangMenu.style.display = 'none');
        mobileLangMenu.addEventListener('click', (e) => e.stopPropagation());
    }
</script>
