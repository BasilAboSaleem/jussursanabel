<html lang="<%= locals.currentLocale %>" dir="<%= locals.langDir %>">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title %> — <%= __('hero_title') %>
    </title>

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=Tajawal:wght@300;400;500;700;800;900&family=Cairo:wght@400;600;700;800;900&display=swap"
        rel="stylesheet">

    <!-- Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <!-- Global CSS -->
    <link rel="stylesheet" href="/assets/css/premium.css">

    <style>
        :root {
            --primary: #0f172a;
            --secondary: #fbbf24;
            /* Gold */
            --accent: #14b8a6;
            /* Teal */
            --grad-navy: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
        }

        body {
            font-family: 'Tajawal', sans-serif;
            background: #f8fafc;
            color: var(--primary);
            overflow-x: hidden;
        }

        .navbar-luxury {
            background: rgba(15, 23, 42, 0.95);
            backdrop-filter: blur(10px);
            padding: 15px 0;
            position: sticky;
            top: 0;
            z-index: 1000;
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
        }

        .footer-luxury {
            background: var(--primary);
            color: white;
            padding: 80px 0 30px;
        }
    </style>
</head>

<body>

    <%- include('../partials/header') %>

        <main>
            <%- body %>
        </main>

        <%- include('../partials/footer') %>

            <!-- Global Scripts -->
            <script src="/assets/js/main.js"></script>
</body>

</html>